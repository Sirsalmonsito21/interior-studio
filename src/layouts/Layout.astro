---
interface Props { title: string }
const { title } = Astro.props
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <slot />
    
    <script is:inline>
      if (history.scrollRestoration) {
        history.scrollRestoration = 'manual'
      }
      window.scrollTo(0, 0)
    </script>

    <script>
      import Lenis from 'lenis'
      import gsap from 'gsap'
      import { ScrollTrigger } from 'gsap/ScrollTrigger'

      // Registramos ScrollTrigger
      gsap.registerPlugin(ScrollTrigger)

      // Inicializamos Lenis
      const lenis = new Lenis({
        duration: 1.2, // El tiempo que tarda en frenar (fluidez premium)
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), 
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        wheelMultiplier: 1,
        touchMultiplier: 2,
      })

      // Sincronizamos Lenis con GSAP ScrollTrigger (vital para tus líneas SVG)
      lenis.on('scroll', ScrollTrigger.update)

      // Conectamos Lenis al ticker interno de GSAP
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000)
      })

      gsap.ticker.lagSmoothing(0)
    </script>
  </body>
</html>

<style is:global>
  html {
    /* Desactiva el scroll nativo a tirones del navegador */
    scroll-behavior: auto !important; 
  }
  html, body {
    min-height: 100%;
    height: auto;
  }
</style>