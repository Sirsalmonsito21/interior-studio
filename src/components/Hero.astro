---
// AQUÍ ELIGES LAS IMÁGENES Y EL ORDEN
// El primer bloque que pongas aquí será el primero en cargar en el video.
// Puedes cambiar el orden copiando y pegando los bloques { ... }
const slides = [
  {
    img: "/images/heroimagen.webp",
    typed: "tienen estilo.",
  },
  {
    img: "/images/cocina1-1.webp", 
    typed: "crean armonía.",
  },
  {
    img: "/images/niño1.webp",
    // FRASE MÁS CORTA PARA QUE NO ROMPA LA LÍNEA
    typed: "perduran.",
  },
]
---

<section class="hero" id="hero">
  <div class="hero__slides">
    {slides.map((s, i) => (
      <div 
        class="hero__slide" 
        data-index={i} 
        style={i === 0 ? "opacity: 1; z-index: 1;" : "opacity: 0; z-index: 0;"}
      >
        <img class="hero__slide-img" src={s.img} alt="Fondo Studio2810" />
        <div class="hero__slide-overlay"></div>
      </div>
    ))}
  </div>

  <div class="hero__content">
    <div class="hero__content-wrapper" id="heroTextWrapper">
      
      
      <h1 class="hero__title">
        <span>Espacios que </span><br>
        <span id="heroTyped" class="hero__typed"></span><span class="hero__cursor">|</span>
      </h1>
      
      
      <div class="hero__action">
        <a href="#portafolio" class="hero__btn">VER PORTAFOLIO</a>
      </div>
    </div>
  </div>

  <div class="hero__progress-container">
    <div class="hero__progress-bar" id="heroProgress"></div>
  </div>
</section>

<script is:inline define:vars={{ slidesData: slides }}>
  window.heroSlidesData = slidesData;
</script>

<style>
  /* Importamos Inter y Jost juntas */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Jost:wght@300;400;500&display=swap');

  .hero { position: relative; height: 100vh; width: 100%; overflow: hidden; background-color: #111; }

  /* IMÁGENES Y CAPAS */
  .hero__slides { position: absolute; inset: 0; }
  .hero__slide { position: absolute; inset: 0; }
  .hero__slide-img { width: 100%; height: 100%; object-fit: cover; transform-origin: center; will-change: transform; }
  .hero__slide-overlay { 
    position: absolute; inset: 0; 
    background: linear-gradient(90deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
  }

  /* TEXTOS FIJOS */
  .hero__content { position: absolute; top: 50%; left: 8vw; transform: translateY(-50%); z-index: 10; width: 90%; max-width: 750px; }
  .hero__content-wrapper { opacity: 0; /* Inicia oculto solo al recargar la web */ }
  
  .hero__eyebrow { font-family: 'Jost', sans-serif; font-size: 0.8rem; color: white; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1.5rem; opacity: 0.85; }
  
  /* NUEVA TIPOGRAFÍA Y TAMAÑO PARA EL TÍTULO */
  .hero__title { 
    font-family: 'Inter', sans-serif;
    font-size: clamp(3.8rem, 7vw, 6.2rem); /* Más grande */
    color: white; 
    font-weight: 400; 
    line-height: 1.1; 
    letter-spacing: -0.03em; /* Ajuste para que Inter se vea más premium */
    margin: 0; 
  }
  
  .hero__typed {
    background: linear-gradient(120deg, #aa8570 0%, #bda677 50%, #bdb59d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
    font-weight: 500;
  }
  .hero__cursor { 
    font-weight: 300; 
    animation: blink 1s step-end infinite; 
    color: #8A9A95;
  }
  
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .hero__desc { font-family: 'Jost', sans-serif; font-size: 1rem; color: rgba(255, 255, 255, 0.9); line-height: 1.6; margin-top: 1.5rem; max-width: 550px; }

  /* BOTÓN MÁS ABAJO */
  .hero__action { margin-top: 4.5rem; } 
  .hero__btn { display: inline-block; padding: 14px 35px; border: 1px solid rgba(255, 255, 255, 0.6); background: transparent; color: white; font-family: 'Jost', sans-serif; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; text-decoration: none; transition: all 0.3s ease; }
  .hero__btn:hover { background: white; color: black; border-color: white; }

  /* PROGRESO */
  .hero__progress-container { position: absolute; bottom: 2.5rem; left: 8vw; right: 8vw; height: 2px; background: rgba(255,255,255,0.2); z-index: 10; }
  .hero__progress-bar { height: 100%; width: 0%; background: white; }
  
  /* ========================================================
     REDISEÑO REACTIVE (iPads y Tablets max 1024px)
     ======================================================== */
  @media (max-width: 1024px) {
    .hero__eyebrow,
    .hero__desc {
      display: none;
    }
  }

  /* ========================================================
     REDISEÑO REACTIVE (Celulares max 768px)
     ======================================================== */
  @media (max-width: 768px) {
    .hero__content { 
      left: 50%;
      transform: translate(-50%, -50%); 
      width: 100%;
      padding: 0 5vw;
      text-align: center; 
    }
    
    .hero__action {
      display: flex;
      justify-content: center; 
      margin-top: 3rem; /* En celular no hace falta tanta separación */
    }

    .hero__progress-container { left: 5vw; right: 5vw; }
    
    .hero__title { 
      font-size: clamp(3rem, 9vw, 4rem); /* Proporcionalmente más grande en celular */
    }
  }
</style>

<script>
  import gsap from 'gsap';
  document.addEventListener('DOMContentLoaded', () => {
    const slideData = window.heroSlidesData;
    const slidesEls = document.querySelectorAll('.hero__slide');
    const images = document.querySelectorAll('.hero__slide-img');
    const wrapper = document.getElementById('heroTextWrapper');
    const progressBar = document.getElementById('heroProgress');
    const elTyped = document.getElementById('heroTyped');
    
    let current = 0;
    let typingInterval;

    // APARECEN TODOS LOS TEXTOS JUNTOS AL ENTRAR A LA WEB
    gsap.fromTo(wrapper, { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 1, ease: "power2.out" });
 
    // Zoom inicial de la primera imagen
    gsap.fromTo(images[0], { scale: 1 }, { scale: 1.1, duration: 15, ease: "none" });
    
    // Inicia el tipeo de la primera frase
    typeText(slideData[0].typed);

    function typeText(text) {
      let i = 0;
      elTyped.textContent = '';
      gsap.set(elTyped, { opacity: 1 });
      
      typingInterval = setInterval(() => {
        elTyped.textContent += text.charAt(i);
        i++;
        if (i >= text.length) {
          clearInterval(typingInterval);
          startWait(); 
        }
      }, 70);
    }

    function startWait() {
      gsap.fromTo(progressBar, 
        { width: '0%' }, 
        { width: '100%', duration: 5, ease: "none", onComplete: eraseAndTransition }
      );
    }

    function eraseAndTransition() {
      gsap.to(elTyped, { opacity: 0, duration: 0.4 });
      gsap.set(progressBar, { width: '0%' });

      const next = (current + 1) % slidesEls.length;
      const prevSlide = slidesEls[current];
      const nextSlide = slidesEls[next];
      const nextImg = images[next];

      gsap.set(nextSlide, { zIndex: 2, opacity: 0 });
      gsap.set(prevSlide, { zIndex: 1 }); 

      gsap.set(nextImg, { scale: 1 });
      gsap.to(nextImg, { scale: 1.1, duration: 15, ease: "none" });

      gsap.to(nextSlide, {
        opacity: 1,
        duration: 1.5, 
        ease: "power2.inOut",
        onComplete: () => {
          gsap.set(prevSlide, { opacity: 0, zIndex: 0 });
          gsap.set(nextSlide, { zIndex: 1 });
          
          current = next;
          typeText(slideData[current].typed); 
        }
      });
    }

    // ==========================================
    // SCROLL ULTRA SUAVE PARA EL BOTÓN
    // ==========================================
    const heroBtn = document.querySelector('.hero__btn');
    if (heroBtn) {
      heroBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        const targetSection = document.querySelector(targetId);
        
        if (targetSection) {
          // El -65 es para descontar el tamaño de tu header pegajoso
          const targetPos = targetSection.getBoundingClientRect().top + window.scrollY - 65;
          window.scrollTo({
            top: targetPos,
            behavior: 'smooth'
          });
        }
      });
    }
  });
</script>