---
---

<section class="hero" id="inicio">

  <div class="hero__image-wrap">
    <img
      class="hero__image"
      src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=1800&q=80"
      alt="Interior de lujo Studio2810"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <span class="label hero__label">Diseño de Interiores · Lima, Perú</span>

    <h1 class="hero__title">
  Espacios que<br />
  <em class="hero__typewriter" id="heroTypewriter"></em>
</h1>

    <p class="hero__subtitle">
      Transformamos ambientes en experiencias. Cada proyecto es
      una conversación entre quien lo habita y el espacio que lo contiene.
    </p>

    <div class="hero__actions">
      <a href="#portafolio" class="hero__btn">
        Ver portafolio
      </a>
    </div>
  </div>

  <div class="hero__scroll">
    <span class="label">Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 680px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

    /* Cursor parpadeante del typewriter */
  .hero__typewriter::after {
    content: '|';
    display: inline-block;
    margin-left: 2px;
    color: var(--secondary-fixed-dim);
    animation: blink 0.9s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }


  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.05);
    transition: transform 8s ease;
  }

  .hero:hover .hero__image {
    transform: scale(1.0);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(12, 14, 13, 0.80) 0%,
      rgba(12, 14, 13, 0.40) 60%,
      rgba(12, 14, 13, 0.10) 100%
    );
  }

  /* Contenido centrado verticalmente, empujado un poco arriba */
  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--space-8);
    margin-top: -8vh;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hero__label {
    color: rgba(240, 237, 232, 0.55);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #f0ede8;
    max-width: 680px;
  }

  .hero__title em {
    font-style: italic;
    font-weight: 300;
  }

  .hero__subtitle {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(240, 237, 232, 0.70);
    max-width: 440px;
  }

  .hero__actions {
    margin-top: var(--space-4);
  }

  /* Botón fino elegante — mismo estilo que header */
  .hero__btn {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(240, 237, 232, 0.85);
    border: 1px solid rgba(240, 237, 232, 0.35);
    padding: 0.9rem 2.2rem;
    transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease;
  }

  .hero__btn:hover {
    border-color: rgba(240, 237, 232, 0.8);
    color: #f0ede8;
    background: rgba(240, 237, 232, 0.08);
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    right: var(--space-8);
    bottom: var(--space-8);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .hero__scroll .label {
    color: rgba(240, 237, 232, 0.4);
    writing-mode: vertical-rl;
    letter-spacing: 0.15em;
    font-size: 0.6rem;
  }

  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(
      to bottom,
      rgba(240, 237, 232, 0.45),
      rgba(240, 237, 232, 0)
    );
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.15); }
  }

  @media (max-width: 768px) {
    .hero__content {
      padding: 0 var(--space-6);
      margin-top: -6vh;
    }
    .hero__scroll { display: none; }
  }

  @media (max-width: 480px) {
    .hero__content { margin-top: -4vh; }
  }
</style>

<script>
  // animations.js se encarga — ver Layout
</script>