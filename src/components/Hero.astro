---
const slides = [
  {
    img: "/images/oficina1.png",
    label: "Espacios que inspiran",
    sub: "Diseño de interiores · Lima, Perú",
  },
  {
    img: "/images/cocina1.PNG",
    label: "Cada detalle cuenta",
    sub: "Cocinas · Residencial",
  },
  {
    img: "/images/cocina3.jpeg",
    label: "Materiales nobles",
    sub: "Acabados · Mobiliario a medida",
  },
]
---

<section class="hero" id="hero">
  <div class="hero__container">
    <div class="hero__slides" id="heroSlides">
      {slides.map((s, i) => (
        <div
          class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
          data-index={i}
        >
          <img
            class="hero__slide-img"
            src={s.img}
            alt={s.label}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
          <div class="hero__slide-overlay"></div>
        </div>
      ))}
    </div>
  </div>

  <div class="hero__content">
    <div class="hero__mask">
      <p class="hero__eyebrow" id="heroEyebrow">{slides[0].sub}</p>
    </div>
    <div class="hero__mask">
      <h1 class="hero__title" id="heroTitle">{slides[0].label}</h1>
    </div>
    
    <div class="hero__bottom">
      <div class="hero__pagination">
        <span id="heroCurrent">01</span>
        <div class="hero__progress-bg">
          <div class="hero__progress-bar" id="heroProgress"></div>
        </div>
        <span>0{slides.length}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    background: #000;
  }

  .hero__container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120%; /* Altura extra para el efecto parallax */
    will-change: transform;
  }

  .hero__slides {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: visibility 0s 1.2s;
    overflow: hidden;
  }

  .hero__slide.is-active {
    opacity: 1;
    visibility: visible;
    transition: opacity 1.2s ease-in-out;
  }

  .hero__slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.1); /* Preparado para el efecto Zoom */
    will-change: transform;
  }

  .hero__slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.5));
  }

  /* ── Contenido y Máscaras ── */
  .hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: #fff;
    z-index: 10;
    padding: 0 5vw;
  }

  .hero__mask {
    overflow: hidden;
    margin-bottom: 10px;
  }

  .hero__eyebrow {
    font-family: 'Jost', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.8rem;
    margin: 0;
  }

  .hero__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    margin: 0;
  }

  /* ── Progreso y Pagina ── */
  .hero__bottom {
    position: absolute;
    bottom: 10%;
    width: 100%;
  }

  .hero__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
  }

  .hero__progress-bg {
    width: 100px;
    height: 1px;
    background: rgba(255,255,255,0.2);
    position: relative;
  }

  .hero__progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: #fff;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const slideData = [
    { label: "Espacios que inspiran", sub: "Diseño de interiores · Lima, Perú" },
    { label: "Cada detalle cuenta", sub: "Cocinas · Residencial" },
    { label: "Materiales nobles", sub: "Acabados · Mobiliario a medida" }
  ];

  let current = 0;
  const duration = 6; // Segundos por slide
  const slides = document.querySelectorAll('.hero__slide');
  const images = document.querySelectorAll('.hero__slide-img');
  const progressBar = document.getElementById('heroProgress');
  
  function initHero() {
    // 1. Efecto Parallax del Hero completo al hacer scroll
    gsap.to('.hero__container', {
      yPercent: 15,
      ease: "none",
      scrollTrigger: {
        trigger: ".hero",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });

    // 2. Animación de entrada inicial (Text Masking)
    const tl = gsap.timeline();
    tl.from('.hero__mask > *', {
      y: 100,
      opacity: 0,
      duration: 1.5,
      ease: "power4.out",
      stagger: 0.2
    });

    startSlideshow();
  }

  function startSlideshow() {
    // Animación de la barra de progreso
    gsap.to(progressBar, {
      width: '100%',
      duration: duration,
      ease: "none",
      onComplete: nextSlide
    });

    // Efecto Zoom sutil constante (Ken Burns) en la imagen activa
    gsap.to(images[current], {
      scale: 1.2,
      duration: duration + 1,
      ease: "sine.inOut"
    });
  }

  function nextSlide() {
    const next = (current + 1) % slides.length;
    
    // Fade Out actual / Fade In siguiente
    const outImg = images[current];
    const inImg = images[next];
    
    // Reiniciar escala de la que entra
    gsap.set(inImg, { scale: 1.1 });

    slides[current].classList.remove('is-active');
    slides[next].classList.add('is-active');

    // Cambiar textos con animación suave
    gsap.to('.hero__mask > *', {
      y: -20,
      opacity: 0,
      duration: 0.4,
      onComplete: () => {
        document.getElementById('heroTitle')!.textContent = slideData[next].label;
        document.getElementById('heroEyebrow')!.textContent = slideData[next].sub;
        document.getElementById('heroCurrent')!.textContent = `0${next + 1}`;
        
        gsap.fromTo('.hero__mask > *', 
          { y: 40, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.8, ease: "power4.out" }
        );
      }
    });

    current = next;
    gsap.set(progressBar, { width: '0%' });
    startSlideshow();
  }

  // Ejecutar
  initHero();
</script>