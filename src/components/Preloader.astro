---
---
<div class="splash" id="splash">
  <div class="splash__logo-wrap" id="splashLogoWrap">
    <img src="/images/studioLOGO.jpeg" alt="Studio2810" class="splash__logo" id="splashLogo" />
  </div>
</div>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #0f0e0c;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .splash__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  .splash__logo {
    width: clamp(260px, 38vw, 520px);
    height: auto;
    opacity: 0;
    filter: invert(1) brightness(2);
    transition: opacity 0.9s ease;
    will-change: transform, opacity;
    display: block;
  }

  .splash__logo.is-visible {
    opacity: 1;
  }

  .splash.is-done {
    opacity: 0;
    transition: opacity 0.55s ease 0.1s;
    pointer-events: none;
  }

  .splash.is-gone {
    display: none;
  }
</style>

<script>
  // Esperar a que todo esté listo
  window.addEventListener('load', () => {
    const splash       = document.getElementById('splash')
    const splashLogo   = document.getElementById('splashLogo') as HTMLImageElement
    const splashWrap   = document.getElementById('splashLogoWrap')
    const headerLogo   = document.getElementById('headerLogoImg') as HTMLImageElement

    if (!splash || !splashLogo || !splashWrap || !headerLogo) return

    // 1. Fade in del logo en el splash
    requestAnimationFrame(() => {
      splashLogo.classList.add('is-visible')
    })

    // 2. Después de 1.8s → animar hacia el header
    setTimeout(() => {
      const srcRect  = splashWrap.getBoundingClientRect()
      const dstRect  = headerLogo.getBoundingClientRect()

      // Centro de origen y destino
      const srcCX = srcRect.left + srcRect.width  / 2
      const srcCY = srcRect.top  + srcRect.height / 2
      const dstCX = dstRect.left + dstRect.width  / 2
      const dstCY = dstRect.top  + dstRect.height / 2

      const dx    = dstCX - srcCX
      const dy    = dstCY - srcCY
      const scale = dstRect.width / srcRect.width

      // Aplicar la transformación FLIP
      splashLogo.style.transition = 'transform 0.85s cubic-bezier(0.77,0,0.175,1), opacity 0.6s ease 0.35s'
      splashLogo.style.transform  = `translate(${dx}px, ${dy}px) scale(${scale})`
      splashLogo.style.opacity    = '0'

      // Revelar el logo del header justo cuando termina
      setTimeout(() => {
        headerLogo.style.opacity    = '1'
        headerLogo.style.transition = 'opacity 0.4s ease'
        splash.classList.add('is-done')
      }, 700)

      setTimeout(() => {
        splash.classList.add('is-gone')
        document.body.style.overflow = ''
      }, 1300)

    }, 1900)

    // Bloquear scroll durante el splash
    document.body.style.overflow = 'hidden'
  })
</script>