---
const servicios = [
  {
    numero: "01",
    titulo: "Diseño de\nInteriores",
    descripcion: "Desde la concepción hasta el detalle final. Creamos espacios que equilibran estética y funcionalidad con intención en cada decisión.",
    imagen: "/images/cocina3.jpeg",
  },
  {
    numero: "02",
    titulo: "Remodelación",
    descripcion: "Transformamos ambientes existentes respetando su esencia y elevando su potencial al máximo.",
    imagen: "/images/entrada1.jpeg",
  },
  {
    numero: "03",
    titulo: "Mobiliario\na Medida",
    descripcion: "Piezas únicas que se integran perfectamente al espacio. Cada mueble es una extensión del ambiente.",
    imagen: "/images/niña4.jpeg",
  },
  {
    numero: "04",
    titulo: "Consultoría",
    descripcion: "Una mirada experta para decisiones clave: paletas, materiales, distribución y estilo.",
    imagen: "/images/oficina2.png",
  },
]

// Colores de las líneas separadoras entre servicios (3 líneas para 4 servicios) [cite: 1]
const lineaColores = ["#548235", "#FAC606", "#C55A11"]
---

<script is:inline>
  ;(function () {
    var imgs = [
      '/images/cocina3.jpeg',
      '/images/entrada1.jpeg',
      '/images/niña4.jpeg',
      '/images/oficina2.png',
    ]
    imgs.forEach(function (src) {
      var link = document.createElement('link')
      link.rel = 'preload'
      link.as = 'image'
      link.href = src
      link.fetchpriority = 'high'
      document.head.appendChild(link)
    })
  })()
</script>

<section class="srv" id="servicios">

  <div class="srv__intro">
    <div class="srv__label-wrap">
      <span class="srv__label-line"></span>
      <span class="srv__label">Lo Que Hacemos</span>
    </div>
    <h2 class="srv__heading">Nuestros <em>Servicios</em></h2>
  </div>

  <div class="srv__items">
    {servicios.map((s, i) => (
      <div class="srv__item-wrap">

        {/* Fila del servicio */}
        <div class={`srv__item ${i % 2 === 0 ? 'srv__item--normal' : 'srv__item--reverse'}`}>

          {/* Imagen pegada al borde */}
          <div class="srv__image-col">
            <img
              class="srv__image"
              src={s.imagen}
              alt={s.titulo}
              loading="eager"
              decoding={i < 2 ? 'async' : 'sync'}
              fetchpriority="high"
            />
          </div>

          {/* Texto centrado en su columna */}
          <div class="srv__text-col">
            <div class="srv__num">{s.numero}</div>
            <h3 class="srv__title">
              {s.titulo.split('\n').map((line, j) => (
                <>{line}{j < s.titulo.split('\n').length - 1 && <br />}</>
              ))}
            </h3>
            <p class="srv__desc">{s.descripcion}</p>
          </div>

        </div>

        {/* Línea ondulada SVG entre servicios */}
        {i < servicios.length - 1 && (
          <div class="srv__wave-wrap" data-index={i}>
            <svg
              class="srv__wave"
              viewBox="0 0 1200 350"
              preserveAspectRatio="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              {i === 0 && (
  <path
    class="srv__wave-path"
    data-color={lineaColores[0]}
    d="M 0,280 C 100,280 150,20 300,80 C 450,140 500,280 650,200 C 800,120 900,20 1200,60"
    fill="none"
    stroke={lineaColores[0]}
    stroke-width="4"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
)}

{i === 1 && (
  <path
    class="srv__wave-path"
    data-color={lineaColores[1]}
    d="M 1200,280 C 1000,280 950,20 750,80 C 550,140 500,280 300,160 C 150,80 100,20 0,60"
    fill="none"
    stroke={lineaColores[1]}
    stroke-width="4"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
)}

{i === 2 && (
  <path
    class="srv__wave-path"
    data-color={lineaColores[2]}
    d="M 0,280 C 100,280 150,20 300,80 C 450,140 500,280 650,200 C 800,120 900,20 1200,60"
    fill="none"
    stroke={lineaColores[2]}
    stroke-width="4"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
)}

              {i === 1 && (
                <path
                  class="srv__wave-path"
                  data-color={lineaColores[1]}
                  /* De Pie Imagen 2 (Derecha) a Lado Imagen 3 (Izquierda) */
                  d="M 950, 0 C 950, 250 400, -50 250, 350"
                  fill="none"
                  stroke={lineaColores[1]}
                  stroke-width="5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              )}

              {i === 2 && (
                <path
                  class="srv__wave-path"
                  data-color={lineaColores[2]}
                  /* De Pie Imagen 3 (Izquierda) a Lado Imagen 4 (Derecha) */
                  d="M 250, 0 C 250, 250 800, -50 950, 350"
                  fill="none"
                  stroke={lineaColores[2]}
                  stroke-width="5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              )}
            </svg>
          </div>
        )}

      </div>
    ))}
  </div>

  <div class="srv__section-line"></div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400&display=swap');

  .srv { background: #f5f2ee; padding: 4rem 0 10rem; overflow: hidden; }
  .srv__section-line { max-width: 1300px; margin: 0 auto; height: 1px; background: rgba(100, 85, 60, 0.15); }
  .srv__intro { max-width: 1300px; margin: 0 auto 3rem; padding: 0 5vw; display: flex; flex-direction: column; gap: 1.2rem; }
  .srv__label-wrap { display: flex; align-items: center; gap: 14px; }
  .srv__label-line { display: inline-block; width: 32px; height: 1px; background: rgba(100, 85, 60, 0.4); flex-shrink: 0; }
  .srv__label { font-family: 'Jost', sans-serif; font-size: 0.72rem; font-weight: 400; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(120, 95, 60); }
  .srv__heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.4rem, 3.8vw, 3.6rem); font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; color: #0a0a08; }
  .srv__heading em { font-style: italic; color: rgb(110, 90, 55); }

  .srv__items { display: flex; flex-direction: column; gap: 0; }
  .srv__item-wrap { display: flex; flex-direction: column; }

  .srv__item {
    display: grid;
    grid-template-columns: 55fr 45fr;
    align-items: center;
    min-height: 560px;
    position: relative;
    z-index: 5; /* Las imágenes y textos tienen mayor z-index para tapar la línea */
  }

  .srv__item--reverse { grid-template-columns: 45fr 55fr; }
  .srv__item--reverse .srv__image-col { order: 2; }
  .srv__item--reverse .srv__text-col  { order: 1; }

  .srv__image-col {
    position: relative;
    align-self: stretch;
    overflow: hidden;
    z-index: 5; /* Aseguramos que la imagen tapa la línea */
  }

  .srv__image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 560px;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transform: scale(1.06);
    transition: opacity 2s ease, transform 2.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .srv__image.is-visible { opacity: 1; transform: scale(1); }

  .srv__text-col {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    padding: 4rem 5vw;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 1.8s ease, transform 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 2;
  }

  .srv__item--reverse .srv__text-col { transform: translateX(-30px); }
  .srv__text-col.is-visible { opacity: 1; transform: translateX(0); }

  .srv__num { font-family: 'Cormorant Garamond', serif; font-size: clamp(4.5rem, 9vw, 8rem); font-weight: 400; line-height: 0.85; color: rgba(160, 120, 70, 0.28); letter-spacing: -0.03em; margin-bottom: -1rem; }
  .srv__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.4vw, 3.2rem); font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; color: #0a0a08; }
  .srv__desc { font-family: 'Jost', sans-serif; font-size: 0.97rem; font-weight: 300; line-height: 1.85; color: rgba(20, 18, 14, 0.82); max-width: 380px; text-align: justify; }

  /* ══════════════════════════════════════
     LÍNEA ONDULADA
  ══════════════════════════════════════ */
  .srv__wave-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0;
    
    /* Agresivo margen negativo para que la curva enlace entre las filas */
    margin-top: -140px; 
    margin-bottom: -140px;
    
    position: relative;
    z-index: 1; /* ¡CLAVE! Esto pone la línea detrás de las fotos */
    overflow: visible;
    line-height: 0;
    pointer-events: none;
  }

  .srv__wave {
    display: block;
    width: 100%;
    max-width: 1200px;
    height: 350px;
    overflow: visible;
  }

  .srv__wave-path {
    stroke-dasharray: 2000; 
    stroke-dashoffset: 2000;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .srv__item { grid-template-columns: 52fr 48fr; min-height: 460px; }
    .srv__item--reverse { grid-template-columns: 48fr 52fr; }
    .srv__image { min-height: 460px; }
    .srv__wave-wrap { margin-top: -100px; margin-bottom: -100px; }
    .srv__wave { height: 280px; }
  }

  @media (max-width: 820px) {
    .srv__item, .srv__item--reverse { display: flex; flex-direction: column; min-height: unset; }
    .srv__item--reverse .srv__image-col, .srv__item--reverse .srv__text-col { order: unset; }
    .srv__image-col { width: 100%; z-index: 5; }
    .srv__image { min-height: 360px; height: 360px; }
    .srv__text-col { padding: 2.2rem 2rem; transform: translateY(28px); align-items: flex-start; }
    .srv__text-col.is-visible { transform: translateY(0); }
    .srv__wave-wrap { margin-top: -60px; margin-bottom: -60px; }
    .srv__wave { height: 180px; }
  }

  @media (max-width: 768px) {
    .srv__image { min-height: 280px; height: 280px; }
    .srv__wave-wrap { margin-top: -50px; margin-bottom: -50px; }
    .srv__wave { height: 140px; }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  const isMobile = window.innerWidth <= 820

  document.querySelectorAll('.srv__item').forEach((item) => {
    const img     = item.querySelector('.srv__image') as HTMLImageElement | null
    const textCol = item.querySelector('.srv__text-col') as HTMLElement | null
    const imgCol  = item.querySelector('.srv__image-col') as HTMLElement | null
    const isReverse = item.classList.contains('srv__item--reverse')

    if (img) {
      const imgObs = new IntersectionObserver(
        ([e]) => { if (e.isIntersecting) { img.classList.add('is-visible'); imgObs.disconnect() } },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      )
      imgObs.observe(img)
    }

    if (textCol) {
      const textObs = new IntersectionObserver(
        ([e]) => { if (e.isIntersecting) { textCol.classList.add('is-visible'); textObs.disconnect() } },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      )
      textObs.observe(textCol)
    }

    if (!isMobile && imgCol) {
      gsap.fromTo(imgCol, { x: isReverse ? 40 : -40 }, { x: 0, duration: 2, ease: 'power3.out', scrollTrigger: { trigger: item, start: 'top 80%' } })
    }
  })

  // Animación del ScrollTrigger actualizada
  document.querySelectorAll('.srv__wave-wrap').forEach((wrap) => {
    const path = wrap.querySelector('.srv__wave-path') as SVGPathElement | null
    if (!path) return

    const length = path.getTotalLength()
    path.style.strokeDasharray  = String(length)
    path.style.strokeDashoffset = String(length)

    ScrollTrigger.create({
      trigger: wrap,
      start: 'top 55%', // <--- AQUÍ ESTÁ EL CAMBIO: El efecto empieza más abajo para que se vea claramente
      end: 'bottom 30%', 
      scrub: 1.5,
      onUpdate(self) {
        const offset = length * (1 - self.progress)
        path.style.strokeDashoffset = String(offset)
      },
    })
  })

  gsap.from('.srv__intro > *', { scrollTrigger: { trigger: '.srv__intro', start: 'top 82%' }, opacity: 0, y: 20, duration: 1.6, stagger: 0.2, ease: 'power3.out' })
</script>