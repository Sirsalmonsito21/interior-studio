---
const servicios = [
  {
    numero: "01",
    titulo: "Diseño de\nInteriores",
    descripcion: "Desde la concepción hasta el detalle final. Creamos espacios que equilibran estética y funcionalidad con intención en cada decisión.",
    imagen: "/images/cocina3.jpeg",
  },
  {
    numero: "02",
    titulo: "Remodelación",
    descripcion: "Transformamos ambientes existentes respetando su esencia y elevando su potencial al máximo.",
    imagen: "/images/entrada1.jpeg",
  },
  {
    numero: "03",
    titulo: "Mobiliario\na Medida",
    descripcion: "Piezas únicas que se integran perfectamente al espacio. Cada mueble es una extensión del ambiente.",
    imagen: "/images/niña4.jpeg",
  },
  {
    numero: "04",
    titulo: "Consultoría",
    descripcion: "Una mirada experta para decisiones clave: paletas, materiales, distribución y estilo.",
    imagen: "/images/oficina2.png",
  },
]

// Colores de las líneas separadoras entre servicios (3 líneas para 4 servicios)
const lineaColores = ["#548235", "#FAC606", "#C55A11"]
---

<!-- Preload de las 4 imágenes -->
<script is:inline>
  ;(function () {
    var imgs = [
      '/images/cocina3.jpeg',
      '/images/entrada1.jpeg',
      '/images/niña4.jpeg',
      '/images/oficina2.png',
    ]
    imgs.forEach(function (src) {
      var link = document.createElement('link')
      link.rel = 'preload'
      link.as = 'image'
      link.href = src
      link.fetchpriority = 'high'
      document.head.appendChild(link)
    })
  })()
</script>

<section class="srv" id="servicios">

  <div class="srv__intro">
    <div class="srv__label-wrap">
      <span class="srv__label-line"></span>
      <span class="srv__label">Lo Que Hacemos</span>
    </div>
    <h2 class="srv__heading">Nuestros <em>Servicios</em></h2>
  </div>

  <div class="srv__items">
    {servicios.map((s, i) => (
      <div class="srv__item-wrap">

        {/* Fila del servicio */}
        <div class={`srv__item ${i % 2 === 0 ? 'srv__item--normal' : 'srv__item--reverse'}`}>

          {/* Imagen pegada al borde */}
          <div class="srv__image-col">
            <img
              class="srv__image"
              src={s.imagen}
              alt={s.titulo}
              loading="eager"
              decoding={i < 2 ? 'async' : 'sync'}
              fetchpriority="high"
            />
          </div>

          {/* Texto centrado en su columna */}
          <div class="srv__text-col">
            <div class="srv__num">{s.numero}</div>
            <h3 class="srv__title">
              {s.titulo.split('\n').map((line, j) => (
                <>{line}{j < s.titulo.split('\n').length - 1 && <br />}</>
              ))}
            </h3>
            <p class="srv__desc">{s.descripcion}</p>
          </div>

        </div>

        {/* Línea ondulada SVG entre servicios (no después del último) */}
        {i < servicios.length - 1 && (
          <div class="srv__wave-wrap" data-index={i}>
            <svg
              class="srv__wave"
              viewBox="0 0 1200 60"
              preserveAspectRatio="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                class="srv__wave-path"
                data-color={lineaColores[i]}
                d="M0,30 C150,5 300,55 450,30 C600,5 750,55 900,30 C1050,5 1150,48 1200,30"
                fill="none"
                stroke={lineaColores[i]}
                stroke-width="1.5"
                stroke-linecap="round"
              />
            </svg>
          </div>
        )}

      </div>
    ))}
  </div>

  <div class="srv__section-line"></div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400&display=swap');

  .srv {
    background: #f5f2ee;
    padding: 4rem 0 10rem;
    overflow: hidden;
  }

  .srv__section-line {
    max-width: 1300px;
    margin: 0 auto;
    height: 1px;
    background: rgba(100, 85, 60, 0.15);
  }

  /* ── INTRO — con padding lateral propio ── */
  .srv__intro {
    max-width: 1300px;
    margin: 0 auto 3rem;
    padding: 0 5vw;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .srv__label-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .srv__label-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: rgba(100, 85, 60, 0.4);
    flex-shrink: 0;
  }

  .srv__label {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(120, 95, 60);
  }

  .srv__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 3.8vw, 3.6rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #0a0a08;
  }

  .srv__heading em {
    font-style: italic;
    color: rgb(110, 90, 55);
  }

  /* ── ITEMS — sin padding, llegan al borde ── */
  .srv__items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .srv__item-wrap {
    display: flex;
    flex-direction: column;
  }

  /*
    Grid de 2 columnas:
    - Imagen toma 55% y está pegada al borde (sin margin/padding)
    - Texto toma 45% con padding interno propio
  */
  .srv__item {
    display: grid;
    grid-template-columns: 55fr 45fr;
    align-items: center;
    min-height: 560px;
  }

  /* Versión inversa: texto primero, imagen al borde derecho */
  .srv__item--reverse {
    grid-template-columns: 45fr 55fr;
  }

  .srv__item--reverse .srv__image-col { order: 2; }
  .srv__item--reverse .srv__text-col  { order: 1; }

  /* ── IMAGEN — pegada completamente al borde ── */
  .srv__image-col {
    position: relative;
    align-self: stretch; /* ocupa toda la altura de la fila */
    overflow: hidden;
  }

  /*
    CLAVE de carga fluida: opacity 0 en CSS desde el inicio.
    JS agrega .is-visible via IntersectionObserver.
  */
  .srv__image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 560px;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transform: scale(1.06);
    transition: opacity 2s ease, transform 2.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .srv__image.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  /* ── TEXTO — centrado en su columna, con padding ── */
  .srv__text-col {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    padding: 4rem 5vw;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 1.8s ease, transform 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .srv__item--reverse .srv__text-col {
    transform: translateX(-30px);
  }

  .srv__text-col.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .srv__num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4.5rem, 9vw, 8rem);
    font-weight: 400;
    line-height: 0.85;
    color: rgba(160, 120, 70, 0.28);
    letter-spacing: -0.03em;
    margin-bottom: -1rem;
  }

  .srv__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 3.4vw, 3.2rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #0a0a08;
  }

  .srv__desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.97rem;
    font-weight: 300;
    line-height: 1.85;
    color: rgba(20, 18, 14, 0.82);
    max-width: 380px;
    text-align: justify;
  }

  /* ══════════════════════════════════════
     LÍNEA ONDULADA
  ══════════════════════════════════════ */
  .srv__wave-wrap {
    width: 100%;
    padding: 0.4rem 0;
    overflow: hidden;
    line-height: 0;
  }

  .srv__wave {
    display: block;
    width: 100%;
    height: 60px;
  }

  /*
    La línea arranca invisible (stroke-dasharray = longitud total del path).
    JS anima stroke-dashoffset de lleno a 0 conforme el usuario scrollea,
    creando el efecto de "dibujo" en tiempo real.
  */
  .srv__wave-path {
    stroke-dasharray: 1300;
    stroke-dashoffset: 1300;
    transition: stroke-dashoffset 0.05s linear;
  }

  /* ── TABLET LANDSCAPE (1024px) ── */
  @media (max-width: 1024px) {
    .srv { padding: 4rem 0 8rem; }

    .srv__item {
      grid-template-columns: 52fr 48fr;
      min-height: 460px;
    }

    .srv__item--reverse {
      grid-template-columns: 48fr 52fr;
    }

    .srv__image { min-height: 460px; }
    .srv__text-col { padding: 3rem 4vw; }
  }

  /* ── TABLET PORTRAIT / MOBILE (820px) ── */
  @media (max-width: 820px) {
    .srv { padding: 3rem 0 6rem; }
    .srv__intro { padding: 0 2.5rem; margin-bottom: 2.5rem; }

    .srv__item,
    .srv__item--reverse {
      display: flex;
      flex-direction: column;
      min-height: unset;
    }

    .srv__item--reverse .srv__image-col,
    .srv__item--reverse .srv__text-col { order: unset; }

    /* En mobile la imagen va de borde a borde */
    .srv__image-col {
      width: 100%;
    }

    .srv__image {
      min-height: 360px;
      height: 360px;
    }

    .srv__text-col,
    .srv__item--reverse .srv__text-col {
      padding: 2.2rem 2rem;
      transform: translateY(28px);
      transition: opacity 1.4s ease, transform 1.4s ease;
      gap: 0.8rem;
      align-items: flex-start;
    }

    .srv__text-col.is-visible {
      transform: translateY(0);
    }

    .srv__num { font-size: 3.8rem; margin-bottom: -0.4rem; }
    .srv__title { font-size: 2.4rem; }
    .srv__desc { max-width: 100%; font-size: 0.95rem; }

    /* Línea ondulada más baja en mobile */
    .srv__wave { height: 44px; }
  }

  /* ── MOBILE (768px) ── */
  @media (max-width: 768px) {
    .srv { padding: 3rem 0 5rem; }
    .srv__intro { padding: 0 1.4rem; margin-bottom: 2rem; }

    .srv__image { min-height: 280px; height: 280px; }

    .srv__text-col,
    .srv__item--reverse .srv__text-col {
      padding: 1.8rem 1.4rem;
      gap: 0.7rem;
    }

    .srv__num { font-size: 3.2rem; margin-bottom: -0.5rem; }
    .srv__title { font-size: 2rem; }
    .srv__desc { font-size: 0.93rem; }

    .srv__wave { height: 36px; }
  }

  /* ── iPhone pequeño (390px) ── */
  @media (max-width: 390px) {
    .srv__intro { padding: 0 1.2rem; }
    .srv__image { min-height: 240px; height: 240px; }
    .srv__text-col,
    .srv__item--reverse .srv__text-col { padding: 1.5rem 1.2rem; }
    .srv__num { font-size: 2.8rem; }
    .srv__title { font-size: 1.85rem; }
    .srv__desc { font-size: 0.9rem; }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  const isMobile = window.innerWidth <= 820

  /* ══════════════════════════════════════
     IMÁGENES Y TEXTO — IntersectionObserver
     Mismo patrón que Esencia: CSS opacity 0,
     JS solo agrega .is-visible
  ══════════════════════════════════════ */
  document.querySelectorAll('.srv__item').forEach((item) => {
    const img     = item.querySelector('.srv__image') as HTMLImageElement | null
    const textCol = item.querySelector('.srv__text-col') as HTMLElement | null
    const imgCol  = item.querySelector('.srv__image-col') as HTMLElement | null
    const isReverse = item.classList.contains('srv__item--reverse')

    if (img) {
      const imgObs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) {
            img.classList.add('is-visible')
            imgObs.disconnect()
          }
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      )
      imgObs.observe(img)
    }

    if (textCol) {
      const textObs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) {
            textCol.classList.add('is-visible')
            textObs.disconnect()
          }
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      )
      textObs.observe(textCol)
    }

    /* Deslizamiento lateral de la columna imagen — solo desktop */
    if (!isMobile && imgCol) {
      gsap.fromTo(
        imgCol,
        { x: isReverse ? 40 : -40 },
        {
          x: 0,
          duration: 2,
          ease: 'power3.out',
          scrollTrigger: { trigger: item, start: 'top 80%' },
        }
      )
    }
  })

  /* ══════════════════════════════════════
     LÍNEAS ONDULADAS — animación por scroll
     Cada path se "dibuja" conforme el usuario
     scrollea hacia la siguiente sección.
     stroke-dashoffset va de 1300 (invisible)
     a 0 (línea completa) según el progreso
     de scroll entre los dos servicios.
  ══════════════════════════════════════ */
  document.querySelectorAll('.srv__wave-wrap').forEach((wrap) => {
    const path = wrap.querySelector('.srv__wave-path') as SVGPathElement | null
    if (!path) return

    /* Longitud real del path para dasharray exacto */
    const length = path.getTotalLength()
    path.style.strokeDasharray  = String(length)
    path.style.strokeDashoffset = String(length)

    ScrollTrigger.create({
      trigger: wrap,
      start: 'top 90%',
      end: 'top 20%',
      scrub: 1.2,
      onUpdate(self) {
        const remaining = length * (1 - self.progress)
        path.style.strokeDashoffset = String(remaining)
      },
    })
  })

  /* Intro heading */
  gsap.from('.srv__intro > *', {
    scrollTrigger: { trigger: '.srv__intro', start: 'top 82%' },
    opacity: 0,
    y: 20,
    duration: 1.6,
    stagger: 0.2,
    ease: 'power3.out',
  })
</script>