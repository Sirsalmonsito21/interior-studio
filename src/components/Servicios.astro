---
const servicios = [
  {
    numero: "01",
    titulo: "Diseño de<br>Interiores",
    descripcion: "Desde la concepción hasta el detalle final. Creamos espacios que equilibran estética y funcionalidad con intención en cada decisión.",
    tag: "Servicio Principal",
    imagen: "https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=1600&q=85",
  },
  {
    numero: "02",
    titulo: "Remo&shy;delación",
    descripcion: "Transformamos ambientes existentes respetando su esencia y elevando su potencial al máximo.",
    tag: "Transformación",
    imagen: "https://images.unsplash.com/photo-1503174971373-b1f69850bded?w=1600&q=85",
  },
  {
    numero: "03",
    titulo: "Mobiliario<br>a Medida",
    descripcion: "Piezas únicas que se integran perfectamente al espacio. Cada mueble es una extensión del ambiente.",
    tag: "Exclusivo",
    imagen: "https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=1600&q=85",
  },
  {
    numero: "04",
    titulo: "Consultoría",
    descripcion: "Una mirada experta para decisiones clave: paletas, materiales, distribución y estilo.",
    tag: "Asesoría",
    imagen: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=85",
  },
]
---

<section class="srv" id="servicios">

  <div class="srv__intro">
    <p class="srv__eyebrow">Lo que hacemos</p>
    <h2 class="srv__heading">Nuestros<br><em>Servicios</em></h2>
  </div>

  <div class="srv__items">
    {servicios.map((s, i) => (
      <div
        class="srv__item"
        style={`--bg: url('${s.imagen}')`}
      >
        <div class="srv__item-overlay"></div>
        <div class="srv__item-content">

          <div class="srv__item-left">
            <span class="srv__item-tag">{s.tag}</span>
            <span class="srv__item-num">{s.numero}</span>
            <h3 class="srv__item-title" set:html={s.titulo} />
          </div>

          <div class="srv__item-right">
            <div class="srv__item-line"></div>
            <p class="srv__item-desc">{s.descripcion}</p>
          </div>

        </div>
      </div>
    ))}
  </div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@200;300;400&display=swap');

  .srv {
    font-family: 'Jost', sans-serif;
    background: #0a0d0b;
    color: #f0ede8;
  }

  /* ── INTRO ── */
  .srv__intro {
    min-height: 38vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 6rem 5vw 5rem;
    position: relative;
  }

  .srv__intro::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 5vw;
    right: 5vw;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(240, 237, 232, 0.12) 20%,
      rgba(240, 237, 232, 0.12) 80%,
      transparent
    );
  }

  .srv__eyebrow {
    font-size: 0.62rem;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.38);
    margin-bottom: 1.4rem;
  }

  .srv__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 7vw, 6.5rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: #f0ede8;
  }

  .srv__heading em {
    font-style: italic;
    color: rgba(240, 237, 232, 0.5);
  }

  /* ── ITEMS ── */
  .srv__items {
    display: flex;
    flex-direction: column;
  }

  .srv__item {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  /* La imagen va aquí como pseudo-elemento */
  .srv__item::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
    filter: brightness(0.52);
    transition: transform 7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.6s ease;
    z-index: 0;
  }

  .srv__item:hover::before {
    transform: scale(1.06);
    filter: brightness(0.65);
  }

  /* Degradado oscuro desde abajo */
  .srv__item-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 11, 9, 0.93) 0%,
      rgba(8, 11, 9, 0.48) 35%,
      rgba(8, 11, 9, 0.08) 65%,
      transparent 100%
    );
    z-index: 1;
  }

  /* Contenido */
  .srv__item-content {
    position: relative;
    z-index: 2;
    padding: 0 5vw 6vh;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: flex-end;
    gap: 2rem;
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s ease, transform 0.9s ease;
  }

  .srv__item.visible .srv__item-content {
    opacity: 1;
    transform: translateY(0);
  }

  /* Izquierda */
  .srv__item-left {
    display: flex;
    flex-direction: column;
  }

  .srv__item-tag {
    display: inline-block;
    font-size: 0.58rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.38);
    border: 0.5px solid rgba(240, 237, 232, 0.14);
    padding: 0.35em 0.85em;
    margin-bottom: 2rem;
    width: fit-content;
  }

  .srv__item-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 300;
    line-height: 0.85;
    color: rgba(240, 237, 232, 0.06);
    letter-spacing: -0.03em;
    margin-bottom: -1.5rem;
  }

  .srv__item-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.6rem, 5.5vw, 5.2rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #f0ede8;
    position: relative;
    z-index: 1;
  }

  /* Derecha */
  .srv__item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-end;
    gap: 1.8rem;
    padding-bottom: 0.3rem;
  }

  .srv__item-line {
    width: 1px;
    height: 55px;
    background: linear-gradient(to bottom, transparent, rgba(240, 237, 232, 0.2));
    transition: height 0.5s ease;
  }

  .srv__item:hover .srv__item-line {
    height: 85px;
  }

  .srv__item-desc {
    font-size: clamp(0.78rem, 1.05vw, 0.9rem);
    font-weight: 200;
    line-height: 1.9;
    color: rgba(240, 237, 232, 0.48);
    max-width: 340px;
    text-align: right;
  }

  /* Separador entre items */
  .srv__item + .srv__item {
    border-top: 1px solid rgba(240, 237, 232, 0.04);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .srv__intro {
      padding: 5rem 1.5rem 4rem;
    }

    .srv__item {
      min-height: 82vh;
    }

    .srv__item-content {
      grid-template-columns: 1fr;
      gap: 1.4rem;
      padding: 0 1.5rem 5vh;
    }

    .srv__item-right {
      align-items: flex-start;
    }

    .srv__item-desc {
      text-align: left;
      max-width: 100%;
    }

    .srv__item-line {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .srv__item {
      min-height: 75vh;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  // Animación intro header
  gsap.from('.srv__eyebrow, .srv__heading', {
    scrollTrigger: { trigger: '.srv__intro', start: 'top 80%' },
    opacity: 0,
    y: 22,
    duration: 1,
    stagger: 0.15,
    ease: 'power3.out',
  })

  // Activar cada item cuando entra en viewport (para el transition CSS)
  const items = document.querySelectorAll('.srv__item')
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add('visible')
      })
    },
    { threshold: 0.12 }
  )
  items.forEach((el) => observer.observe(el))
</script>