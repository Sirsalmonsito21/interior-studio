---
const servicios = [
  {
    numero: "01",
    titulo: "Diseño de\nInteriores",
    descripcion: "Desde la concepción hasta el detalle final. Creamos espacios que equilibran estética y funcionalidad con intención en cada decisión.",
    imagen: "/images/cocina3.webp",
  },
  {
    numero: "02",
    titulo: "Remodelación",
    descripcion: "Transformamos ambientes existentes respetando su esencia y elevando su potencial al máximo.",
    imagen: "/images/entrada2.webp",
  },
  {
    numero: "03",
    titulo: "Mobiliario\na Medida",
    descripcion: "Piezas únicas que se integran perfectamente al espacio. Cada mueble es una extensión del ambiente.",
    imagen: "/images/niña4.webp",
  },
  {
    numero: "04",
    titulo: "Consultoría",
    descripcion: "Una mirada experta para decisiones clave: paletas, materiales, distribución y estilo.",
    imagen: "/images/oficina2.webp",
  },
]

const lineaColores = ["#548235", "#FAC606", "#C55A11"]
---

<section class="srv" id="servicios">

  <div class="srv__intro">
    <div class="srv__mask" style="text-align: center;">
      <h2 class="srv__heading">Nuestros <em>servicios</em></h2>
    </div>
  </div>

  <div class="srv__items">
    {servicios.map((s, i) => (
      <div class="srv__item-wrap">
        <div class={`srv__item ${i % 2 === 0 ? 'srv__item--normal' : 'srv__item--reverse'}`}>
          
          <div class="srv__image-col">
            <div class="srv__parallax-inner">
              <img class="srv__image" src={s.imagen} alt={s.titulo} loading="eager" />
            </div>
          </div>

          <div class="srv__text-col">
            <div class="srv__mask srv__mask-num">
              <div class="srv__num">{s.numero}</div>
            </div>
            
            <div class="srv__mask srv__mask-title">
              <h3 class="srv__title">
                {s.titulo.split('\n').map((line, j) => (
                  <>{line}{j < s.titulo.split('\n').length - 1 && <br />}</>
                ))}
              </h3>
            </div>
            
            <div class="srv__mask srv__mask-desc">
              <p class="srv__desc">{s.descripcion}</p>
            </div>
          </div>

        </div>

        {/* LÍNEA VERTICAL CONECTORA ENTRE IMÁGENES */}
        {i < servicios.length - 1 && (
          <div class="srv__wave-wrap" data-index={i}>
            <svg class="srv__wave" viewBox="0 0 1000 150" preserveAspectRatio="none">
              <path class="srv__wave-path" 
                d={i % 2 === 0 
                  ? "M 250,0 C 250,80 750,70 750,150" 
                  : "M 750,0 C 750,80 250,70 250,150"} 
                fill="none" stroke={lineaColores[i]} stroke-width="3" stroke-linecap="round" />
            </svg>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,500;1,500&display=swap');
  
  .srv { background: #f5f2ee; padding: 4rem 0 10rem; overflow: hidden; }
  
  .srv__intro { max-width: 1300px; margin: 0 auto 5rem; padding: 0 5vw; }
  
  .srv__heading { 
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 3.8vw, 3.6rem); 
    font-weight: 300; 
    color: #0a0a08; 
    text-transform: uppercase; 
    letter-spacing: 0.1em;
    margin: 0;
  }
  
  /* AQUÍ RECUPERAMOS EL COLOR Y ESTILO DE LA PALABRA "SERVICIOS" */
  .srv__heading em { 
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 4.5vw, 4.5rem); 
    font-weight: 300; 
    color: #a07846; 
    font-style: italic;
    text-transform: none;
    letter-spacing: normal;
  }

  .srv__mask { overflow: hidden; padding-bottom: 5px; }
  .srv__items { display: flex; flex-direction: column; gap: 0; }
  
  .srv__item { display: grid; grid-template-columns: 55fr 45fr; align-items: center; min-height: 560px; position: relative; z-index: 5; }
  
  .srv__item--reverse { grid-template-columns: 45fr 55fr; }
  .srv__item--reverse .srv__image-col { order: 2; }
  .srv__item--reverse .srv__text-col  { order: 1; }

  .srv__image-col { position: relative; align-self: stretch; overflow: hidden; min-height: 560px; }
  .srv__parallax-inner { position: absolute; top: -15%; left: 0; width: 100%; height: 130%; }
  .srv__image { width: 100%; height: 100%; object-fit: cover; }

  .srv__text-col { display: flex; flex-direction: column; gap: 1.6rem; padding: 4rem 5vw; }

  .srv__num { 
    font-family: 'Cormorant Garamond', serif; 
    font-size: clamp(4.5rem, 9vw, 8rem);
    line-height: 1; 
    color: rgba(160, 120, 70, 0.28); 
    margin-bottom: 0.5rem; 
  }

  /* FUENTE INTER APLICADA A LOS TÍTULOS */
  .srv__title { 
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 3.4vw, 3.2rem); 
    font-weight: 400; 
    line-height: 1.15; 
    color: #0a0a08;
    letter-spacing: -0.02em;
  }
  
  .srv__desc { 
    font-family: 'Inter', sans-serif; 
    font-size: 1.15rem; 
    font-weight: 300; 
    line-height: 1.6;
    color: rgba(20, 18, 14, 0.82); 
    max-width: 420px; 
    text-align: justify; 
  }

  /* NUEVO ESPACIO VERTICAL PARA LAS LÍNEAS */
  .srv__wave-wrap { 
    width: 100%; 
    height: 120px; 
    display: flex; 
    justify-content: center;
    margin: 2rem 0; 
    position: relative; 
    z-index: 1; 
  }
  .srv__wave { width: 100%; max-width: 1000px; height: 100%; overflow: visible; }
  .srv__wave-path { stroke-dasharray: 2000; stroke-dashoffset: 2000; }

  @media (max-width: 1024px) {
    .srv__wave-wrap { display: none; }
    .srv__item, .srv__item--reverse { display: flex; flex-direction: column; min-height: unset; gap: 0; margin-bottom: 5rem; }
    .srv__text-col { display: contents; }
    .srv__item .srv__mask-num { order: 1; text-align: center; margin-top: 1rem; }
    .srv__item .srv__mask-title { order: 2; text-align: center; padding: 0 5vw; margin-bottom: 2.5rem; }
    .srv__item .srv__image-col, .srv__item--reverse .srv__image-col { order: 3; width: 100%; min-height: 450px; margin-bottom: 2.5rem; }
    .srv__item .srv__mask-desc { order: 4; text-align: center; padding: 0 5vw; }
    .srv__desc { margin-left: auto; margin-right: auto; text-align: center; }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  function initServicios() {
    gsap.from('.srv__heading', {
      y: 50, opacity: 0, duration: 1, scrollTrigger: { trigger: ".srv__intro", start: "top 90%" }
    })

    document.querySelectorAll('.srv__item-wrap').forEach((wrap) => {
      const item = wrap.querySelector('.srv__item');
      if (!item) return;

      // 1. Textos: Entrada más fluida
      gsap.from(item.querySelectorAll('.srv__mask > *'), {
        y: 80, opacity: 0, duration: 1.2, ease: "power3.out", stagger: 0.2, 
        scrollTrigger: { trigger: item, start: "top 80%" }
      })

      // 2. Imágenes: Efecto Revelado "Cortina" + Parallax
      const imgCol = item.querySelector('.srv__image-col');
      const img = item.querySelector('.srv__image');

      if (imgCol && img) {
        // Revelado de la caja
        gsap.fromTo(imgCol, 
          { clipPath: "inset(100% 0 0 0)" },
          { clipPath: "inset(0% 0 0 0)", duration: 1.5, ease: "power3.inOut", scrollTrigger: { trigger: item, start: "top 75%" } }
        )
        // Parallax de la foto
        gsap.to(img, {
          yPercent: 25, ease: "none", scrollTrigger: { trigger: item, start: "top bottom", end: "bottom top", scrub: true }
        })
      }
    })

    // 3. Líneas verticales bajando
    if(window.innerWidth > 1024) {
      document.querySelectorAll('.srv__wave-path').forEach((path: any) => {
        const length = path.getTotalLength()
        gsap.set(path, { strokeDasharray: length, strokeDashoffset: length })
        gsap.to(path, {
          strokeDashoffset: 0, 
          scrollTrigger: { trigger: path, start: "top 65%", end: "bottom 35%", scrub: 1 }
        })
      })
    }
  }
  
  initServicios()
  document.addEventListener('astro:after-swap', initServicios);
</script>