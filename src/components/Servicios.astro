---
const servicios = [
  {
    numero: "01",
    titulo: "Diseño de\nInteriores",
    descripcion: "Desde la concepción hasta el detalle final. Creamos espacios que equilibran estética y funcionalidad con intención en cada decisión.",
    tag: "Servicio Principal",
    imagen: "/images/cocina3.jpeg",
    tagImagen: "Cocina · Lima",
  },
  {
    numero: "02",
    titulo: "Remodelación",
    descripcion: "Transformamos ambientes existentes respetando su esencia y elevando su potencial al máximo.",
    tag: "Transformación",
    imagen: "/images/entrada1.jpeg",
    tagImagen: "Entrada · Lima",
  },
  {
    numero: "03",
    titulo: "Mobiliario\na Medida",
    descripcion: "Piezas únicas que se integran perfectamente al espacio. Cada mueble es una extensión del ambiente.",
    tag: "Exclusivo",
    imagen: "/images/niña4.jpeg",
    tagImagen: "Detalle · Lima",
  },
  {
    numero: "04",
    titulo: "Consultoría",
    descripcion: "Una mirada experta para decisiones clave: paletas, materiales, distribución y estilo.",
    tag: "Asesoría",
    imagen: "/images/oficina2.png",
    tagImagen: "Oficina · Lima",
  },
]
---

<!--
  OPTIMIZACIÓN DE CARGA: Inyectamos <link rel="preload"> para las 4 imágenes
  directamente en el <head> via un script de inicialización temprana.
  Esto le dice al browser que las descargue ANTES de parsear el DOM,
  eliminando el retraso que sufren las imágenes 3 y 4.
-->
<script is:inline>
  ;(function () {
    const imgs = [
      '/images/cocina3.jpeg',
      '/images/entrada1.jpeg',
      '/images/niña4.jpeg',
      '/images/oficina2.png',
    ]
    imgs.forEach(function (src) {
      var link = document.createElement('link')
      link.rel = 'preload'
      link.as = 'image'
      link.href = src
      link.fetchpriority = 'high'
      document.head.appendChild(link)
    })
  })()
</script>

<section class="srv" id="servicios">

  <div class="srv__intro">
    <div class="srv__label-wrap">
      <span class="srv__label-line"></span>
      <span class="srv__label">Lo Que Hacemos</span>
    </div>
    <h2 class="srv__heading">Nuestros <em>Servicios</em></h2>
  </div>

  <div class="srv__items">
    {servicios.map((s, i) => (
      <div class="srv__item-wrap">
        <div class={`srv__item ${i % 2 === 0 ? 'srv__item--normal' : 'srv__item--reverse'}`}>

          <div class="srv__image-col">
            <div class="srv__image-frame">
              <img
                class="srv__image"
                src={s.imagen}
                alt={s.titulo}
                loading="eager"
                decoding={i < 2 ? 'async' : 'sync'}
                fetchpriority="high"
              />
              <div class="srv__image-tag">
                <span>Studio2810</span>
                <span class="srv__image-tag-line"></span>
                <span>{s.tagImagen}</span>
              </div>
            </div>
          </div>

          <div class="srv__text-col">
            <div class="srv__label-wrap">
              <span class="srv__label-line"></span>
              <span class="srv__label">{s.tag}</span>
            </div>
            <div class="srv__num">{s.numero}</div>
            <h3 class="srv__title">
              {s.titulo.split('\n').map((line, j) => (
                <>{line}{j < s.titulo.split('\n').length - 1 && <br />}</>
              ))}
            </h3>
            <p class="srv__desc">{s.descripcion}</p>
          </div>

        </div>

        <div class="srv__divider"></div>
      </div>
    ))}
  </div>

  <div class="srv__section-line"></div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400&display=swap');

  .srv {
    background: #f5f2ee;
    padding: 4rem 5vw 10rem;
    overflow: hidden;
  }

  .srv__section-line {
    max-width: 1300px;
    margin: 0 auto;
    height: 1px;
    background: rgba(100, 85, 60, 0.15);
  }

  .srv__intro {
    max-width: 1300px;
    margin: 0 auto 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .srv__label-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .srv__label-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: rgba(100, 85, 60, 0.4);
    flex-shrink: 0;
  }

  .srv__label {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(120, 95, 60);
  }

  .srv__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 3.8vw, 3.6rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #0a0a08;
  }

  .srv__heading em {
    font-style: italic;
    color: rgb(110, 90, 55);
  }

  .srv__items {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .srv__item-wrap {
    display: flex;
    flex-direction: column;
  }

  .srv__item {
    display: grid;
    grid-template-columns: 1.45fr 0.55fr;
    gap: 5vw;
    align-items: center;
    padding: 4rem 0;
  }

  .srv__item--reverse {
    grid-template-columns: 0.55fr 1.45fr;
  }

  .srv__item--reverse .srv__image-col { order: 2; }
  .srv__item--reverse .srv__text-col  { order: 1; }

  .srv__divider {
    width: 100%;
    height: 1px;
    background: rgba(100, 85, 60, 0.12);
  }

  .srv__item-wrap:last-child .srv__divider {
    display: none;
  }

  /* ── IMAGEN ── */
  .srv__image-col {
    position: relative;
    min-width: 0;
  }

  .srv__image-frame {
    position: relative;
    overflow: hidden;
  }

  .srv__image-frame::before {
    content: '';
    position: absolute;
    top: -24px;
    left: -24px;
    width: 60%;
    height: 60%;
    border: 1px solid rgba(160, 140, 110, 0.25);
    z-index: 0;
    transition: transform 0.8s ease;
  }

  .srv__item--reverse .srv__image-frame::before {
    left: auto;
    right: -24px;
  }

  .srv__image-frame::after {
    content: '';
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 45%;
    height: 45%;
    background: rgba(160, 140, 110, 0.08);
    z-index: 0;
    transition: transform 0.8s ease;
  }

  .srv__item--reverse .srv__image-frame::after {
    right: auto;
    left: -20px;
  }

  .srv__image-col:hover .srv__image-frame::before { transform: translate(-6px, -6px); }
  .srv__item--reverse .srv__image-col:hover .srv__image-frame::before { transform: translate(6px, -6px); }
  .srv__image-col:hover .srv__image-frame::after { transform: translate(6px, 6px); }
  .srv__item--reverse .srv__image-col:hover .srv__image-frame::after { transform: translate(-6px, 6px); }

  .srv__image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 580px;
    object-fit: cover;
    object-position: center;
    display: block;
    /* Sin opacity ni transform aquí — GSAP los pone via gsap.set() */
  }

  .srv__image-tag {
    position: absolute;
    bottom: 24px;
    left: 24px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #0f0f0d;
    background: rgba(245, 242, 238, 0.92);
    padding: 0.55em 1em;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 1.2s ease 1s, transform 1.2s ease 1s;
  }

  .srv__item--reverse .srv__image-tag {
    left: auto;
    right: 24px;
  }

  .srv__image-frame:has(.srv__image.is-visible) .srv__image-tag {
    opacity: 1;
    transform: translateY(0);
  }

  .srv__image-tag-line {
    display: inline-block;
    width: 22px;
    height: 1px;
    background: rgba(0, 0, 0, 0.35);
  }

  .srv__text-col {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    min-width: 0;
  }

  .srv__num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4.5rem, 9vw, 8rem);
    font-weight: 400;
    line-height: 0.85;
    color: rgba(160, 120, 70, 0.28);
    letter-spacing: -0.03em;
    margin-bottom: -1rem;
  }

  .srv__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 3.4vw, 3.2rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #0a0a08;
  }

  .srv__desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.97rem;
    font-weight: 300;
    line-height: 1.85;
    color: rgba(20, 18, 14, 0.82);
    max-width: 380px;
    text-align: justify;
  }

  /* ── TABLET LANDSCAPE (1024px) ── */
  @media (max-width: 1024px) {
    .srv { padding: 4rem 4vw 8rem; }

    .srv__item {
      grid-template-columns: 1.2fr 0.8fr;
      gap: 3vw;
      padding: 3.5rem 0;
    }

    .srv__item--reverse { grid-template-columns: 0.8fr 1.2fr; }
    .srv__image { height: 460px; }
  }

  /* ── TABLET PORTRAIT (820px) ── */
  @media (max-width: 820px) {
    .srv { padding: 3rem 2.5rem 6rem; }
    .srv__intro { margin-bottom: 2.5rem; }

    .srv__item,
    .srv__item--reverse {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 3rem 0;
    }

    .srv__item--reverse .srv__image-col,
    .srv__item--reverse .srv__text-col { order: unset; }

    .srv__image-frame::before,
    .srv__image-frame::after { display: none; }

    .srv__image { height: 400px; }

    .srv__image-tag {
      opacity: 0;
      transform: translateY(8px);
    }

    .srv__item--reverse .srv__image-tag { left: 24px; right: auto; }

    .srv__text-col {
      gap: 0.8rem;
      padding: 2.2rem 2rem 0;
      text-align: left;
      align-items: flex-start;
    }

    .srv__label-wrap { justify-content: flex-start; }

    .srv__num { font-size: 3.8rem; margin-bottom: -0.4rem; }
    .srv__title { font-size: 2.4rem; text-align: left; }
    .srv__desc { max-width: 100%; font-size: 0.95rem; text-align: justify; }
  }

  /* ── MOBILE (768px) ── */
  @media (max-width: 768px) {
    .srv { padding: 3rem 1.4rem 5rem; }
    .srv__intro { margin-bottom: 2rem; }

    .srv__item,
    .srv__item--reverse {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 2.5rem 0;
    }

    .srv__item--reverse .srv__image-col,
    .srv__item--reverse .srv__text-col { order: unset; }

    .srv__image-frame::before,
    .srv__image-frame::after { display: none; }

    .srv__image { height: 280px; }

    .srv__image-tag {
      font-size: 0.58rem;
      padding: 0.45em 0.8em;
      bottom: 14px;
      left: 14px;
      opacity: 0;
      transform: translateY(8px);
    }

    .srv__item--reverse .srv__image-tag { left: 14px; right: auto; }

    .srv__text-col {
      gap: 0.7rem;
      padding: 1.8rem 1rem 0;
      text-align: left;
      align-items: flex-start;
    }

    .srv__label-wrap { justify-content: flex-start; }
    .srv__num { font-size: 3.2rem; margin-bottom: -0.5rem; }
    .srv__title { font-size: 2rem; text-align: left; }
    .srv__desc { max-width: 100%; font-size: 0.93rem; text-align: justify; }
  }

  /* ── iPhone pequeño (390px) ── */
  @media (max-width: 390px) {
    .srv { padding: 2.5rem 1.2rem 4rem; }
    .srv__image { height: 240px; }
    .srv__text-col { padding: 1.5rem 0.8rem 0; }
    .srv__num { font-size: 2.8rem; }
    .srv__title { font-size: 1.85rem; }
    .srv__desc { font-size: 0.9rem; }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  const isMobile = window.innerWidth <= 820

  /**
   * Retorna una Promise que se resuelve cuando la imagen está completamente cargada.
   * Si ya está cacheada (complete = true), resuelve de inmediato.
   */
  function waitForImage(img: HTMLImageElement): Promise<void> {
    return new Promise((resolve) => {
      if (img.complete && img.naturalWidth > 0) {
        resolve()
      } else {
        img.addEventListener('load',  () => resolve(), { once: true })
        img.addEventListener('error', () => resolve(), { once: true })
      }
    })
  }

  function initAnimations() {
    if (isMobile) {
      // ── MOBILE: CSS transition + IntersectionObserver ──
      document.querySelectorAll('.srv__image').forEach(img => {
        const el = img as HTMLElement
        el.style.opacity = '0'
        el.style.transform = 'scale(1.05)'
        el.style.transition = 'opacity 2s ease, transform 2.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)'
      })

      document.querySelectorAll('.srv__text-col').forEach(col => {
        const el = col as HTMLElement
        el.style.opacity = '0'
        el.style.transform = 'translateY(28px)'
        el.style.transition = 'opacity 1.4s ease, transform 1.4s ease'
      })

      const imgObserver = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const el = e.target as HTMLImageElement
            // Esperar a que la imagen esté lista antes de disparar la transición
            waitForImage(el).then(() => {
              el.style.opacity = '1'
              el.style.transform = 'scale(1)'
              el.classList.add('is-visible')
            })
            imgObserver.unobserve(e.target)
          }
        })
      }, { threshold: 0, rootMargin: '0px 0px -40px 0px' })

      const textObserver = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement
            el.style.opacity = '1'
            el.style.transform = 'translateY(0)'
            textObserver.unobserve(e.target)
          }
        })
      }, { threshold: 0, rootMargin: '0px 0px -40px 0px' })

      document.querySelectorAll('.srv__image').forEach(img => imgObserver.observe(img))
      document.querySelectorAll('.srv__text-col').forEach(col => textObserver.observe(col))

    } else {
      // ── DESKTOP: GSAP — espera a que cada imagen esté cargada antes de animar ──
      document.querySelectorAll('.srv__item').forEach((item) => {
        const textCol   = item.querySelector('.srv__text-col') as HTMLElement | null
        const imgCol    = item.querySelector('.srv__image-col') as HTMLElement | null
        const img       = item.querySelector('.srv__image') as HTMLImageElement | null
        const isReverse = item.classList.contains('srv__item--reverse')

        // Poner en opacity 0 inmediatamente vía GSAP
        if (img)     gsap.set(img,     { opacity: 0, scale: 1.06 })
        if (textCol) gsap.set(textCol, { opacity: 0, x: isReverse ? -30 : 30 })

        ScrollTrigger.create({
          trigger: item,
          start: 'top 78%',
          onEnter: () => {
            // Esperar a que la imagen esté descargada antes de disparar GSAP
            if (img) {
              waitForImage(img).then(() => {
                gsap.to(img, {
                  opacity: 1,
                  scale: 1,
                  duration: 2,
                  ease: 'power2.out',
                  onComplete() { img.classList.add('is-visible') },
                })
              })
            }

            // La columna imagen puede deslizarse aunque la img no esté lista
            if (imgCol) {
              gsap.fromTo(imgCol,
                { x: isReverse ? 36 : -36 },
                { x: 0, duration: 2, ease: 'power3.out' }
              )
            }

            // Texto: no depende de la imagen, puede animar en paralelo
            if (textCol) {
              gsap.to(textCol, {
                opacity: 1,
                x: 0,
                duration: 1.8,
                ease: 'power3.out',
              })
            }
          }
        })
      })

      gsap.from('.srv__intro > *', {
        scrollTrigger: { trigger: '.srv__intro', start: 'top 82%' },
        opacity: 0,
        y: 20,
        duration: 1.6,
        stagger: 0.2,
        ease: 'power3.out',
      })
    }
  }

  // Esperar a que TODO esté cargado antes de inicializar
  if (document.readyState === 'complete') {
    initAnimations()
  } else {
    window.addEventListener('load', initAnimations)
  }
</script>