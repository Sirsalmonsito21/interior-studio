---
const servicios = [
  {
    numero: "01",
    titulo: "Diseño de\nInteriores",
    tituloKey: "srv.titulo.0",
    descripcion: "Desde la concepción hasta el detalle final. Creamos espacios que equilibran estética y funcionalidad con intención en cada decisión.",
    descKey: "srv.desc.0",
    imagen: "/images/cocina3.webp",
  },
  {
    numero: "02",
    titulo: "Remodelación",
    tituloKey: "srv.titulo.1",
    descripcion: "Transformamos ambientes existentes respetando su esencia y elevando su potencial al máximo.",
    descKey: "srv.desc.1",
    imagen: "/images/entrada2.webp",
  },
  {
    numero: "03",
    titulo: "Mobiliario\na Medida",
    tituloKey: "srv.titulo.2",
    descripcion: "Piezas únicas que se integran perfectamente al espacio. Cada mueble es una extensión del ambiente.",
    descKey: "srv.desc.2",
    imagen: "/images/bebe1.webp",
  },
  {
    numero: "04",
    titulo: "Consultoría",
    tituloKey: "srv.titulo.3",
    descripcion: "Una mirada experta para decisiones clave: paletas, materiales, distribución y estilo.",
    descKey: "srv.desc.3",
    imagen: "/images/oficina2.webp",
  },
]


const lineaColores = ["#a07846", "#C55A11", "#548235"]

// ── LÍNEA 1 (conector 0): imagen1 → imagen2 ──
const l1_startX = 275
const l1_startY = 0
const l1_endX   = 480
const l1_endY   = 300

// ── LÍNEA 2 (conector 1): imagen2 → imagen3 ──
const l2_startX = 920
const l2_startY = 0
const l2_endX = 480
const l2_endY = 170

// ── LÍNEA 3 (conector 2): imagen3 → imagen4 ── LISTA PARA PERSONALIZAR
const l3_startX = 560
const l3_startY = 0
const l3_endX   = 470
const l3_endY   = 300

const conectores = [
  // Línea 1 — no tocar
  `M ${l1_startX},${l1_startY} C 310,25 360,45 330,75 C 300,105 160,110 180,155 C 195,195 350,210 ${l1_endX},${l1_endY}`,
  // Línea 2 — inicio más a la derecha, fin más abajo y a la derecha
  `M ${l2_startX},${l2_startY} C 1050,30 1080,110 950,125 C 820,140 650,145 580,120 C 520,98 510,88 ${l2_endX},${l2_endY}`,
  // Línea 3 — LISTA PARA PERSONALIZAR
  `M ${l3_startX},${l3_startY} C 750,25 780,60 680,85 C 580,108 350,110 280,135 C 240,158 320,200 ${l3_endX},${l3_endY}`,
]
---

<section class="srv" id="servicios">

  <div class="srv__intro">
    <div class="srv__mask">
      <h2 class="srv__heading">
        <span class="srv__heading-normal" data-i18n="srv.heading.1">Nuestros</span>
<span class="srv__heading-italic" data-i18n="srv.heading.2">servicios</span>
      </h2>
    </div>
  </div>

  <div class="srv__items">
    {servicios.map((s, i) => (
      <div class="srv__item-wrap">
        <div class={`srv__item ${i % 2 === 0 ? 'srv__item--normal' : 'srv__item--reverse'}`}>

          <div class="srv__image-col">
            <div class="srv__parallax-inner">
              <img class="srv__image" src={s.imagen} alt={s.titulo} loading="eager" />
            </div>
            <div class="srv__num-overlay">{s.numero}</div>
          </div>

          <div class="srv__text-col">
            <div class="srv__mask srv__mask-title">
              <h3 class="srv__title" data-i18n={s.tituloKey}>
  {s.titulo.split('\n').map((line, j) => (
    <>{line}{j < s.titulo.split('\n').length - 1 && <br />}</>
  ))}
</h3>
            </div>
            <div class="srv__accent-line"></div>
            <div class="srv__mask srv__mask-desc">
              <p class="srv__desc" data-i18n={s.descKey}>{s.descripcion}</p>
            </div>
            <div class="srv__num-mobile">{s.numero}</div>
          </div>

        </div>

        {i < servicios.length - 1 && (
          <div class="srv__connector" data-index={i}>
            <svg class="srv__wave" viewBox="0 0 1000 160" preserveAspectRatio="none">
              <path
                class="srv__wave-path"
                d={conectores[i]}
                fill="none"
                stroke={lineaColores[i]}
                stroke-width="10"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <circle
                class="srv__wave-dot srv__wave-dot--start"
                cx={
                  i === 0 ? String(l1_startX) :
                  i === 1 ? String(l2_startX) :
                            String(l3_startX)
                }
                cy="0"
                r="9"
                fill={lineaColores[i]}
              />
              <circle
                class="srv__wave-dot srv__wave-dot--end"
                cx={
                  i === 0 ? String(l1_endX) :
                  i === 1 ? String(l2_endX) :
                            String(l3_endX)
                }
                cy={
                  i === 0 ? String(l1_endY) :
                  i === 1 ? String(l2_endY) :
                            String(l3_endY)
                }
                r="9"
                fill={lineaColores[i]}
              />
            </svg>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,300;0,400;1,300;1,400&family=Cormorant+Garamond:wght@300;400;500&display=swap');

  .srv {
    background: #f5f2ee;
    padding: 4rem 0 2rem;
    overflow: hidden;
  }

  .srv__intro {
    max-width: 1300px;
    margin: 0 auto 5rem;
    padding: 0 5vw;
    text-align: center;
  }

  .srv__heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 auto;
    width: fit-content;
    text-align: left;
  }

  .srv__heading-normal {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 4.5vw, 4.5rem);
    font-weight: 300;
    color: #1a1a1a;
    text-transform: none;
    letter-spacing: -0.02em;
    line-height: 1.1;
    display: block;
    align-self: flex-start;
  }

  .srv__heading-italic {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 300;
    font-style: italic;
    color: #a07846;
    line-height: 1.05;
    display: block;
    letter-spacing: -0.02em;
    padding-left: 4rem;
    margin-top: -0.5rem;
  }

  .srv__mask { overflow: hidden; padding-bottom: 5px; }
  .srv__items { display: flex; flex-direction: column; gap: 0; }

  .srv__item {
    display: grid;
    grid-template-columns: 55fr 45fr;
    align-items: center;
    min-height: 560px;
    position: relative;
    z-index: 5;
  }

  .srv__item--reverse { grid-template-columns: 45fr 55fr; }
  .srv__item--reverse .srv__image-col { order: 2; }
  .srv__item--reverse .srv__text-col  { order: 1; }

  .srv__image-col {
    position: relative;
    align-self: stretch;
    overflow: hidden;
    min-height: 560px;
  }

  .srv__parallax-inner {
    position: absolute;
    top: -15%;
    left: 0;
    width: 100%;
    height: 130%;
  }

  .srv__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .srv__num-overlay {
    position: absolute;
    bottom: 1.8rem;
    right: 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(5rem, 10vw, 9rem);
    line-height: 1;
    color: rgba(255,255,255,0.18);
    pointer-events: none;
    z-index: 2;
    letter-spacing: -0.04em;
    text-shadow: 0 2px 24px rgba(0,0,0,0.18);
    transition: color 0.4s ease;
  }

  .srv__item:hover .srv__num-overlay {
    color: rgba(160,120,70,0.35);
  }

  .srv__num-mobile { display: none; }

  .srv__text-col {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding: 4rem 5vw;
  }

  .srv__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 3.4vw, 3.2rem);
    font-weight: 400;
    line-height: 1.15;
    color: #0a0a08;
    letter-spacing: -0.02em;
  }

  .srv__accent-line {
    width: 40px;
    height: 2px;
    background: #a07846;
    border-radius: 0;
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.4s ease;
  }

  .srv__item-wrap.is-visible .srv__accent-line {
    opacity: 1;
    transform: scaleX(1);
  }

  .srv__desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(20,18,14,0.75);
    max-width: 420px;
    text-align: justify;
  }

  .srv__connector {
    width: 100%;
    height: 160px;
    justify-content: center;
    margin: -45px 0;
    position: relative;
    z-index: 10;
    display: none;
    pointer-events: none;
  }

  .srv__wave {
    width: 100%;
    max-width: 1000px;
    height: 100%;
    overflow: visible;
  }

  .srv__wave-path {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
  }

  .srv__wave-dot { opacity: 0; }

  @media (min-width: 1025px) {
    .srv__connector { display: flex; }
  }

  @media (max-width: 1024px) {
    .srv__item, .srv__item--reverse {
      display: flex;
      flex-direction: column;
      min-height: unset;
      gap: 0;
      margin-bottom: 5rem;
    }

    .srv__text-col { display: contents; }

    .srv__item .srv__mask-title { order: 2; text-align: center; padding: 0 5vw; margin-bottom: 0.5rem; }
    .srv__item .srv__accent-line { order: 3; margin: 0 auto 1rem; }
    .srv__item .srv__mask-desc  { order: 4; text-align: center; padding: 0 5vw; }
    .srv__desc { margin-left: auto; margin-right: auto; text-align: center; }

    .srv__item .srv__image-col,
    .srv__item--reverse .srv__image-col {
      order: 5;
      width: 100%;
      height: auto;
      min-height: auto;
    }

    .srv__parallax-inner {
      position: relative;
      top: 0;
      height: auto;
      width: 100%;
    }

    .srv__image {
      width: 100%;
      height: auto;
      object-fit: contain;
      display: block;
    }

    .srv__num-overlay { display: none; }

    .srv__num-mobile {
      display: block;
      order: 1;
      text-align: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 10vw, 5rem);
      line-height: 1;
      color: rgba(160,120,70,0.3);
      margin-bottom: 0.2rem;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  function initServicios() {
    gsap.from('.srv__heading', {
      y: 50, opacity: 0, duration: 1,
      scrollTrigger: { trigger: ".srv__intro", start: "top 90%" }
    })

    document.querySelectorAll('.srv__item-wrap').forEach((wrap) => {
      const item = wrap.querySelector('.srv__item')
      if (!item) return

      gsap.from(item.querySelectorAll('.srv__mask > *'), {
        y: 80, opacity: 0, duration: 1.2, ease: "power3.out", stagger: 0.2,
        scrollTrigger: { trigger: item, start: "top 80%" }
      })

      ScrollTrigger.create({
        trigger: item,
        start: "top 78%",
        onEnter: () => wrap.classList.add('is-visible'),
      })

      const imgCol = item.querySelector('.srv__image-col')
      const img    = item.querySelector('.srv__image')

      if (imgCol && img) {
        gsap.fromTo(imgCol,
          { clipPath: "inset(100% 0 0 0)" },
          { clipPath: "inset(0% 0 0 0)", duration: 1.5, ease: "power3.inOut",
            scrollTrigger: { trigger: item, start: "top 75%" } }
        )
        if (window.innerWidth > 1024) {
          gsap.to(img, {
            yPercent: 25, ease: "none",
            scrollTrigger: { trigger: item, start: "top bottom", end: "bottom top", scrub: true }
          })
        }
      }
    })

    if (window.innerWidth > 1024) {
      document.querySelectorAll('.srv__connector').forEach((connector) => {
        const path = connector.querySelector('.srv__wave-path') as SVGPathElement | null
        const dots = connector.querySelectorAll('.srv__wave-dot')

        if (!path) return
        const length = path.getTotalLength()
        gsap.set(path, { strokeDasharray: length, strokeDashoffset: length })
        gsap.set(dots, { opacity: 0 })

        const tl = gsap.timeline({
          scrollTrigger: { trigger: connector, start: "top 70%", end: "bottom 30%", scrub: 1 }
        })

        tl.to(dots[0], { opacity: 1, duration: 0.1 })
        tl.to(path, { strokeDashoffset: 0, duration: 1, ease: "none" }, 0.05)
        tl.to(dots[1], { opacity: 1, duration: 0.1 }, 0.9)
      })
    }
  }

  initServicios()
  document.addEventListener('astro:after-swap', initServicios)
</script>