---
const NUMERO = "51999999999"
const MENSAJE = encodeURIComponent("Hola Studio2810, me gustaría obtener información sobre sus servicios.")
const href = `https://wa.me/${NUMERO}?text=${MENSAJE}`
---

<a class="wa-btn" href={href} target="_blank" rel="noopener noreferrer" aria-label="Escríbenos por WhatsApp">
  <span class="wa-btn__inner">
    <svg class="wa-btn__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <span class="wa-btn__text">Escríbenos</span>
  </span>
  <span class="wa-dot"></span>
</a>

<style is:global>
  /* ── BASE ── */
  .wa-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 9998;
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .wa-btn__inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: #0e1110;
    border: 1px solid rgba(240, 237, 232, 0.15);
    color: rgba(240, 237, 232, 0.75);
    padding: 0.7rem 1.2rem;
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease;
  }

  .wa-btn:hover .wa-btn__inner {
    border-color: rgba(240, 237, 232, 0.35);
    color: #f0ede8;
    background: #111614;
  }

  /* Punto verde */
  .wa-dot {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 9px;
    height: 9px;
    background: #25d366;
    border-radius: 50%;
    border: 1px solid #070908;
  }

  .wa-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid #25d366;
    animation: waPulse 2.5s ease-out infinite;
  }

  @keyframes waPulse {
    0%   { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.8); opacity: 0; }
  }

  /* ── MOBILE: pill compacto en la esquina inferior derecha ── */
  @media (max-width: 768px) {
    .wa-btn {
      /*
        Pegado al borde inferior respetando el safe area de iPhone
        (la barra de gestos). env(safe-area-inset-bottom) suma el
        espacio de la home bar automáticamente.
      */
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      right: 1rem;
    }

    .wa-btn__inner {
      /* Pill circular — sólo el ícono visible por defecto */
      width: 48px;
      height: 48px;
      padding: 0;
      border-radius: 50%;
      justify-content: center;
      overflow: hidden;
      /* Animación de expansión */
      transition:
        width 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        border-radius 0.35s ease,
        border-color 0.3s ease,
        color 0.3s ease,
        background 0.3s ease;
    }

    .wa-btn__text {
      /* Oculto por defecto, sin ocupar espacio */
      max-width: 0;
      opacity: 0;
      white-space: nowrap;
      overflow: hidden;
      transition:
        max-width 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        opacity 0.25s ease;
    }

    /* Al tocar: se expande mostrando el texto */
    .wa-btn.is-expanded .wa-btn__inner {
      width: 168px;
      border-radius: 24px;
      padding: 0 1.1rem;
      gap: 0.55rem;
    }

    .wa-btn.is-expanded .wa-btn__text {
      max-width: 120px;
      opacity: 1;
    }

    /* Punto más pequeño y reposicionado en mobile */
    .wa-dot {
      width: 8px;
      height: 8px;
      top: 2px;
      right: 2px;
    }
  }

  /* ── iPhone muy pequeño (SE, mini) ── */
  @media (max-width: 390px) {
    .wa-btn {
      bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
      right: 0.75rem;
    }

    .wa-btn__inner {
      width: 44px;
      height: 44px;
    }

    .wa-btn.is-expanded .wa-btn__inner {
      width: 158px;
    }
  }
</style>

<script>
  /*
    En desktop: el botón funciona directo como link, sin JS.
    En mobile: primer tap expande el pill mostrando el texto,
    segundo tap (o tap fuera) navega / colapsa.
    Se colapsa automáticamente a los 3s si no se navega.
  */
  const btn = document.querySelector('.wa-btn') as HTMLAnchorElement | null
  if (!btn) return

  const isMobile = () => window.innerWidth <= 768

  let collapseTimer: ReturnType<typeof setTimeout> | null = null

  function collapse() {
    btn.classList.remove('is-expanded')
    if (collapseTimer) clearTimeout(collapseTimer)
  }

  btn.addEventListener('click', (e) => {
    if (!isMobile()) return // desktop: comportamiento normal

    if (!btn.classList.contains('is-expanded')) {
      // Primer tap: expandir y cancelar navegación
      e.preventDefault()
      btn.classList.add('is-expanded')
      // Auto-colapsar a los 3s
      collapseTimer = setTimeout(collapse, 3000)
    }
    // Segundo tap: navega normalmente (href se ejecuta)
  })

  // Colapsar al tocar fuera
  document.addEventListener('touchstart', (e) => {
    if (isMobile() && btn.classList.contains('is-expanded') && !btn.contains(e.target as Node)) {
      collapse()
    }
  }, { passive: true })
</script>