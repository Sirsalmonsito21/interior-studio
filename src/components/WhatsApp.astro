---
const NUMERO = "51999999999"
const MENSAJE = encodeURIComponent("Hola Studio2810, me gustaría obtener información sobre sus servicios.")
const href = `https://wa.me/${NUMERO}?text=${MENSAJE}`
---

<a class="wa-btn" href={href} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L.057 23.886a.75.75 0 0 0 .921.921l6.106-1.457A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.706 9.706 0 0 1-4.953-1.355l-.355-.211-3.674.877.893-3.583-.23-.368A9.709 9.709 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
  </svg>
  <span class="wa-pulse"></span>
</a>

<style is:global>
  .wa-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 9998;
    width: 52px;
    height: 52px;
    background: #1a1f1d;
    border: 1px solid rgba(37, 211, 102, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #25d366;
    box-shadow: 0 4px 24px rgba(0,0,0,0.5);
    text-decoration: none;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .wa-btn:hover {
    background: #111614;
    transform: translateY(-3px);
  }

  .wa-pulse {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 10px;
    height: 10px;
    background: #25d366;
    border-radius: 50%;
  }

  .wa-pulse::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid #25d366;
    animation: waPulse 2s ease-out infinite;
  }

  @keyframes waPulse {
    0%   { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  @media (max-width: 768px) {
    .wa-btn {
      bottom: 1.2rem;
      right: 1.2rem;
      width: 46px;
      height: 46px;
    }
  }
</style>