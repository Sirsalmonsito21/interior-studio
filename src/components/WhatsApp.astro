---
const NUMERO = "51999999999"
const MENSAJE = encodeURIComponent("Hola Studio2810, me gustaría obtener información sobre sus servicios.")
const href = `https://wa.me/${NUMERO}?text=${MENSAJE}`
---

<a class="wa-btn" href={href} target="_blank" rel="noopener noreferrer" aria-label="Escríbenos">
  <span class="wa-btn__inner">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <span class="wa-btn__text">Escríbenos</span>
  </span>
  <span class="wa-dot"></span>
</a>

<style is:global>
  .wa-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 9998;
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .wa-btn__inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: #0e1110;
    border: 1px solid rgba(240, 237, 232, 0.15);
    color: rgba(240, 237, 232, 0.75);
    padding: 0.7rem 1.2rem;
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s ease,
                color 0.3s ease,
                background 0.3s ease;
  }

  .wa-btn:hover .wa-btn__inner {
    border-color: rgba(240, 237, 232, 0.35);
    color: #f0ede8;
    background: #111614;
  }

  /* Punto verde vivo */
  .wa-dot {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 9px;
    height: 9px;
    background: #25d366;
    border-radius: 50%;
    border: 1px solid #070908;
  }

  .wa-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid #25d366;
    animation: waPulse 2.5s ease-out infinite;
  }

  @keyframes waPulse {
    0%   { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.8); opacity: 0; }
  }

  @media (max-width: 1024px) {
  .wa-btn {
    bottom: 4rem;
    right: 1.2rem;
  }


    .wa-btn__inner {
      padding: 0.65rem 1rem;
      font-size: 0.65rem;
    }
  }
</style>