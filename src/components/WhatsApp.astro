---
const NUMERO = "51999999999"
const MENSAJE = encodeURIComponent("Hola Studio2810, me gustaría obtener información sobre sus servicios.")
const href = `https://wa.me/${NUMERO}?text=${MENSAJE}`
---

<a class="wa-btn" href={href} target="_blank" rel="noopener noreferrer" aria-label="Escríbenos por WhatsApp">
  <span class="wa-btn__inner">
    <svg class="wa-btn__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <span class="wa-btn__text">Escríbenos</span>
  </span>
  <span class="wa-dot"></span>
</a>

<style is:global>

  /* ═══════════════════════════════════════════
     COMPARTIDO — posición fija y punto verde
  ═══════════════════════════════════════════ */
  .wa-btn {
    position: fixed;
    z-index: 9998;
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .wa-dot {
    position: absolute;
    background: #25d366;
    border-radius: 50%;
    border: 1px solid #070908;
  }

  .wa-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid #25d366;
    animation: waPulse 2.5s ease-out infinite;
  }

  @keyframes waPulse {
    0%   { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.8); opacity: 0; }
  }

  /* ═══════════════════════════════════════════
     TELÉFONO — pill circular que se expande
     Aplica a TODOS los teléfonos: mini, 12, 14 Pro Max…
     (cualquier pantalla < 768px)
  ═══════════════════════════════════════════ */
  @media (max-width: 767px) {
    .wa-btn {
      bottom: calc(1.2rem + env(safe-area-inset-bottom, 0px));
      right: 1rem;
    }

    .wa-btn__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0e1110;
      border: 1px solid rgba(240, 237, 232, 0.2);
      color: rgba(240, 237, 232, 0.85);
      /* Pill circular por defecto — SOLO el ícono */
      width: 52px;
      height: 52px;
      border-radius: 50%;
      overflow: hidden;
      padding: 0;
      gap: 0;
      transition:
        width     0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        border-radius 0.35s ease,
        padding   0.35s ease,
        gap       0.35s ease,
        border-color 0.3s ease,
        color     0.3s ease,
        background 0.3s ease;
    }

    /* Texto oculto — sin ocupar espacio */
    .wa-btn__text {
      font-family: 'Manrope', system-ui, sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      white-space: nowrap;
      max-width: 0;
      opacity: 0;
      overflow: hidden;
      transition:
        max-width 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        opacity   0.25s ease;
    }

    /* Estado expandido (JS agrega .is-expanded) */
    .wa-btn.is-expanded .wa-btn__inner {
      width: 172px;
      height: 52px;
      border-radius: 26px;
      padding: 0 1.2rem;
      gap: 0.6rem;
      border-color: rgba(240, 237, 232, 0.35);
    }

    .wa-btn.is-expanded .wa-btn__text {
      max-width: 140px;
      opacity: 1;
    }

    /* Punto verde en phone */
    .wa-dot {
      width: 10px;
      height: 10px;
      top: 1px;
      right: 1px;
    }
  }

  /* ═══════════════════════════════════════════
     TABLET — botón rectangular compacto,
     sin texto, solo ícono + punto
     (768px – 1023px)
  ═══════════════════════════════════════════ */
  @media (min-width: 768px) and (max-width: 1023px) {
    .wa-btn {
      bottom: 2rem;
      right: 1.5rem;
    }

    .wa-btn__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0e1110;
      border: 1px solid rgba(240, 237, 232, 0.15);
      color: rgba(240, 237, 232, 0.8);
      width: 52px;
      height: 52px;
      border-radius: 4px;
      transition: border-color 0.3s ease, background 0.3s ease;
    }

    .wa-btn:hover .wa-btn__inner {
      border-color: rgba(240, 237, 232, 0.35);
      background: #111614;
    }

    /* Texto oculto en tablet */
    .wa-btn__text {
      display: none;
    }

    .wa-dot {
      width: 9px;
      height: 9px;
      top: -3px;
      right: -3px;
    }
  }

  /* ═══════════════════════════════════════════
     DESKTOP — botón completo con texto
     (≥ 1024px)
  ═══════════════════════════════════════════ */
  @media (min-width: 1024px) {
    .wa-btn {
      bottom: 2rem;
      right: 2rem;
    }

    .wa-btn__inner {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: #0e1110;
      border: 1px solid rgba(240, 237, 232, 0.15);
      color: rgba(240, 237, 232, 0.75);
      padding: 0.7rem 1.2rem;
      font-family: 'Manrope', system-ui, sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease;
    }

    .wa-btn:hover .wa-btn__inner {
      border-color: rgba(240, 237, 232, 0.35);
      color: #f0ede8;
      background: #111614;
    }

    .wa-btn__text {
      font-family: 'Manrope', system-ui, sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wa-dot {
      width: 9px;
      height: 9px;
      top: -4px;
      right: -4px;
    }
  }

</style>

<script>
  const btn = document.querySelector('.wa-btn') as HTMLAnchorElement | null
  if (!btn) throw new Error()

  const isPhone = () => window.innerWidth < 768

  let collapseTimer: ReturnType<typeof setTimeout> | null = null

  function collapse() {
    btn.classList.remove('is-expanded')
    if (collapseTimer) { clearTimeout(collapseTimer); collapseTimer = null }
  }

  btn.addEventListener('click', (e) => {
    // Solo en teléfono se activa el comportamiento de dos taps
    if (!isPhone()) return

    if (!btn.classList.contains('is-expanded')) {
      e.preventDefault()
      btn.classList.add('is-expanded')
      collapseTimer = setTimeout(collapse, 3000)
    }
    // Segundo tap: navega normalmente
  })

  document.addEventListener('touchstart', (e) => {
    if (isPhone() && btn.classList.contains('is-expanded') && !btn.contains(e.target as Node)) {
      collapse()
    }
  }, { passive: true })

  // Si el usuario rota el dispositivo, limpiar estado
  window.addEventListener('resize', () => {
    if (!isPhone()) collapse()
  })
</script>