---
const indicadores = [
  { numero: "50", label: "Proyectos", plus: true },
  { numero: "9",  label: "Años de experiencia", plus: true },
  { numero: "100", label: "Acompañamiento", plus: false, suffix: "%" },
]
---

<section class="esencia" id="esencia">
  <div class="esencia__inner">

    <!-- MOBILE: título va primero -->
    <div class="esencia__title-mobile">
      <span class="label esencia__label">Nuestra Esencia</span>
      <h2 class="esencia__title">
        Diseñamos con<br />
        <em>propósito y detalle</em>
      </h2>
    </div>

    <!-- Imagen -->
    <div class="esencia__image-col">
      <img
        class="esencia__image"
        src="https://images.unsplash.com/photo-1600210492493-0946911123ea?w=1200&q=85"
        alt="Proyecto Studio2810"
        loading="lazy"
      />
    </div>

    <!-- Texto derecha (desktop) / debajo imagen (mobile) -->
    <div class="esencia__text-col">

      <!-- Solo visible en desktop -->
      <div class="esencia__title-desktop">
        <span class="label esencia__label">Nuestra Esencia</span>
        <h2 class="esencia__title">
          Diseñamos con<br />
          <em>propósito y detalle</em>
        </h2>
      </div>

      <p class="esencia__body">
        En Studio2810 creemos que un espacio bien diseñado transforma
        la manera en que vivimos, sentimos y nos relacionamos con el mundo.
        Cada línea, textura y luz tiene una razón de ser.
      </p>

      <p class="esencia__body">
        Nuestro proceso combina escucha profunda, rigor técnico y
        sensibilidad estética para entregar ambientes que son, ante todo,
        auténticamente tuyos.
      </p>

      <div class="esencia__indicadores">
        {indicadores.map(ind => (
          <div class="esencia__ind">
            <span
              class="esencia__ind-num"
              data-val={ind.numero}
              data-plus={String(ind.plus)}
              data-suffix={ind.suffix ?? ''}
            >
              {ind.plus ? '+' : ''}{ind.numero}{ind.suffix ?? ''}
            </span>
            <span class="esencia__ind-label label">{ind.label}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .esencia {
    background: #0e1110;
    padding: var(--space-24) var(--space-8);
  }

  .esencia__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-20);
    align-items: center;
  }

  /* Título mobile — oculto en desktop */
  .esencia__title-mobile {
    display: none;
  }

  /* Título desktop — visible en desktop */
  .esencia__title-desktop {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ── IMAGEN ── */
  .esencia__image-col {
    width: 100%;
    height: 600px;
    overflow: hidden;
    background: #1a1f1d;
  }

  .esencia__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1.2s ease, transform 1.2s ease;
  }

  .esencia__image.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── TEXTO ── */
  .esencia__text-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .esencia__label { color: var(--secondary-fixed-dim); }

  .esencia__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #f0ede8;
  }

  .esencia__title em { font-style: italic; }

  .esencia__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(240, 237, 232, 0.65);
    max-width: 480px;
  }

  /* ── INDICADORES ── */
  .esencia__indicadores {
    display: flex;
    gap: var(--space-8);
    margin-top: var(--space-4);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(240, 237, 232, 0.08);
  }

  .esencia__ind {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .esencia__ind-num {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 2.5vw, 2.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: #f0ede8;
  }

  .esencia__ind-label {
    color: rgba(240, 237, 232, 0.4);
    font-size: 0.7rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .esencia__image-col { height: 500px; }
  }

  @media (max-width: 768px) {
    .esencia {
      padding: var(--space-20) var(--space-6);
    }

    /* Grid pasa a una columna */
    .esencia__inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Título mobile aparece primero */
    .esencia__title-mobile {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
      align-items: center;
      margin-bottom: var(--space-8);
    }

    /* Imagen en segundo lugar */
    .esencia__image-col {
      order: 2;
      height: 280px;
      width: 100%;
      margin-bottom: var(--space-8);
    }

    /* Título desktop oculto en mobile */
    .esencia__title-desktop { display: none; }

    /* Texto después de imagen */
    .esencia__text-col {
      order: 3;
      text-align: center;
      align-items: center;
    }

    .esencia__body {
      max-width: 100%;
      text-align: center;
    }

    /* Indicadores centrados */
    .esencia__indicadores {
      justify-content: center;
      flex-wrap: wrap;
      gap: var(--space-6);
      width: 100%;
    }

    .esencia__ind {
      align-items: center;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .esencia__image-col { height: 240px; }

    .esencia__title-mobile h2 {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  const img = document.querySelector('.esencia__image')
  if (img) {
    const obs = new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) {
          img.classList.add('is-visible')
          obs.disconnect()
        }
      },
      { threshold: 0.15 }
    )
    obs.observe(img)
  }

  gsap.from('.esencia__text-col > *', {
    scrollTrigger: { trigger: '.esencia', start: 'top 75%' },
    opacity: 0, x: 30, duration: 0.9, stagger: 0.15, ease: 'power2.out'
  })

  function animateCounter(el: Element) {
    const val    = parseInt(el.getAttribute('data-val') ?? '0')
    const plus   = el.getAttribute('data-plus') === 'true'
    const suffix = el.getAttribute('data-suffix') ?? ''
    const obj    = { v: 0 }
    gsap.to(obj, {
      v: val, duration: 2, ease: 'power3.out',
      onUpdate() { el.textContent = (plus ? '+' : '') + Math.round(obj.v) + suffix },
      onComplete() { el.textContent = (plus ? '+' : '') + val + suffix }
    })
  }

  document.querySelectorAll('.esencia__ind-num').forEach(el => {
    const obs = new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) { animateCounter(el); obs.disconnect() }
      },
      { threshold: 0.5 }
    )
    obs.observe(el)
  })
</script>