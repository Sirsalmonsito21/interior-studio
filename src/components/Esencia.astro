---
const indicadores = [
  { numero: "50", label: "Proyectos", plus: true },
  { numero: "9",  label: "Años de experiencia", plus: true },
  { numero: "100", label: "Acompañamiento", plus: false, suffix: "%" },
]
---

<section class="esencia" id="esencia">
  <div class="esencia__container">
    
    <div class="esencia__content">
      <div class="esencia__mask">
        <h2 class="esencia__title">
          Diseño que<br />
          <em class="esencia__italic">transforma espacios</em>
        </h2>
      </div>

      <div class="esencia__text-blocks">
        <div class="esencia__mask">
          <p class="esencia__body">
            En Studio2810 diseñamos espacios con intención, sensibilidad y claridad.
            Entendemos el diseño como una experiencia cercana, donde escuchar y comprender
            al cliente es tan importante como proponer.
          </p>
        </div>
        <div class="esencia__mask">
          <p class="esencia__body">
            Nuestro enfoque combina la funcionalidad arquitectónica con una curaduría 
            meticulosa de materiales, logrando ambientes que no solo se ven bien, 
            sino que se sienten propios.
          </p>
        </div>
      </div>

      <div class="esencia__stats">
        {indicadores.map((ind) => (
          <div class="esencia__stat-item esencia__mask">
            <div class="esencia__stat-inner">
              <span class="esencia__number" data-target={ind.numero}>0</span>
              <span class="esencia__suffix">{ind.plus ? '+' : ''}{ind.suffix || ''}</span>
              <p class="esencia__stat-label">{ind.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="esencia__image-wrapper">
      <div class="esencia__parallax-container">
        <img
          class="esencia__image"
          src="/images/comedor3.jpeg"
          alt="Proyecto Studio2810"
          loading="eager"
        />
      </div>
    </div>

  </div>
</section>

<style>
  .esencia {
    padding: 120px 0;
    background-color: #F9F8F5;
    overflow: hidden;
  }

  .esencia__container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 5vw;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 100px;
    align-items: center;
  }

  /* ── Texto y Máscaras ── */
  .esencia__mask {
    overflow: hidden;
    margin-bottom: 5px;
  }

  .esencia__title {
    font-family: 'Jost', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    color: #1a1a1a;
    margin-bottom: 40px;
  }

  .esencia__italic {
    font-style: italic;
    color: #a07846; /* Color de acento */
  }

  .esencia__body {
    font-family: 'Jost', sans-serif;
    font-size: 1.15rem;
    line-height: 1.7;
    color: #444;
    max-width: 500px;
    margin-bottom: 1.5rem;
  }

  /* ── Indicadores ── */
  .esencia__stats {
    display: flex;
    gap: 40px;
    margin-top: 50px;
  }

  .esencia__number {
    font-size: 2.5rem;
    font-weight: 500;
    color: #1a1a1a;
  }

  .esencia__suffix {
    font-size: 1.5rem;
    color: #a07846;
    margin-left: 2px;
  }

  .esencia__stat-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    margin-top: 5px;
  }

  /* ── Imagen y Parallax ── */
  .esencia__image-wrapper {
    position: relative;
    height: 650px; /* Altura fija para mayor impacto */
    overflow: hidden;
    clip-path: inset(0); /* Contenedor limpio */
  }

  .esencia__parallax-container {
    position: absolute;
    top: -15%; /* Espacio extra para el movimiento */
    left: 0;
    width: 100%;
    height: 130%; /* La imagen es más alta que el marco */
  }

  .esencia__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .esencia__container {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .esencia__image-wrapper {
      height: 500px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initEsencia() {
    // 1. Revelación de Textos (Masking)
    const itemsToReveal = document.querySelectorAll('.esencia__mask > *');
    
    gsap.from(itemsToReveal, {
      y: 80, // Un poco más de recorrido para que se note el efecto
      opacity: 0,
      duration: 1.4,
      ease: "power4.out",
      stagger: 0.1,
      scrollTrigger: {
        trigger: ".esencia",
        start: "top 75%",
      }
    });

    // 2. Parallax de la Imagen (Más Notorio)
    gsap.to('.esencia__image', {
      yPercent: 25, // Incrementado para que el movimiento sea más obvio
      ease: "none",
      scrollTrigger: {
        trigger: ".esencia__image-wrapper",
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });

    // 3. Animación de Contadores (Numbers)
    const numbers = document.querySelectorAll('.esencia__number');
    numbers.forEach(num => {
      const target = parseInt(num.getAttribute('data-target') || "0");
      
      gsap.to(num, {
        innerText: target,
        duration: 2.5,
        snap: { innerText: 1 }, // Asegura números enteros
        ease: "power2.out",
        scrollTrigger: {
          trigger: num,
          start: "top 90%",
        }
      });
    });
  }

  // Inicializar
  initEsencia();
</script>