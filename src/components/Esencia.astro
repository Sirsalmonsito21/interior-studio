---
const indicadores = [
  { numero: "50", label: "Proyectos", plus: true },
  { numero: "9",  label: "Años de experiencia", plus: true },
  { numero: "100", label: "Acompañamiento", plus: false, suffix: "%" },
]
---

<section class="esencia" id="esencia">
  <div class="esencia__inner">

    <div class="esencia__text-col">
      <div class="esencia__label-wrap">
        <span class="esencia__label-line"></span>
        <span class="esencia__label">Nuestra Esencia</span>
      </div>

      <h2 class="esencia__title">
        Diseñamos con<br />
        <em>propósito y detalle</em>
      </h2>
    </div>

    <div class="esencia__image-col">
      <div class="esencia__image-frame">
        <img
          class="esencia__image"
          src="/images/comedor3.jpeg"
          alt="Proyecto Studio2810"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div class="esencia__image-tag">
          <span>Studio2810</span>
          <span class="esencia__image-tag-line"></span>
          <span>Lima, Perú</span>
        </div>
      </div>
    </div>

    <div class="esencia__body-col">
      <p class="esencia__body">
        En Studio2810 creemos que un espacio bien diseñado transforma
        la manera en que vivimos, sentimos y nos relacionamos con el mundo.
        Cada línea, textura y luz tiene una razón de ser.
      </p>
      <p class="esencia__body">
        Nuestro proceso combina escucha profunda, rigor técnico y
        sensibilidad estética para entregar ambientes que son, ante todo,
        auténticamente tuyos.
      </p>
      <div class="esencia__indicadores">
        {indicadores.map(ind => (
          <div class="esencia__ind">
            <span
              class="esencia__ind-num"
              data-val={ind.numero}
              data-plus={String(ind.plus)}
              data-suffix={ind.suffix ?? ''}
            >
              {ind.plus ? '+' : ''}{ind.numero}{ind.suffix ?? ''}
            </span>
            <span class="esencia__ind-label">{ind.label}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400&display=swap');

  .esencia {
    background: #f5f2ee;
    padding: 10rem 5vw;
    overflow: hidden;
  }

  /* ── DESKTOP: grid 2 columnas ── */
  .esencia__inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.45fr 0.55fr;
    grid-template-rows: auto auto;
    column-gap: 5vw;
    row-gap: 3rem;
    grid-template-areas:
      "img  text"
      "img  body";
    align-items: start;
  }

  .esencia__text-col  { grid-area: text; }
  .esencia__image-col { grid-area: img;  }
  .esencia__body-col  { grid-area: body; }

  /* ── IMAGEN ── */
  .esencia__image-col {
    position: relative;
  }

  .esencia__image-frame {
    position: relative;
    overflow: hidden;
  }

  .esencia__image-frame::before {
    content: '';
    position: absolute;
    top: -24px;
    left: -24px;
    width: 60%;
    height: 60%;
    border: 1px solid rgba(160, 140, 110, 0.25);
    z-index: 0;
    transition: transform 0.8s ease;
  }

  .esencia__image-col:hover .esencia__image-frame::before {
    transform: translate(-6px, -6px);
  }

  .esencia__image-frame::after {
    content: '';
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 45%;
    height: 45%;
    background: rgba(160, 140, 110, 0.08);
    z-index: 0;
    transition: transform 0.8s ease;
  }

  .esencia__image-col:hover .esencia__image-frame::after {
    transform: translate(6px, 6px);
  }

  .esencia__image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 640px;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 1.4s ease, transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .esencia__image.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .esencia__image-tag {
    position: absolute;
    bottom: 24px;
    left: 24px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #0f0f0d;
    background: rgba(245, 242, 238, 0.92);
    padding: 0.55em 1em;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.8s ease 0.6s, transform 0.8s ease 0.6s;
  }

  .esencia__image-frame:has(.is-visible) .esencia__image-tag {
    opacity: 1;
    transform: translateY(0);
  }

  .esencia__image-tag-line {
    display: inline-block;
    width: 22px;
    height: 1px;
    background: rgba(0, 0, 0, 0.35);
  }

  /* ── TEXTO ── */
  .esencia__text-col {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding-top: 1rem;
  }

  .esencia__label-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .esencia__label-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: rgba(100, 85, 60, 0.4);
    flex-shrink: 0;
  }

  .esencia__label {
    font-family: 'Jost', sans-serif;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(100, 85, 60);
  }

  .esencia__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 3.8vw, 3.6rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #0a0a08;
  }

  .esencia__title em {
    font-style: italic;
    color: rgb(110, 90, 55);
  }

  /* ── BODY COL ── */
  .esencia__body-col {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  padding-bottom: 3rem; /* antes era 2rem */
  border-bottom: 1px solid rgba(100, 85, 60, 0.15);
}

  .esencia__body {
    font-family: 'Jost', sans-serif;
    font-size: 0.97rem;
    font-weight: 300;
    line-height: 1.85;
    color: rgba(20, 18, 14, 0.82);
  }

  /* ── INDICADORES ── */
  .esencia__indicadores {
    display: flex;
    gap: 3rem;
    margin-top: 0.5rem;
    padding-top: 2rem;
  }

  .esencia__ind {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .esencia__ind-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 2.8vw, 2.8rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #0a0a08;
    line-height: 1;
  }

  .esencia__ind-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(20, 18, 14, 0.65);
  }

  /* ── TABLET (iPad landscape ~1024px) ── */
  @media (max-width: 1024px) {
    .esencia {
      padding: 7rem 4vw;
    }

    .esencia__inner {
      grid-template-columns: 1.2fr 0.8fr;
    }

    .esencia__image { height: 520px; }
  }

  /* ── TABLET PORTRAIT + MOBILE ── */
  @media (max-width: 860px) {
    .esencia {
      padding: 5rem 1.6rem 4rem;
    }

    .esencia__inner {
      grid-template-columns: 1fr;
      grid-template-areas:
        "text"
        "img"
        "body";
      row-gap: 2rem;
    }

    .esencia__image-frame::before,
    .esencia__image-frame::after {
      display: none;
    }

    /* Imagen: animación fade+scale activada por JS */
    .esencia__image {
      height: 340px;
      opacity: 0;
      transform: scale(1.04);
    }

    .esencia__image.is-visible {
      opacity: 1;
      transform: scale(1);
    }

    .esencia__image-tag {
      opacity: 0;
      transform: translateY(8px);
      font-size: 0.6rem;
      padding: 0.45em 0.85em;
      bottom: 14px;
      left: 14px;
    }

    .esencia__image-frame:has(.is-visible) .esencia__image-tag {
      opacity: 1;
      transform: translateY(0);
    }

    .esencia__text-col {
      padding-top: 0;
      gap: 1rem;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }

    .esencia__text-col.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .esencia__title {
      font-size: 2.2rem;
    }

    .esencia__body-col {
      gap: 1.2rem;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.9s ease 0.15s, transform 0.9s ease 0.15s;
    }

    .esencia__body-col.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .esencia__body {
      font-size: 0.93rem;
    }

    /* Indicadores: 3 columnas simétricas centradas */
    .esencia__indicadores {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      padding-top: 1.5rem;
      text-align: center;
    }

    .esencia__ind {
      align-items: center;
      padding: 0 0.5rem;
    }

    /* Separador vertical entre indicadores */
    .esencia__ind + .esencia__ind {
      border-left: 1px solid rgba(100, 85, 60, 0.15);
    }

    .esencia__ind-num { font-size: 1.9rem; }

    .esencia__ind-label {
      font-size: 0.58rem;
      letter-spacing: 0.08em;
      text-align: center;
    }
  }

  /* ── iPhone 12 mini (390px y menos) ── */
  @media (max-width: 390px) {
    .esencia {
      padding: 4.5rem 1.2rem 3.5rem;
    }

    .esencia__image { height: 260px; }

    .esencia__title { font-size: 1.9rem; }

    .esencia__ind-num { font-size: 1.7rem; }

    .esencia__ind-label { font-size: 0.55rem; }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  const isDesktop = window.innerWidth > 860

  if (isDesktop) {
    // Desktop: imagen con IntersectionObserver
    const img = document.querySelector('.esencia__image')
    if (img) {
      const obs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) { img.classList.add('is-visible'); obs.disconnect() }
        },
        { threshold: 0.1 }
      )
      obs.observe(img)
    }

    gsap.from('.esencia__text-col > *', {
      scrollTrigger: { trigger: '.esencia', start: 'top 70%' },
      opacity: 0, x: 30, duration: 1.1, stagger: 0.13, ease: 'power3.out',
    })

    gsap.from('.esencia__body-col > *', {
      scrollTrigger: { trigger: '.esencia', start: 'top 60%' },
      opacity: 0, x: 30, duration: 1.1, stagger: 0.13, ease: 'power3.out',
    })

    gsap.from('.esencia__image-col', {
      scrollTrigger: { trigger: '.esencia', start: 'top 70%' },
      opacity: 0, x: -36, duration: 1.2, ease: 'power3.out',
    })

  } else {
    // Mobile/tablet: animaciones con IntersectionObserver (sin GSAP)

    // Imagen: fade + scale al hacer scroll
    const img = document.querySelector('.esencia__image')
    if (img) {
      const imgObs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) { img.classList.add('is-visible'); imgObs.disconnect() }
        },
        { threshold: 0.15 }
      )
      imgObs.observe(img)
    }

    // Título: fade + slide up al hacer scroll
    const textCol = document.querySelector('.esencia__text-col')
    if (textCol) {
      const textObs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) { textCol.classList.add('is-visible'); textObs.disconnect() }
        },
        { threshold: 0.2 }
      )
      textObs.observe(textCol)
    }

    // Body + indicadores: fade + slide up con delay
    const bodyCol = document.querySelector('.esencia__body-col')
    if (bodyCol) {
      const bodyObs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) { bodyCol.classList.add('is-visible'); bodyObs.disconnect() }
        },
        { threshold: 0.15 }
      )
      bodyObs.observe(bodyCol)
    }
  }

  // Contadores — funcionan en todos los tamaños
  function animateCounter(el: Element) {
    const val    = parseInt(el.getAttribute('data-val') ?? '0')
    const plus   = el.getAttribute('data-plus') === 'true'
    const suffix = el.getAttribute('data-suffix') ?? ''
    const obj    = { v: 0 }
    gsap.to(obj, {
      v: val, duration: 2, ease: 'power3.out',
      onUpdate() { el.textContent = (plus ? '+' : '') + Math.round(obj.v) + suffix },
      onComplete() { el.textContent = (plus ? '+' : '') + val + suffix },
    })
  }

  document.querySelectorAll('.esencia__ind-num').forEach(el => {
    const obs = new IntersectionObserver(
      ([e]) => { if (e.isIntersecting) { animateCounter(el); obs.disconnect() } },
      { threshold: 0.3 }
    )
    obs.observe(el)
  })
</script>