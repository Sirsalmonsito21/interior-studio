---
const indicadores = [
  { numero: "50", label: "Proyectos", plus: true },
  { numero: "9",  label: "Años de experiencia", plus: true },
  { numero: "100", label: "Acompañamiento", plus: false, suffix: "%" },
]
---

<section class="esencia" id="esencia">
  <div class="esencia__container">
    
    <div class="esencia__content">
      <div class="esencia__title-col">
        <div class="esencia__mask">
          <h2 class="esencia__title">
            Diseño que<br />
            <em class="esencia__italic">transforma espacios</em>
          </h2>
        </div>
      </div>

      <div class="esencia__text-col">
        <div class="esencia__text-blocks">
          <div class="esencia__mask">
            <p class="esencia__body">
              En Studio2810 diseñamos espacios con intención, sensibilidad y claridad.
              Entendemos el diseño como una experiencia cercana, donde escuchar y comprender
              al cliente es tan importante como proponer.
            </p>
          </div>
          <div class="esencia__mask">
            <p class="esencia__body">
              Nuestro enfoque combina la funcionalidad arquitectónica con una curaduría 
              meticulosa de materiales, logrando ambientes que no solo se ven bien, 
              sino que se sienten propios.
            </p>
          </div>
        </div>

        <div class="esencia__stats">
          {indicadores.map((ind) => (
            <div class="esencia__stat-item esencia__mask">
              <div class="esencia__stat-inner">
                <span class="esencia__number" data-target={ind.numero}>0</span>
                <span class="esencia__suffix">{ind.plus ? '+' : ''}{ind.suffix || ''}</span>
                <p class="esencia__stat-label">{ind.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="esencia__image-wrapper">
      <div class="esencia__parallax-container">
        <img
          class="esencia__image"
          src="/images/comedor3UP.webp"
          alt="Proyecto Studio2810"
          loading="eager"
        />
      </div>
    </div>

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap');

  .esencia {
    padding: 120px 0;
    background-color: #F9F8F5;
    overflow: hidden;
  }

  /* ── GRID ORIGINAL PC (Intacto) ── */
  .esencia__container {
    display: grid;
    grid-template-columns: 38% 1fr; 
    align-items: center;
    gap: 6vw; 
    padding-left: 6vw; 
    padding-right: 0;  
  }

  /* NUEVO: Forzamos a que toda la columna izquierda se centre sobre sí misma */
  .esencia__content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .esencia__mask { overflow: hidden; margin-bottom: 5px; }

  .esencia__title {
    font-family: 'Playfair Display', serif;
    text-align: center;
    font-size: clamp(2.5rem, 4.5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: #1a1a1a;
    margin-bottom: 40px;
    letter-spacing: -0.02em;
  }

  .esencia__italic { font-style: italic; color: #a07846; }

  .esencia__body {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.7;
    color: #444;
    max-width: 600px; 
    /* NUEVO: Centra el bloque de texto horizontalmente */
    margin: 0 auto 1.5rem auto; 
    text-align: center;
  }

  .esencia__stats {
    display: flex;
    /* NUEVO: Centra los números horizontalmente */
    justify-content: center; 
    gap: 50px;
    margin-top: 50px;
    text-align: center;
  }

  .esencia__number {
    font-family: 'Inter', sans-serif;
    font-size: 2.5rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.03em;
  }

  .esencia__suffix {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    color: #a07846;
    margin-left: 2px;
  }

  .esencia__stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    margin-top: 5px;
  }

  .esencia__image-wrapper {
    position: relative;
    width: 100%;
    height: 85vh; 
    min-height: 700px;
    overflow: hidden;
    clip-path: inset(0);
  }

  .esencia__parallax-container {
    position: absolute;
    top: -15%;
    left: 0;
    width: 100%;
    height: 130%;
  }

  .esencia__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
  }

  /* ── REDISEÑO REACTIVE (Mobile e iPad) ── */
  @media (max-width: 1024px) {
    .esencia { padding: 80px 0; }
    
    .esencia__container {
      display: flex;
      flex-direction: column;
      padding: 0; 
      gap: 0; 
    }

    .esencia__content { display: contents; }

    .esencia__title-col {
      order: 1;
      padding: 0 6vw; 
      text-align: center;
      margin-bottom: 40px;
    }
    .esencia__title { margin-bottom: 0; }

    .esencia__image-wrapper {
      order: 2;
      width: 100%;
      height: 55vh;
      min-height: 350px;
      margin-bottom: 40px;
    }

    .esencia__text-col {
      order: 3;
      padding: 0 6vw;
      text-align: center;
    }
    
    .esencia__body {
      margin-left: auto;
      margin-right: auto;
    }

    .esencia__stats {
      justify-content: center;
      flex-wrap: wrap; 
      gap: 30px;
      margin-top: 10px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initEsencia() {
    const itemsToReveal = document.querySelectorAll('.esencia__mask > *');
    
    gsap.from(itemsToReveal, {
      y: 80, 
      opacity: 0,
      duration: 1.4,
      ease: "power4.out",
      stagger: 0.1,
      scrollTrigger: {
        trigger: ".esencia",
        start: "top 75%",
      }
    });

    gsap.to('.esencia__image', {
      yPercent: 25, 
      ease: "none",
      scrollTrigger: {
        trigger: ".esencia__image-wrapper",
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });

    const numbers = document.querySelectorAll('.esencia__number');
    numbers.forEach(num => {
      const target = parseInt(num.getAttribute('data-target') || "0");
      
      gsap.to(num, {
        innerText: target,
        duration: 2.5,
        snap: { innerText: 1 }, 
        ease: "power2.out",
        scrollTrigger: {
          trigger: num,
          start: "top 90%",
        }
      });
    });
  }

  initEsencia();
</script>