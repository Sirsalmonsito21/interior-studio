---
const navLinks = [
  { label: "Nosotros",   href: "#esencia"   },
  { label: "Servicios",  href: "#servicios"  },
  { label: "Portafolio", href: "#portafolio" },
  { label: "Contacto",   href: "#contacto"   },
]
---

<footer class="footer">

  <div class="footer__body">
    <div class="footer__body-inner">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <span class="footer__logo-main">STUDIO</span>
          <span class="footer__logo-sub">2810</span>
        </a>
        <p class="footer__tagline">
          Espacios que cuentan<br />tu historia.
        </p>
      </div>

      <nav class="footer__nav">
        <span class="label footer__nav-label">Navegación</span>
        <ul class="footer__nav-list">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="footer__nav-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__contact">
        <span class="label footer__contact-label">Contacto</span>
        <div class="footer__contact-list">
          <a href="mailto:hola@studio2810.com" class="footer__contact-item">hola@studio2810.com</a>
          <a href="https://wa.me/51999999999" target="_blank" class="footer__contact-item">+51 999 999 999</a>
          <span class="footer__contact-item">Lima, Perú</span>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bar">
    <div class="footer__bar-inner">
      <span class="footer__copy">© 2025 Studio2810. Todos los derechos reservados.</span>
      <a href="#inicio" class="footer__top">Volver arriba <span>↑</span></a>
    </div>
  </div>

</footer>

<style>
  .footer { background: #070908; }

  /* ── CUERPO ── */
  .footer__body {
    border-bottom: 1px solid rgba(240, 237, 232, 0.06);
  }

  .footer__body-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-20) var(--space-8);
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-20);
    align-items: start;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer__logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 4px;
  }

  .footer__logo-main {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: #f0ede8;
  }

  .footer__logo-sub {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.3);
  }

  .footer__tagline {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
    color: rgba(240, 237, 232, 0.3);
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer__nav-label { color: rgba(240, 237, 232, 0.25); }

  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__nav-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(240, 237, 232, 0.5);
    text-decoration: none;
    transition: color 0.3s ease;
    position: relative;
    display: inline-block;
    padding-bottom: 1px;
  }

  .footer__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 1px;
    background: var(--secondary-fixed-dim);
    transition: width 0.35s ease;
  }

  .footer__nav-link:hover { color: #f0ede8; }
  .footer__nav-link:hover::after { width: 100%; }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer__contact-label { color: rgba(240, 237, 232, 0.25); }

  .footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__contact-item {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(240, 237, 232, 0.5);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  a.footer__contact-item:hover { color: #f0ede8; }

  /* ── BARRA ── */
  .footer__bar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__copy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(240, 237, 232, 0.2);
  }

  .footer__top {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.25);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.3s ease;
  }

  .footer__top:hover { color: rgba(240, 237, 232, 0.7); }

  /* ── TABLET ── */
  @media (min-width: 769px) and (max-width: 1024px) {
    .footer__body-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
      padding: var(--space-8);
    }

    .footer__brand {
      grid-column: span 2;
      align-items: center;
      text-align: center;
    }

    .footer__tagline { text-align: center; }
    .footer__nav { align-items: flex-start; }
    .footer__nav-list { align-items: flex-start; }
    .footer__contact { align-items: flex-start; }
    .footer__contact-list { align-items: flex-start; }

    .footer__bar-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .footer__body-inner {
      grid-template-columns: 1fr;
      padding: var(--space-8) var(--space-6);
      gap: var(--space-8);
    }

    .footer__brand {
      align-items: center;
      text-align: center;
    }

    .footer__tagline { text-align: center; }
    .footer__nav { align-items: center; }
    .footer__nav-list { align-items: center; }
    .footer__contact { align-items: center; }
    .footer__contact-list { align-items: center; }
    .footer__contact-item { text-align: center; }

    .footer__bar-inner {
      padding: var(--space-6);
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }

    .footer__copy { text-align: center; }
  }
</style>