---
const navLinks = [
  { label: "Nosotros",   href: "#esencia",    key: "nav.nosotros"   },
  { label: "Servicios",  href: "#servicios",  key: "nav.servicios"  },
  { label: "Portafolio", href: "#portafolio", key: "nav.portafolio" },
  { label: "Contacto",   href: "#contacto",   key: "nav.contacto"   },
]
---

<footer class="footer">
  <div class="footer__body">
    <div class="footer__body-inner">

      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="/images/studioLOGO.jpeg" alt="Studio 2810 Logo" class="footer__logo-img" />
        </a>
        <p class="footer__tagline" data-i18n="footer.tagline">
          Espacios que cuentan<br />tu historia.
        </p>
      </div>

      <nav class="footer__nav">
        <span class="footer__label" data-i18n="footer.nav.label">Navegación</span>
        <ul class="footer__nav-list">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="footer__nav-link" data-i18n={link.key}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__contact">
        <span class="footer__label" data-i18n="footer.cont.label">Contacto</span>
        <div class="footer__contact-list">
         /* ──  <a href="mailto:hola@studio2810.com" class="footer__contact-item">hola@studio2810.com</a>── */ 
          <a href="https://wa.me/51912813145" target="_blank" class="footer__contact-item">+51 912 813 145</a>
          <span class="footer__contact-item">Lima, Perú</span>
        </div>
      </div>

    </div>
  </div>

  <div class="footer__bar">
    <div class="footer__bar-inner">
      <span class="footer__copy" data-i18n="footer.copy">© 2025 Studio2810. Todos los derechos reservados.</span>
      <a href="#hero" class="footer__top" data-i18n="footer.top">Volver arriba <span>↑</span></a>
    </div>
  </div>
</footer>

<style>
  /* Importamos las fuentes para asegurar consistencia */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital@0;1&family=Jost:wght@300;400;500&display=swap');

  .footer { 
    background: #0a0a08; /* Fondo oscuro igual al de contacto */
    color: #f0ede8;
    padding-top: 4rem;
  }

  /* ── CUERPO ── */
  .footer__body {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer__body-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 5vw;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .footer__logo-img {
  width: 140px;
  height: auto;
  filter: invert(1);
  }

  .footer__logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 5px;
  }

  .footer__logo-main {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: #fff;
  }

  .footer__logo-sub {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer__tagline {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__label { 
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgb(255, 255, 255);
    margin-bottom: 1.5rem;
    display: block;
  }

  .footer__nav-list, .footer__contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__nav-link, .footer__contact-item {
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .footer__nav-link:hover, .footer__contact-item:hover { 
    color: #fff; 
  }

  /* ── BARRA FINAL ── */
  .footer__bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 5vw;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__copy {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.2);
  }

  .footer__top {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.3s ease;
  }

  .footer__top:hover { color: #fff; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .footer__body-inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .footer__brand { grid-column: span 2; align-items: center; text-align: center; }
  }

  @media (max-width: 768px) {
    .footer__body-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer__brand, .footer__nav, .footer__contact {
      grid-column: span 1;
      align-items: center;
    }
    .footer__bar-inner {
      flex-direction: column-reverse;
      gap: 1.5rem;
      text-align: center;
    }
  }
</style>