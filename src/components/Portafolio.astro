---
const categorias = [
  {
    id: "sala",
    label: "Sala de Estar",
    tipo: "RESIDENCIAL",
    cover: "/images/sala1.jpeg",
    imagenes: [
      "/images/sala1.jpeg",
      "/images/sala2.jpeg",
      "/images/sala3.jpeg",
      "/images/sala4.jpeg",
      "/images/sala5.jpeg",
      "/images/sala6.jpeg",
      "/images/sala7.jpeg",
      "/images/sala8.jpeg",
    ]
  },
  {
    id: "comedor",
    label: "Comedor",
    tipo: "RESIDENCIAL",
    cover: "/images/comedor1.jpeg",
    imagenes: [
      "/images/comedor1.jpeg",
      "/images/comedor2.jpeg",
      "/images/comedor3.jpeg",
    ]
  },
  {
    id: "cocina",
    label: "Cocina",
    tipo: "RESIDENCIAL",
    cover: "/images/cocina1.PNG",
    imagenes: [
      "/images/cocina1.PNG",
      "/images/cocina2.jpeg",
      "/images/cocina3.jpeg",
      "/images/cocina4.jpeg",
      "/images/cocina5.jpeg",
    ]
  },
  {
    id: "bano",
    label: "Baño de Diseño",
    tipo: "RESIDENCIAL",
    cover: "/images/baño1.jpeg",
    imagenes: [
      "/images/baño1.jpeg",
      "/images/baño2.jpeg",
    ]
  },
  {
    id: "oficina",
    label: "Oficina Ejecutiva",
    tipo: "COMERCIAL",
    cover: "/images/oficina1.png",
    imagenes: [
      "/images/oficina1.png",
      "/images/oficina2.png",
    ]
  },
  {
    id: "ninos",
    label: "Espacio Niños",
    tipo: "RESIDENCIAL",
    cover: "/images/niño1.jpeg",
    imagenes: [
      "/images/niño1.jpeg",
      "/images/niño2.jpeg",
      "/images/niño3.jpeg",
      "/images/niña1.jpeg",
      "/images/niña2.PNG",
      "/images/niña3.jpeg",
      "/images/niña4.jpeg",
      "/images/niña5.jpeg",
      "/images/niña6.jpeg",
      "/images/niña7.jpeg",
      "/images/niña8.jpeg",
      "/images/niña9.jpeg",
    ]
  },
  {
    id: "entrada",
    label: "Entrada",
    tipo: "RESIDENCIAL",
    cover: "/images/entrada1.jpeg",
    imagenes: [
      "/images/entrada1.jpeg",
      "/images/entrada2.jpeg",
    ]
  },
]
---

<section class="port" id="portafolio">
  <div class="port__header">
    <div class="port__header-inner">
      <span class="port__label">Nuestro Trabajo</span>
      <h2 class="port__title">Portafolio de<br /><em>Proyectos</em></h2>
    </div>
    <div class="port__filtros">
      <button class="port__filtro is-active" data-filter="todos">Todos</button>
      <button class="port__filtro" data-filter="RESIDENCIAL">Residencial</button>
      <button class="port__filtro" data-filter="COMERCIAL">Comercial</button>
    </div>
  </div>

  <div class="port__grid" id="portGrid">
    {categorias.map((cat) => (
      <div
        class="port__card"
        data-tipo={cat.tipo}
        data-id={cat.id}
        data-imagenes={JSON.stringify(cat.imagenes)}
        data-label={cat.label}
        data-count={cat.imagenes.length}
      >
        <div class="port__card-img-wrap">
          <img class="port__card-img" src={cat.cover} alt={cat.label} loading="lazy" />
          <div class="port__card-overlay">
            <span class="port__card-ver">Ver proyecto</span>
          </div>
        </div>
        <div class="port__card-info">
          <span class="port__card-tipo">{cat.tipo}</span>
          <span class="port__card-nombre">{cat.label}</span>
          <span class="port__card-count">{cat.imagenes.length} {cat.imagenes.length === 1 ? 'foto' : 'fotos'}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ── LIGHTBOX ── -->
<div class="lb" id="lightbox" aria-hidden="true">

  <!-- Cerrar -->
  <button class="lb__close" id="lbClose" aria-label="Cerrar">
    <span></span><span></span>
  </button>

  <!-- Sidebar: navega entre proyectos de la misma categoría -->
  <aside class="lb__sidebar" id="lbSidebar">
    <button class="lb__proj-btn" id="lbProjPrev" aria-label="Proyecto anterior">
      <svg width="11" height="18" viewBox="0 0 11 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9.5 16.5L2 9L9.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="lb__sidebar-info">
      <span class="lb__sidebar-cat"  id="lbSidebarCat"></span>
      <span class="lb__sidebar-name" id="lbSidebarName"></span>
      <span class="lb__sidebar-idx"  id="lbSidebarIdx"></span>
    </div>

    <button class="lb__proj-btn" id="lbProjNext" aria-label="Proyecto siguiente">
      <svg width="11" height="18" viewBox="0 0 11 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1.5 1.5L9 9L1.5 16.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </aside>

  <!-- Zona principal: scroll vertical por fotos -->
  <div class="lb__main">

    <!-- Contenedor de scroll — este es el único que scrollea -->
    <div class="lb__scroll" id="lbScroll"></div>

    <!-- Contador de foto actual (esquina inf-derecha) -->
    <div class="lb__photo-counter" id="lbPhotoCounter">
      <span id="lbPhotoCurrent">1</span>
      <span class="lb__photo-sep"></span>
      <span id="lbPhotoTotal">1</span>
    </div>

    <!-- Hint scroll (solo cuando hay más de 1 foto) -->
    <div class="lb__hint" id="lbHint">
      <svg width="12" height="18" viewBox="0 0 12 18" fill="none">
        <rect x="1" y="1" width="10" height="14" rx="5" stroke="currentColor" stroke-width="1.2"/>
        <line x1="6" y1="4" x2="6" y2="7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M3 15.5l3 2 3-2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Scroll</span>
    </div>

  </div>
</div>

<style>
  /* ══════════════════════════════════════
     PORTAFOLIO — SECCIÓN
  ══════════════════════════════════════ */
  .port {
    background: #F4F1EA;
    padding: 6rem 0;
  }

  .port__header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .port__header-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .port__label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #A48D78;
  }

  .port__title {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #2C2420;
  }

  .port__title em { font-style: italic; }

  .port__filtros {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .port__filtro {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: 1px solid rgba(44, 36, 32, 0.15);
    color: rgba(44, 36, 32, 0.4);
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .port__filtro:hover,
  .port__filtro.is-active {
    border-color: #A48D78;
    color: #A48D78;
    background: rgba(164, 141, 120, 0.06);
  }

  /* ── GRILLA ── */
  .port__grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 300px;
    gap: 10px;
  }

  .port__card:nth-child(1) { grid-column: span 7; grid-row: span 2; }
  .port__card:nth-child(2) { grid-column: span 5; }
  .port__card:nth-child(3) { grid-column: span 5; }
  .port__card:nth-child(4) { grid-column: span 4; grid-row: span 2; }
  .port__card:nth-child(5) { grid-column: span 4; }
  .port__card:nth-child(6) { grid-column: span 4; }
  .port__card:nth-child(7) { grid-column: span 4; }

  /* ── CARD ── */
  .port__card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: #E6DAC8;
  }

  .port__card-img-wrap {
    position: absolute;
    inset: 0;
  }

  .port__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .port__card:hover .port__card-img { transform: scale(1.06); }

  .port__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 36, 32, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .port__card:hover .port__card-overlay { opacity: 1; }

  .port__card-ver {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FAF9F6;
    border: 1px solid rgba(250,249,246,0.6);
    padding: 0.6rem 1.4rem;
  }

  .port__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.2rem 1.4rem;
    background: linear-gradient(to top, rgba(44,36,32,0.75) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .port__card-tipo {
    font-family: 'Manrope', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #CBB9A4;
  }

  .port__card-nombre {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    color: #FAF9F6;
    line-height: 1.2;
  }

  .port__card-count {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(250,249,246,0.5);
  }

  .port__card.is-hidden { display: none; }

  /* ══════════════════════════════════════
     LIGHTBOX
  ══════════════════════════════════════ */

  /*
    El lightbox es fixed y ocupa todo el viewport.
    El scroll del body se bloquea con JS al abrir.
    SOLO lb__scroll tiene overflow-y: scroll.
  */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #0C0B0A;
    display: flex;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lb.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Botón cerrar ── */
  .lb__close {
    position: fixed;
    top: 1.4rem;
    right: 1.4rem;
    z-index: 20;
    width: 42px;
    height: 42px;
    background: rgba(250,249,246,0.06);
    border: 1px solid rgba(250,249,246,0.12);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s;
  }

  .lb__close:hover { background: rgba(250,249,246,0.14); }

  .lb__close span {
    position: absolute;
    width: 16px;
    height: 1px;
    background: rgba(250,249,246,0.8);
  }

  .lb__close span:first-child { transform: rotate(45deg); }
  .lb__close span:last-child  { transform: rotate(-45deg); }

  /* ── Sidebar izquierdo ── */
  .lb__sidebar {
    width: 76px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    border-right: 1px solid rgba(250,249,246,0.06);
    padding: 2rem 0;
  }

  .lb__proj-btn {
    width: 34px;
    height: 34px;
    background: rgba(250,249,246,0.04);
    border: 1px solid rgba(250,249,246,0.1);
    color: rgba(250,249,246,0.35);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .lb__proj-btn:hover:not(:disabled) {
    background: rgba(250,249,246,0.1);
    color: rgba(250,249,246,0.9);
    border-color: rgba(250,249,246,0.25);
  }

  .lb__proj-btn:disabled {
    opacity: 0.15;
    cursor: default;
  }

  .lb__sidebar-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    overflow: hidden;
  }

  .lb__sidebar-cat {
    font-family: 'Manrope', sans-serif;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(164,141,120,0.65);
    writing-mode: vertical-rl;
  }

  .lb__sidebar-name {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 0.78rem;
    font-style: italic;
    font-weight: 300;
    color: rgba(250,249,246,0.5);
    writing-mode: vertical-rl;
    letter-spacing: 0.03em;
    max-height: 150px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lb__sidebar-idx {
    font-family: 'Manrope', sans-serif;
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    color: rgba(250,249,246,0.18);
    writing-mode: vertical-rl;
  }

  /* ── Área principal ── */
  .lb__main {
    flex: 1;
    position: relative;
    /* Sin overflow aquí — solo lb__scroll scrollea */
    overflow: hidden;
  }

  /* ── Contenedor de scroll ──
     Este es el único elemento con overflow-y scroll.
     Ocupa todo el área principal y snapea por foto.
  */
  .lb__scroll {
    position: absolute;
    inset: 0;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    /* Ocultar scrollbar visual */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .lb__scroll::-webkit-scrollbar { display: none; }

  /* ── Cada slide: exactamente 100vh ── */
  .lb__slide {
    /* Ocupa el 100% de lb__scroll, que es 100% del lb__main, que es 100vh */
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Padding interno para que la imagen no toque los bordes */
    padding: 3rem 3.5rem;
    box-sizing: border-box;
    flex-shrink: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* ── Imagen dentro del slide ──
     max-width/height 100% del slide → nunca se desborda.
     object-fit: contain → mantiene aspecto sin recortar.
  */
  .lb__slide img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .lb__slide img.is-loaded {
    opacity: 1;
  }

  /* ── Contador de foto ── */
  .lb__photo-counter {
    position: absolute;
    bottom: 1.6rem;
    right: 1.8rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: rgba(250,249,246,0.28);
    pointer-events: none;
  }

  .lb__photo-sep {
    display: inline-block;
    width: 18px;
    height: 1px;
    background: rgba(250,249,246,0.18);
  }

  /* ── Hint de scroll ── */
  .lb__hint {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.56rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(250,249,246,0.18);
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .lb__hint.is-hidden {
    opacity: 0;
  }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .port__grid {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 240px;
    }
    .port__card:nth-child(1) { grid-column: span 6; grid-row: span 2; }
    .port__card:nth-child(2) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(3) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(4) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(5) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(6) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(7) { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 768px) {
    .port { padding: 5rem 0 3rem; }

    .port__header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1.5rem;
      margin-bottom: 2rem;
    }
    .port__header-inner { align-items: center; }
    .port__filtros { flex-wrap: wrap; justify-content: center; }

    .port__grid {
      padding: 0 1.5rem;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
      gap: 8px;
    }
    .port__card:nth-child(n) { grid-column: span 1; grid-row: span 1; }
    .port__card:nth-child(1) { grid-column: span 2; }

    /* Mobile: sidebar → barra inferior fija */
    .lb__sidebar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      top: auto;
      width: 100%;
      height: 52px;
      flex-direction: row;
      border-right: none;
      border-top: 1px solid rgba(250,249,246,0.08);
      padding: 0 1.2rem;
      background: rgba(12,11,10,0.96);
      gap: 1rem;
      z-index: 15;
    }

    .lb__sidebar-info {
      flex-direction: row;
      flex: 1;
      max-height: none;
      gap: 0.6rem;
      overflow: hidden;
    }

    .lb__sidebar-cat { display: none; }

    .lb__sidebar-name,
    .lb__sidebar-idx {
      writing-mode: horizontal-tb;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .lb__sidebar-name { font-size: 0.72rem; }
    .lb__sidebar-idx  { font-size: 0.55rem; }

    /* El slide deja espacio para la barra inferior */
    .lb__slide {
      height: calc(100vh - 52px);
      padding: 1rem 1rem;
    }

    .lb__photo-counter { bottom: 4.2rem; }
    .lb__hint { display: none; }
  }

  @media (max-width: 480px) {
    .port__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    .port__card:nth-child(n) { grid-column: span 1; }
    .port__card:nth-child(1) { grid-column: span 1; }
  }
</style>

<script>
  // ══════════════════════════════════════
  // FILTROS
  // ══════════════════════════════════════
  var filtros = document.querySelectorAll('.port__filtro')
  var cards   = document.querySelectorAll('.port__card')

  filtros.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filtros.forEach(function(b) { b.classList.remove('is-active') })
      btn.classList.add('is-active')
      var filter = btn.getAttribute('data-filter')
      cards.forEach(function(card) {
        var tipo = card.getAttribute('data-tipo')
        card.classList.toggle('is-hidden', filter !== 'todos' && tipo !== filter)
      })
    })
  })

  // ══════════════════════════════════════
  // LIGHTBOX
  // ══════════════════════════════════════
  var lb           = document.getElementById('lightbox')
  var lbClose      = document.getElementById('lbClose')
  var lbScroll     = document.getElementById('lbScroll')
  var lbProjPrev   = document.getElementById('lbProjPrev')
  var lbProjNext   = document.getElementById('lbProjNext')
  var lbSidebarCat  = document.getElementById('lbSidebarCat')
  var lbSidebarName = document.getElementById('lbSidebarName')
  var lbSidebarIdx  = document.getElementById('lbSidebarIdx')
  var lbPhotoCurrent = document.getElementById('lbPhotoCurrent')
  var lbPhotoTotal   = document.getElementById('lbPhotoTotal')
  var lbHint         = document.getElementById('lbHint')

  // Estado global
  var siblingProjects = []   // proyectos de la misma categoría (tipo)
  var projIdx = 0            // índice actual dentro de siblingProjects
  var observer = null        // IntersectionObserver para el contador de foto

  // ── Calcular ancho del scrollbar para evitar layout shift ──
  function getScrollbarWidth() {
    return window.innerWidth - document.documentElement.clientWidth
  }

  // ── Construir slides en el contenedor de scroll ──
  function buildSlides(imagenes) {
    if (!lbScroll) return

    // Desconectar observer anterior
    if (observer) { observer.disconnect(); observer = null }

    lbScroll.innerHTML = ''

    imagenes.forEach(function(src) {
      var slide = document.createElement('div')
      slide.className = 'lb__slide'

      var img = document.createElement('img')
      img.alt = ''
      img.decoding = 'async'

      function markLoaded() { img.classList.add('is-loaded') }
      img.addEventListener('load', markLoaded)
      img.addEventListener('error', markLoaded) // mostrar aunque falle
      img.src = src

      // Ya en caché
      if (img.complete) markLoaded()

      slide.appendChild(img)
      lbScroll.appendChild(slide)
    })

    // Resetear scroll al inicio
    lbScroll.scrollTop = 0

    // Actualizar totales
    if (lbPhotoTotal)   lbPhotoTotal.textContent   = imagenes.length
    if (lbPhotoCurrent) lbPhotoCurrent.textContent = 1

    // Hint: mostrar solo si hay más de 1 foto
    if (lbHint) {
      lbHint.classList.toggle('is-hidden', imagenes.length <= 1)
    }

    // Observar slides para actualizar contador
    setupObserver()
  }

  // ── IntersectionObserver: detectar qué foto es visible ──
  function setupObserver() {
    var slides = lbScroll.querySelectorAll('.lb__slide')
    if (!slides.length) return

    observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return
        var idx = Array.prototype.indexOf.call(slides, entry.target)
        if (lbPhotoCurrent) lbPhotoCurrent.textContent = idx + 1
        // Ocultar hint después del primer scroll
        if (idx > 0 && lbHint) lbHint.classList.add('is-hidden')
      })
    }, {
      root: lbScroll,
      threshold: 0.5
    })

    slides.forEach(function(slide) { observer.observe(slide) })
  }

  // ── Actualizar sidebar con los datos del proyecto actual ──
  function updateSidebar() {
    var proj = siblingProjects[projIdx]
    if (!proj) return

    if (lbSidebarCat)  lbSidebarCat.textContent  = proj.tipo
    if (lbSidebarName) lbSidebarName.textContent = proj.label
    if (lbSidebarIdx)  lbSidebarIdx.textContent  = (projIdx + 1) + ' / ' + siblingProjects.length

    // Estado de botones: deshabilitar en los extremos
    if (lbProjPrev) lbProjPrev.disabled = (projIdx === 0)
    if (lbProjNext) lbProjNext.disabled = (projIdx === siblingProjects.length - 1)

    buildSlides(proj.imagenes)
  }

  // ── Abrir lightbox ──
  function openLightbox(clickedCard) {
    var clickedTipo  = clickedCard.getAttribute('data-tipo')
    var clickedLabel = clickedCard.getAttribute('data-label')

    // Recopilar proyectos visibles de la MISMA categoría (tipo)
    siblingProjects = []
    cards.forEach(function(card) {
      if (card.classList.contains('is-hidden')) return
      if (card.getAttribute('data-tipo') !== clickedTipo) return
      siblingProjects.push({
        label:    card.getAttribute('data-label')    || '',
        tipo:     card.getAttribute('data-tipo')     || '',
        imagenes: JSON.parse(card.getAttribute('data-imagenes') || '[]')
      })
    })

    // Encontrar índice del proyecto clickeado
    projIdx = siblingProjects.findIndex(function(p) {
      return p.label === clickedLabel
    })
    if (projIdx < 0) projIdx = 0

    updateSidebar()

    // Abrir el lightbox
    lb.classList.add('is-open')
    lb.setAttribute('aria-hidden', 'false')

    // Bloquear scroll del body SIN layout shift
    var sbw = getScrollbarWidth()
    document.body.style.overflow     = 'hidden'
    document.body.style.paddingRight = sbw + 'px'
  }

  // ── Cerrar lightbox ──
  function closeLightbox() {
    lb.classList.remove('is-open')
    lb.setAttribute('aria-hidden', 'true')

    // Restaurar scroll del body
    document.body.style.overflow     = ''
    document.body.style.paddingRight = ''

    // Limpiar DOM tras la transición
    setTimeout(function() {
      if (observer) { observer.disconnect(); observer = null }
      if (lbScroll) lbScroll.innerHTML = ''
    }, 420)
  }

  // ── Navegar entre proyectos de la misma categoría ──
  function goPrevProj() {
    if (projIdx <= 0) return
    projIdx--
    updateSidebar()
  }

  function goNextProj() {
    if (projIdx >= siblingProjects.length - 1) return
    projIdx++
    updateSidebar()
  }

  // ── Eventos: cards ──
  cards.forEach(function(card) {
    card.addEventListener('click', function() {
      openLightbox(card)
    })
  })

  // ── Eventos: controles del lightbox ──
  lbClose.addEventListener('click', closeLightbox)
  lbProjPrev.addEventListener('click', goPrevProj)
  lbProjNext.addEventListener('click', goNextProj)

  // Cerrar al hacer clic en el fondo negro (no en el contenido)
  lb.addEventListener('click', function(e) {
    if (e.target === lb) closeLightbox()
  })

  // ── Teclado ──
  document.addEventListener('keydown', function(e) {
    if (!lb.classList.contains('is-open')) return
    if (e.key === 'Escape')     closeLightbox()
    if (e.key === 'ArrowLeft')  goPrevProj()
    if (e.key === 'ArrowRight') goNextProj()
  })

  // ── Swipe horizontal en mobile → cambiar proyecto ──
  //    Swipe vertical → scroll nativo de lb__scroll (no lo interceptamos)
  var touchX0 = 0
  var touchY0 = 0

  lb.addEventListener('touchstart', function(e) {
    touchX0 = e.touches[0].clientX
    touchY0 = e.touches[0].clientY
  }, { passive: true })

  lb.addEventListener('touchend', function(e) {
    var dx = touchX0 - e.changedTouches[0].clientX
    var dy = touchY0 - e.changedTouches[0].clientY
    // Solo swipe horizontal dominante
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 55) {
      if (dx > 0) goNextProj()
      else        goPrevProj()
    }
  }, { passive: true })
</script>