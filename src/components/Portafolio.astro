---
const categorias = [
  {
    id: "sala",
    label: "Sala de Estar",
    tipo: "RESIDENCIAL",
    cover: "/images/sala1.jpeg",
    imagenes: [
      "/images/sala1.jpeg",
      "/images/sala2.jpeg",
      "/images/sala3.jpeg",
      "/images/sala4.jpeg",
      "/images/sala5.jpeg",
      "/images/sala6.jpeg",
      "/images/sala7.jpeg",
      "/images/sala8.jpeg",
    ]
  },
  {
    id: "comedor",
    label: "Comedor",
    tipo: "RESIDENCIAL",
    cover: "/images/comedor1.jpeg",
    imagenes: [
      "/images/comedor1.jpeg",
      "/images/comedor2.jpeg",
      "/images/comedor3.jpeg",
    ]
  },
  {
    id: "cocina",
    label: "Cocina",
    tipo: "RESIDENCIAL",
    cover: "/images/cocina1.PNG",
    imagenes: [
      "/images/cocina1.PNG",
      "/images/cocina2.jpeg",
      "/images/cocina3.jpeg",
      "/images/cocina4.jpeg",
      "/images/cocina5.jpeg",
    ]
  },
  {
    id: "bano",
    label: "Baño de Diseño",
    tipo: "RESIDENCIAL",
    cover: "/images/baño1.jpeg",
    imagenes: [
      "/images/baño1.jpeg",
      "/images/baño2.jpeg",
    ]
  },
  {
    id: "oficina",
    label: "Oficina Ejecutiva",
    tipo: "COMERCIAL",
    cover: "/images/oficina1.png",
    imagenes: [
      "/images/oficina1.png",
      "/images/oficina2.png",
    ]
  },
  {
    id: "ninos",
    label: "Espacio Niños",
    tipo: "RESIDENCIAL",
    cover: "/images/niño1.jpeg",
    imagenes: [
      "/images/niño1.jpeg",
      "/images/niño2.jpeg",
      "/images/niño3.jpeg",
      "/images/niña1.jpeg",
      "/images/niña2.PNG",
      "/images/niña3.jpeg",
      "/images/niña4.jpeg",
      "/images/niña5.jpeg",
      "/images/niña6.jpeg",
      "/images/niña7.jpeg",
      "/images/niña8.jpeg",
      "/images/niña9.jpeg",
    ]
  },
  {
    id: "entrada",
    label: "Entrada",
    tipo: "RESIDENCIAL",
    cover: "/images/entrada1.jpeg",
    imagenes: [
      "/images/entrada1.jpeg",
      "/images/entrada2.jpeg",
    ]
  },
]
---

<section class="port" id="portafolio">
  <div class="port__header">
    <div class="port__header-inner">
      <span class="port__label">Nuestro Trabajo</span>
      <h2 class="port__title">Portafolio de<br /><em>Proyectos</em></h2>
    </div>
    <div class="port__filtros">
      <button class="port__filtro is-active" data-filter="todos">Todos</button>
      <button class="port__filtro" data-filter="RESIDENCIAL">Residencial</button>
      <button class="port__filtro" data-filter="COMERCIAL">Comercial</button>
    </div>
  </div>

  <div class="port__grid" id="portGrid">
    {categorias.map((cat) => (
      <div
        class="port__card"
        data-tipo={cat.tipo}
        data-id={cat.id}
        data-imagenes={JSON.stringify(cat.imagenes)}
        data-label={cat.label}
        data-count={cat.imagenes.length}
      >
        <div class="port__card-img-wrap">
          <!--
            CLAVE — mismo patrón que Esencia y Servicios:
            opacity: 0 y scale en CSS desde el inicio.
            JS agrega .is-visible cuando entra al viewport.
          -->
          <img
            class="port__card-img"
            src={cat.cover}
            alt={cat.label}
            loading="lazy"
          />
          <div class="port__card-overlay">
            <span class="port__card-ver">Ver proyecto</span>
          </div>
        </div>
        <div class="port__card-info">
          <span class="port__card-tipo">{cat.tipo}</span>
          <span class="port__card-nombre">{cat.label}</span>
          <span class="port__card-count">{cat.imagenes.length} {cat.imagenes.length === 1 ? 'foto' : 'fotos'}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ── LIGHTBOX ── -->
<div class="lb" id="lightbox" aria-hidden="true">

  <button class="lb__close" id="lbClose" aria-label="Cerrar">
    <span></span><span></span>
  </button>

  <button class="lb__arrow lb__arrow--prev" id="lbPrev" aria-label="Foto anterior">
    <svg width="10" height="18" viewBox="0 0 10 18" fill="none">
      <path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="lb__stage" id="lbStage">
    <div class="lb__img-wrap" id="lbImgWrap">
      <img class="lb__img" id="lbImg" src="" alt="" />
    </div>
  </div>

  <button class="lb__arrow lb__arrow--next" id="lbNext" aria-label="Foto siguiente">
    <svg width="10" height="18" viewBox="0 0 10 18" fill="none">
      <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="lb__bar">
    <div class="lb__bar-left">
      <span class="lb__bar-tipo" id="lbBarTipo"></span>
      <span class="lb__bar-name" id="lbBarName"></span>
    </div>
    <div class="lb__bar-center" id="lbDots"></div>
    <div class="lb__bar-right">
      <span class="lb__bar-counter">
        <span id="lbCurrent">1</span>
        <span class="lb__bar-sep"></span>
        <span id="lbTotal">1</span>
      </span>
    </div>
  </div>

</div>

<style>
  /* ══════════════════════════════════════
     PORTAFOLIO — SECCIÓN
  ══════════════════════════════════════ */
  .port {
    background: #F4F1EA;
    padding: 6rem 0;
  }

  .port__header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .port__header-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .port__label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #A48D78;
  }

  .port__title {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #2C2420;
  }

  .port__title em { font-style: italic; }

  .port__filtros {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .port__filtro {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: 1px solid rgba(44, 36, 32, 0.15);
    color: rgba(44, 36, 32, 0.4);
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .port__filtro:hover,
  .port__filtro.is-active {
    border-color: #A48D78;
    color: #A48D78;
    background: rgba(164, 141, 120, 0.06);
  }

  /* ── GRILLA ── */
  .port__grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 300px;
    gap: 10px;
  }

  .port__card:nth-child(1) { grid-column: span 7; grid-row: span 2; }
  .port__card:nth-child(2) { grid-column: span 5; }
  .port__card:nth-child(3) { grid-column: span 5; }
  .port__card:nth-child(4) { grid-column: span 4; grid-row: span 2; }
  .port__card:nth-child(5) { grid-column: span 4; }
  .port__card:nth-child(6) { grid-column: span 4; }
  .port__card:nth-child(7) { grid-column: span 4; }

  /* ── CARD ── */
  .port__card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: #E6DAC8;
  }

  .port__card-img-wrap {
    position: absolute;
    inset: 0;
  }

  /*
    CLAVE — mismo patrón que Esencia y Servicios:
    La imagen arranca invisible vía CSS.
    JS sólo agrega .is-visible cuando entra al viewport.
    Nunca hay un flash de imagen visible antes de que JS corra.
  */
  .port__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transform: scale(1.06);
    transition:
      opacity 1.6s ease,
      transform 2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .port__card-img.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  /* El hover de zoom sigue funcionando sobre el scale base */
  .port__card:hover .port__card-img {
    transform: scale(1.06);
  }

  .port__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 36, 32, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .port__card:hover .port__card-overlay { opacity: 1; }

  .port__card-ver {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FAF9F6;
    border: 1px solid rgba(250,249,246,0.6);
    padding: 0.6rem 1.4rem;
  }

  .port__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.2rem 1.4rem;
    background: linear-gradient(to top, rgba(44,36,32,0.75) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .port__card-tipo {
    font-family: 'Manrope', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #CBB9A4;
  }

  .port__card-nombre {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    color: #FAF9F6;
    line-height: 1.2;
  }

  .port__card-count {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(250,249,246,0.5);
  }

  .port__card.is-hidden { display: none; }

  /* ══════════════════════════════════════
     LIGHTBOX
  ══════════════════════════════════════ */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #0C0B0A;
    display: grid;
    grid-template-columns: 72px 1fr 72px;
    grid-template-rows: 1fr 64px;
    grid-template-areas:
      "prev stage next"
      "bar  bar   bar";
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lb.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .lb__close {
    position: fixed;
    top: 1.2rem;
    right: 1.2rem;
    z-index: 20;
    width: 40px;
    height: 40px;
    background: rgba(250,249,246,0.06);
    border: 1px solid rgba(250,249,246,0.12);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s;
  }

  .lb__close:hover { background: rgba(250,249,246,0.14); }

  .lb__close span {
    position: absolute;
    width: 15px;
    height: 1px;
    background: rgba(250,249,246,0.8);
  }

  .lb__close span:first-child { transform: rotate(45deg); }
  .lb__close span:last-child  { transform: rotate(-45deg); }

  .lb__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(250,249,246,0.3);
    transition: color 0.2s ease, background 0.2s ease;
    z-index: 10;
  }

  .lb__arrow--prev { grid-area: prev; }
  .lb__arrow--next { grid-area: next; }

  .lb__arrow:hover:not(:disabled) {
    color: rgba(250,249,246,0.9);
    background: rgba(250,249,246,0.04);
  }

  .lb__arrow:disabled {
    opacity: 0.1;
    cursor: default;
  }

  .lb__stage {
    grid-area: stage;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb__img-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: pinch-zoom pan-x pan-y;
    overflow: hidden;
  }

  .lb__img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    user-select: none;
    -webkit-user-drag: none;
  }

  .lb__img.is-loaded { opacity: 1; }

  .lb__img.slide-in-right {
    animation: slideInRight 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  .lb__img.slide-in-left {
    animation: slideInLeft 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .lb__bar {
    grid-area: bar;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    border-top: 1px solid rgba(250,249,246,0.06);
    background: rgba(12,11,10,0.95);
    gap: 1rem;
  }

  .lb__bar-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }

  .lb__bar-tipo {
    font-family: 'Manrope', sans-serif;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(164,141,120,0.65);
  }

  .lb__bar-name {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 0.85rem;
    font-style: italic;
    font-weight: 300;
    color: rgba(250,249,246,0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lb__bar-center {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .lb__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(250,249,246,0.18);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, transform 0.25s ease;
    flex-shrink: 0;
  }

  .lb__dot.is-active {
    background: rgba(250,249,246,0.75);
    transform: scale(1.4);
  }

  .lb__dot:hover:not(.is-active) {
    background: rgba(250,249,246,0.4);
  }

  .lb__bar-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .lb__bar-counter {
    font-family: 'Manrope', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(250,249,246,0.28);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .lb__bar-sep {
    display: inline-block;
    width: 16px;
    height: 1px;
    background: rgba(250,249,246,0.18);
  }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .port__grid {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 240px;
    }
    .port__card:nth-child(1) { grid-column: span 6; grid-row: span 2; }
    .port__card:nth-child(2) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(3) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(4) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(5) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(6) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(7) { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 768px) {
    .port { padding: 5rem 0 3rem; }

    .port__header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1.5rem;
      margin-bottom: 2rem;
    }
    .port__header-inner { align-items: center; }
    .port__filtros { flex-wrap: wrap; justify-content: center; }

    .port__grid {
      padding: 0 1.5rem;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
      gap: 8px;
    }
    .port__card:nth-child(n) { grid-column: span 1; grid-row: span 1; }
    .port__card:nth-child(1) { grid-column: span 2; }

    .lb {
      grid-template-columns: 52px 1fr 52px;
      grid-template-rows: 1fr 72px;
    }

    .lb__bar { padding: 0 1rem; }
    .lb__bar-name { font-size: 0.8rem; }
    .lb__dot { width: 4px; height: 4px; }
  }

  @media (max-width: 480px) {
    .port__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    .port__card:nth-child(n) { grid-column: span 1; }
    .port__card:nth-child(1) { grid-column: span 1; }

    .lb {
      grid-template-columns: 44px 1fr 44px;
      grid-template-rows: 1fr 68px;
    }
  }
</style>

<script>
  // ══════════════════════════════════════
  // CARGA FLUIDA — mismo patrón que Esencia y Servicios
  // CSS pone opacity: 0 desde el inicio.
  // IntersectionObserver agrega .is-visible cuando la card entra al viewport.
  // Cada imagen tiene un delay escalonado según su posición en la grilla
  // para un efecto en cascada natural.
  // ══════════════════════════════════════

  var cardImgs = document.querySelectorAll('.port__card-img')

  var imgObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var img = entry.target
        // Delay escalonado: cada imagen espera un poco más que la anterior
        // según su índice dentro de la grilla, para un efecto en cascada
        var card  = img.closest('.port__card')
        var cards = Array.from(document.querySelectorAll('.port__card:not(.is-hidden)'))
        var idx   = cards.indexOf(card)
        var delay = Math.min(idx * 80, 400) // máximo 400ms de delay

        setTimeout(function() {
          img.classList.add('is-visible')
        }, delay)

        imgObserver.unobserve(img)
      }
    })
  }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' })

  cardImgs.forEach(function(img) {
    imgObserver.observe(img)
  })

  // ══════════════════════════════════════
  // FILTROS
  // Cuando se filtra, re-observar las imágenes que vuelven a aparecer
  // ══════════════════════════════════════
  var filtros = document.querySelectorAll('.port__filtro')
  var cards   = document.querySelectorAll('.port__card')

  filtros.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filtros.forEach(function(b) { b.classList.remove('is-active') })
      btn.classList.add('is-active')
      var filter = btn.getAttribute('data-filter')

      cards.forEach(function(card) {
        var tipo = card.getAttribute('data-tipo')
        var hide = filter !== 'todos' && tipo !== filter
        card.classList.toggle('is-hidden', hide)

        // Si la card vuelve a mostrarse y su imagen aún no fue animada,
        // re-observarla para que aparezca fluida
        if (!hide) {
          var img = card.querySelector('.port__card-img')
          if (img && !img.classList.contains('is-visible')) {
            imgObserver.observe(img)
          }
        }
      })
    })
  })

  // ══════════════════════════════════════
  // LIGHTBOX
  // ══════════════════════════════════════
  var lb         = document.getElementById('lightbox')
  var lbClose    = document.getElementById('lbClose')
  var lbPrev     = document.getElementById('lbPrev')
  var lbNext     = document.getElementById('lbNext')
  var lbImg      = document.getElementById('lbImg')
  var lbImgWrap  = document.getElementById('lbImgWrap')
  var lbBarTipo  = document.getElementById('lbBarTipo')
  var lbBarName  = document.getElementById('lbBarName')
  var lbDots     = document.getElementById('lbDots')
  var lbCurrent  = document.getElementById('lbCurrent')
  var lbTotal    = document.getElementById('lbTotal')

  var imagenes    = []
  var photoIdx    = 0
  var isAnimating = false

  function getScrollbarWidth() {
    return window.innerWidth - document.documentElement.clientWidth
  }

  function buildDots(total) {
    lbDots.innerHTML = ''
    var max = Math.min(total, 12)
    for (var i = 0; i < max; i++) {
      var dot = document.createElement('button')
      dot.className = 'lb__dot'
      dot.setAttribute('aria-label', 'Foto ' + (i + 1));
      (function(idx) {
        dot.addEventListener('click', function() { goTo(idx, idx > photoIdx ? 'right' : 'left') })
      })(i)
      lbDots.appendChild(dot)
    }
  }

  function updateDots() {
    var dots = lbDots.querySelectorAll('.lb__dot')
    dots.forEach(function(d, i) { d.classList.toggle('is-active', i === photoIdx) })
  }

  function goTo(idx, direction) {
    if (isAnimating) return
    if (idx < 0 || idx >= imagenes.length) return

    isAnimating = true
    photoIdx = idx

    lbImg.classList.remove('slide-in-right', 'slide-in-left', 'is-loaded')

    requestAnimationFrame(function() {
      lbImg.src = imagenes[photoIdx]

      var animClass = direction === 'right' ? 'slide-in-right' : 'slide-in-left'
      lbImg.classList.add(animClass)

      function onLoad() {
        lbImg.classList.add('is-loaded')
        isAnimating = false
      }

      if (lbImg.complete && lbImg.naturalWidth > 0) {
        onLoad()
      } else {
        lbImg.onload  = onLoad
        lbImg.onerror = function() { isAnimating = false }
      }
    })

    if (lbCurrent) lbCurrent.textContent = photoIdx + 1
    updateDots()
    lbPrev.disabled = (photoIdx === 0)
    lbNext.disabled = (photoIdx === imagenes.length - 1)
  }

  function openLightbox(card) {
    imagenes = JSON.parse(card.getAttribute('data-imagenes') || '[]')
    var label = card.getAttribute('data-label') || ''
    var tipo  = card.getAttribute('data-tipo')  || ''

    photoIdx = 0

    if (lbBarTipo) lbBarTipo.textContent = tipo
    if (lbBarName) lbBarName.textContent = label
    if (lbTotal)   lbTotal.textContent   = imagenes.length

    buildDots(imagenes.length)

    lb.classList.add('is-open')
    lb.setAttribute('aria-hidden', 'false')

    var sbw = getScrollbarWidth()
    document.body.style.overflow     = 'hidden'
    document.body.style.paddingRight = sbw + 'px'

    goTo(0, 'right')
  }

  function closeLightbox() {
    lb.classList.remove('is-open')
    lb.setAttribute('aria-hidden', 'true')
    document.body.style.overflow     = ''
    document.body.style.paddingRight = ''

    setTimeout(function() {
      lbImg.src = ''
      lbImg.classList.remove('is-loaded', 'slide-in-right', 'slide-in-left')
      lbDots.innerHTML = ''
      imagenes = []
      photoIdx = 0
    }, 420)
  }

  cards.forEach(function(card) {
    card.addEventListener('click', function() { openLightbox(card) })
  })

  lbPrev.addEventListener('click', function() {
    if (photoIdx > 0) goTo(photoIdx - 1, 'left')
  })

  lbNext.addEventListener('click', function() {
    if (photoIdx < imagenes.length - 1) goTo(photoIdx + 1, 'right')
  })

  lbClose.addEventListener('click', closeLightbox)

  document.addEventListener('keydown', function(e) {
    if (!lb.classList.contains('is-open')) return
    if (e.key === 'Escape')     closeLightbox()
    if (e.key === 'ArrowLeft')  { if (photoIdx > 0) goTo(photoIdx - 1, 'left') }
    if (e.key === 'ArrowRight') { if (photoIdx < imagenes.length - 1) goTo(photoIdx + 1, 'right') }
  })

  var touchX0    = 0
  var touchY0    = 0
  var touchMoved = false

  lbImgWrap.addEventListener('touchstart', function(e) {
    touchX0    = e.touches[0].clientX
    touchY0    = e.touches[0].clientY
    touchMoved = false
  }, { passive: true })

  lbImgWrap.addEventListener('touchmove', function() {
    touchMoved = true
  }, { passive: true })

  lbImgWrap.addEventListener('touchend', function(e) {
    var dx = touchX0 - e.changedTouches[0].clientX
    var dy = touchY0 - e.changedTouches[0].clientY

    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
      if (dx > 0 && photoIdx < imagenes.length - 1) goTo(photoIdx + 1, 'right')
      if (dx < 0 && photoIdx > 0)                   goTo(photoIdx - 1, 'left')
    }
  }, { passive: true })
</script>