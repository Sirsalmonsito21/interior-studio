---

<section class="prt" id="portafolio">
  <div class="prt__header-container">
    <header class="prt__header">
      <div class="prt__mask">
        <h2 class="prt__heading">NUESTROS <em>PROYECTOS</em></h2>
      </div>
      
      <nav class="prt__nav">
        <button class="prt__cat-btn is-active" data-filter="all">TODOS</button>
        <button class="prt__cat-btn" data-filter="ninos">INFANTIL / KIDS</button>
        <button class="prt__cat-btn" data-filter="residencial">RESIDENCIAL</button>
        <button class="prt__cat-btn" data-filter="comercial">COMERCIAL</button>
      </nav>
    </header>
  </div>

  <div class="prt__grid" id="prtGrid">
    {categorias.map(cat => (
      <div class="prt__item" data-filtro={cat.filtro} data-imagenes={JSON.stringify(cat.imagenes)} data-label={cat.label}>
        <div class="prt__card">
          <div class="prt__img-wrapper">
            <img src={cat.cover} alt={cat.label} class="prt__img" loading="lazy" />
            <div class="prt__overlay">
              <span class="prt__view-btn">EXPLORAR CATÁLOGO</span>
            </div>
          </div>
          <div class="prt__info">
            <span class="prt__project-type">{cat.tipo}</span>
            <h3 class="prt__project-label">{cat.label}</h3>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="prt__lb" id="prtLightbox">
    <div class="prt__lb-controls">
        <button class="prt__lb-close" aria-label="Cerrar">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M18 6L6 18M6 6l12 12"></path>
          </svg>
        </button>
        <div class="prt__lb-title-box">
            <h4 id="lbProjectTitle">PROYECTO</h4>
            <span>Desliza para ver más</span>
        </div>
    </div>

    <div class="prt__lb-content" id="lbScrollArea" data-lenis-prevent>
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap');

  .prt { background: #f5f2ee; padding: 6rem 0 0; color: #0a0a08; overflow: hidden; }
  
  .prt__header-container { max-width: 1400px; margin: 0 auto; padding: 0 5vw; }

  .prt__header { margin-bottom: 4rem; text-align: center; }
  .prt__mask { overflow: hidden; } 
  
  .prt__heading { 
    font-family: 'Playfair Display', serif; 
    font-size: clamp(3.5rem, 10vw, 8rem); 
    font-weight: 500; 
    color: #0a0a08;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
    line-height: 1;
  }

  /* La palabra en cursiva toma el color acento */
  .prt__heading em {
    font-style: italic;
    color: #a07846;
  }

  .prt__nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.8rem; margin-bottom: 2rem; }
  .prt__cat-btn {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.15);
    color: #0a0a08;
    padding: 0.8rem 1.8rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 50px;
    letter-spacing: 0.05em;
  }

  /* Hover: acento cálido en lugar de negro */
  .prt__cat-btn:hover {
    background: rgba(160, 120, 70, 0.08);
    color: #a07846;
    border-color: rgba(160, 120, 70, 0.4);
  }

  /* Activo: fondo acento sólido */
  .prt__cat-btn.is-active {
    background: #a07846;
    color: #fff;
    border-color: #a07846;
  }

  .prt__grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    width: 100%;
    gap: 2px; 
    background: #f5f2ee;
  }

  @media (max-width: 1024px) { .prt__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .prt__grid { grid-template-columns: 1fr; } }

  .prt__item { cursor: pointer; position: relative; }
  .prt__img-wrapper { position: relative; aspect-ratio: 1/1; overflow: hidden; }
  .prt__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  
  .prt__item:hover .prt__img { transform: scale(1.05); }

  /* Capa base permanente para legibilidad del título */
  .prt__img-wrapper::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 55%;
    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.18) 60%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .prt__overlay { 
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
    background: rgba(0,0,0,0.3);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.4s ease;
    z-index: 2;
  }
  .prt__item:hover .prt__overlay { opacity: 1; }

  /* Botón explorar con acento al hover */
  .prt__view-btn { 
    background: #fff;
    color: #000;
    padding: 14px 28px;
    font-size: 0.75rem; 
    font-weight: 700;
    letter-spacing: 0.15em;
    border-radius: 2px;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .prt__item:hover .prt__view-btn:hover {
    background: #a07846;
    color: #fff;
  }

  .prt__info { 
    position: absolute; bottom: 30px; left: 30px; z-index: 3;
    pointer-events: none; transition: transform 0.4s ease;
  }
  .prt__item:hover .prt__info { transform: translateY(-10px); }
  
  .prt__project-type { 
    font-size: 0.7rem;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.2rem;
  }
  .prt__project-label { 
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem; 
    font-weight: 400;
    color: #fff;
    line-height: 1.1;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }

  /* =============================================
     LIGHTBOX
     ============================================= */

  .prt__lb {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #0a0a08;
    z-index: 9999;
    display: none;
    overflow: hidden;
  }
  .prt__lb.is-open { display: block; }

  .prt__lb-controls {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 4vw;
    z-index: 100;
    background: linear-gradient(to bottom, rgba(10,10,8,0.9), transparent);
    pointer-events: none;
    box-sizing: border-box;
  }
  .prt__lb-close {
    background: transparent; color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
    width: 50px; height: 50px; border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    pointer-events: auto;
    transition: all 0.3s;
    flex-shrink: 0;
  }
  .prt__lb-close:hover { background: #a07846; border-color: #a07846; color: #fff; }

  .prt__lb-title-box { text-align: right; color: #fff; }
  .prt__lb-title-box h4 { font-family: 'Playfair Display', serif; font-size: 2rem; margin: 0; font-weight: 400; color: #a07846; }
  .prt__lb-title-box span { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.7; font-weight: 600; }

  .prt__lb-content {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    box-sizing: border-box;
  }

  .prt__lb-img-wrapper {
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 110px 6vw 40px;
    box-sizing: border-box;
    overflow: hidden;
  }

  .prt__lb-img {
    display: block;
    max-width: 100%;
    max-height: 85vh;
    width: auto;
    height: auto;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .prt__lb-img-wrapper { padding: 100px 4vw 30px; }
    .prt__lb-img { max-height: 82vh; }
  }

  @media (max-width: 480px) {
    .prt__lb-img-wrapper { padding: 90px 3vw 20px; }
    .prt__lb-img { max-height: 80vh; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initPortafolio() {
    gsap.fromTo('.prt__heading', 
      { y: 80, opacity: 0 },
      { y: 0, opacity: 1, duration: 1.2, ease: 'power3.out', scrollTrigger: { trigger: '.prt__header-container', start: 'top 85%' } }
    );

    gsap.fromTo('.prt__cat-btn', 
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, stagger: 0.1, ease: 'power3.out', scrollTrigger: { trigger: '.prt__header-container', start: 'top 85%' } }
    );

    gsap.fromTo('.prt__item', 
      { y: 60, opacity: 0 },
      { y: 0, opacity: 1, duration: 1.2, stagger: 0.15, ease: 'power3.out', scrollTrigger: { trigger: '#prtGrid', start: 'top 80%' } }
    );

    const items = document.querySelectorAll('.prt__item');
    const btns = document.querySelectorAll('.prt__cat-btn');
    const lb = document.getElementById('prtLightbox');
    const lbScrollArea = document.getElementById('lbScrollArea');
    const lbTitle = document.getElementById('lbProjectTitle');
    const lbClose = document.querySelector('.prt__lb-close');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        
        const filter = btn.getAttribute('data-filter');
        
        items.forEach(item => {
          if (filter === 'all' || item.getAttribute('data-filtro') === filter) {
            (item as HTMLElement).style.display = 'block';
            gsap.fromTo(item, { opacity: 0, scale: 0.95 }, { opacity: 1, scale: 1, duration: 0.4, ease: "power2.out" });
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
        ScrollTrigger.refresh();
      });
    });

    if (!lb || !lbScrollArea || !lbTitle || !lbClose) return;

    function openCatalog(item) {
      const imagenes = JSON.parse(item.getAttribute('data-imagenes') || '[]');
      const label = item.getAttribute('data-label') || '';

      (lbTitle as HTMLElement).innerText = label.toUpperCase();
      lbScrollArea!.innerHTML = '';

      imagenes.forEach((src) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'prt__lb-img-wrapper';
        const img = document.createElement('img');
        img.src = src;
        img.className = 'prt__lb-img';
        img.alt = 'Proyecto Studio2810';
        img.loading = 'lazy';
        wrapper.appendChild(img);
        lbScrollArea!.appendChild(wrapper);
      });

      lb!.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      lbScrollArea!.scrollTop = 0;
    }

    function closeLb() {
      lb!.classList.remove('is-open');
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
    }

    items.forEach(item => {
      item.addEventListener('click', () => openCatalog(item));
    });

    lbClose.addEventListener('click', closeLb);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLb(); });
  }

  initPortafolio();
  document.addEventListener('astro:after-swap', initPortafolio);
</script>