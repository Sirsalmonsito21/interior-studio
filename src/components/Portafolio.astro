---
const categorias = [
  {
    id: "sala",
    label: "Sala de Estar",
    tipo: "RESIDENCIAL",
    cover: "/images/sala1.jpeg",
    imagenes: [
      "/images/sala1.jpeg",
      "/images/sala2.jpeg",
      "/images/sala3.jpeg",
      "/images/sala4.jpeg",
      "/images/sala5.jpeg",
      "/images/sala6.jpeg",
      "/images/sala7.jpeg",
      "/images/sala8.jpeg",
    ]
  },
  {
    id: "comedor",
    label: "Comedor",
    tipo: "RESIDENCIAL",
    cover: "/images/comedor1.jpeg",
    imagenes: [
      "/images/comedor1.jpeg",
      "/images/comedor2.jpeg",
      "/images/comedor3.jpeg",
    ]
  },
  {
    id: "cocina",
    label: "Cocina",
    tipo: "RESIDENCIAL",
    cover: "/images/cocina1.PNG",
    imagenes: [
      "/images/cocina1.PNG",
      "/images/cocina2.jpeg",
      "/images/cocina3.jpeg",
      "/images/cocina4.jpeg",
      "/images/cocina5.jpeg",
    ]
  },
  {
    id: "bano",
    label: "Baño de Diseño",
    tipo: "RESIDENCIAL",
    cover: "/images/baño1.jpeg",
    imagenes: [
      "/images/baño1.jpeg",
      "/images/baño2.jpeg",
    ]
  },
  {
    id: "oficina",
    label: "Oficina Ejecutiva",
    tipo: "COMERCIAL",
    cover: "/images/oficina1.png",
    imagenes: [
      "/images/oficina1.png",
      "/images/oficina2.png",
    ]
  },
  {
    id: "ninos",
    label: "Espacio Niños",
    tipo: "RESIDENCIAL",
    cover: "/images/niño1.jpeg",
    imagenes: [
      "/images/niño1.jpeg",
      "/images/niño2.jpeg",
      "/images/niño3.jpeg",
      "/images/niña1.jpeg",
      "/images/niña2.PNG",
      "/images/niña3.jpeg",
      "/images/niña4.jpeg",
      "/images/niña5.jpeg",
      "/images/niña6.jpeg",
      "/images/niña7.jpeg",
      "/images/niña8.jpeg",
      "/images/niña9.jpeg",
    ]
  },
  {
    id: "entrada",
    label: "Entrada",
    tipo: "RESIDENCIAL",
    cover: "/images/entrada1.jpeg",
    imagenes: [
      "/images/entrada1.jpeg",
      "/images/entrada2.jpeg",
    ]
  },
]
---

<section class="port" id="portafolio">
  <div class="port__header">
    <div class="port__header-inner">
      <span class="port__label">Nuestro Trabajo</span>
      <h2 class="port__title">Portafolio de<br /><em>Proyectos</em></h2>
    </div>
    <div class="port__filtros">
      <button class="port__filtro is-active" data-filter="todos">Todos</button>
      <button class="port__filtro" data-filter="RESIDENCIAL">Residencial</button>
      <button class="port__filtro" data-filter="COMERCIAL">Comercial</button>
    </div>
  </div>

  <div class="port__grid" id="portGrid">
    {categorias.map((cat, i) => (
      <div
        class="port__card"
        data-tipo={cat.tipo}
        data-id={cat.id}
        data-imagenes={JSON.stringify(cat.imagenes)}
        data-label={cat.label}
      >
        <div class="port__card-img-wrap">
          <img class="port__card-img" src={cat.cover} alt={cat.label} loading="lazy" />
          <div class="port__card-overlay">
            <span class="port__card-ver">Ver proyecto</span>
          </div>
        </div>
        <div class="port__card-info">
          <span class="port__card-tipo">{cat.tipo}</span>
          <span class="port__card-nombre">{cat.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Lightbox fullscreen inmersivo -->
<div class="lb" id="lightbox">
  <button class="lb__close" id="lbClose"><span></span><span></span></button>
  <div class="lb__info" id="lbInfo">
    <span class="lb__label" id="lbLabel"></span>
    <span class="lb__counter" id="lbCounter"></span>
  </div>
  <div class="lb__track" id="lbTrack"></div>
  <button class="lb__arrow lb__arrow--prev" id="lbPrev">&#8592;</button>
  <button class="lb__arrow lb__arrow--next" id="lbNext">&#8594;</button>
</div>

<style>
  /* ── SECCIÓN ── */
  .port {
    background: #FAF9F6;
    padding: 6rem 0;
  }

  .port__header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .port__header-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .port__label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #CBB9A4;
  }

  .port__title {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #2C2420;
  }

  .port__title em { font-style: italic; }

  /* Filtros */
  .port__filtros {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  .port__filtro {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: 1px solid rgba(44, 36, 32, 0.15);
    color: rgba(44, 36, 32, 0.4);
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .port__filtro:hover,
  .port__filtro.is-active {
    border-color: #A48D78;
    color: #A48D78;
  }

  /* ── GRILLA ── */
  .port__grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 280px;
    gap: 12px;
  }

  .port__card:nth-child(1) { grid-column: span 7; grid-row: span 2; }
  .port__card:nth-child(2) { grid-column: span 5; grid-row: span 1; }
  .port__card:nth-child(3) { grid-column: span 5; grid-row: span 1; }
  .port__card:nth-child(4) { grid-column: span 4; grid-row: span 2; }
  .port__card:nth-child(5) { grid-column: span 4; grid-row: span 1; }
  .port__card:nth-child(6) { grid-column: span 4; grid-row: span 1; }
  .port__card:nth-child(7) { grid-column: span 4; grid-row: span 1; }

  /* ── CARD ── */
  .port__card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: #E6DAC8;
  }

  .port__card-img-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .port__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .port__card:hover .port__card-img { transform: scale(1.06); }

  .port__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 36, 32, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .port__card:hover .port__card-overlay { opacity: 1; }

  .port__card-ver {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FAF9F6;
    border: 1px solid rgba(250, 249, 246, 0.7);
    padding: 0.6rem 1.4rem;
  }

  .port__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.2rem;
    background: linear-gradient(to top, rgba(44,36,32,0.7) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .port__card-tipo {
    font-family: 'Manrope', sans-serif;
    font-size: 0.6rem;
    color: #CBB9A4;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .port__card-nombre {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    color: #FAF9F6;
  }

  .port__card.is-hidden { display: none; }

  /* ── LIGHTBOX FULLSCREEN ── */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #0a0a09;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .lb.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* Cerrar */
  .lb__close {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 10;
    width: 44px;
    height: 44px;
    background: rgba(250,249,246,0.06);
    border: 1px solid rgba(250,249,246,0.12);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .lb__close:hover { background: rgba(250,249,246,0.12); }

  .lb__close span {
    position: absolute;
    width: 18px;
    height: 1px;
    background: rgba(250,249,246,0.8);
  }

  .lb__close span:first-child { transform: rotate(45deg); }
  .lb__close span:last-child  { transform: rotate(-45deg); }

  /* Info */
  .lb__info {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .lb__label {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(250,249,246,0.6);
  }

  .lb__counter {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(250,249,246,0.3);
  }

  /* Track */
  .lb__track {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem;
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .lb__slide.is-active { opacity: 1; }

  .lb__slide img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
  }

  /* Flechas */
  .lb__arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(250,249,246,0.05);
    border: 1px solid rgba(250,249,246,0.1);
    color: rgba(250,249,246,0.6);
    width: 52px;
    height: 52px;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .lb__arrow:hover {
    background: rgba(250,249,246,0.1);
    color: #FAF9F6;
  }

  .lb__arrow--prev { left: 1.5rem; }
  .lb__arrow--next { right: 1.5rem; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .port__grid {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 240px;
    }

    .port__card:nth-child(1) { grid-column: span 6; grid-row: span 2; }
    .port__card:nth-child(2) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(3) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(4) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(5) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(6) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(7) { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 768px) {
    .port { padding: 5rem 0 3rem; }

    .port__header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1.5rem;
      margin-bottom: 2rem;
    }

    .port__header-inner { align-items: center; }
    .port__filtros { flex-wrap: wrap; justify-content: center; }

    .port__grid {
      padding: 0 1.5rem;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
      gap: 8px;
    }

    .port__card:nth-child(n) { grid-column: span 1; grid-row: span 1; }
    .port__card:nth-child(1) { grid-column: span 2; grid-row: span 1; }

    .lb__slide { padding: 4rem 1rem; }
    .lb__arrow { display: none; }
  }

  @media (max-width: 480px) {
    .port__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }

    .port__card:nth-child(n) { grid-column: span 1; }
    .port__card:nth-child(1) { grid-column: span 1; }
  }
</style>

<script>
  // ── FILTROS ──
  const filtros = document.querySelectorAll('.port__filtro')
  const cards   = document.querySelectorAll('.port__card')

  filtros.forEach(btn => {
    btn.addEventListener('click', () => {
      filtros.forEach(b => b.classList.remove('is-active'))
      btn.classList.add('is-active')
      const filter = btn.getAttribute('data-filter')
      cards.forEach(card => {
        const tipo = card.getAttribute('data-tipo')
        card.classList.toggle('is-hidden', filter !== 'todos' && tipo !== filter)
      })
    })
  })

  // ── LIGHTBOX ──
  const lb       = document.getElementById('lightbox')
  const lbClose  = document.getElementById('lbClose')
  const lbTrack  = document.getElementById('lbTrack')
  const lbLabel  = document.getElementById('lbLabel')
  const lbCounter = document.getElementById('lbCounter')
  const lbPrev   = document.getElementById('lbPrev')
  const lbNext   = document.getElementById('lbNext')

  let imgs: string[] = []
  let idx = 0

  function open(imagenes: string[], label: string) {
    imgs = imagenes
    idx  = 0

    if (lbTrack) {
      lbTrack.innerHTML = ''
      imagenes.forEach((src, i) => {
        const slide = document.createElement('div')
        slide.className = 'lb__slide' + (i === 0 ? ' is-active' : '')
        const img = document.createElement('img')
        img.src = src
        img.alt = label
        slide.appendChild(img)
        lbTrack.appendChild(slide)
      })
    }

    if (lbLabel)   lbLabel.textContent   = label
    if (lbCounter) lbCounter.textContent = `1 / ${imagenes.length}`

    lb?.classList.add('is-open')
    document.body.style.overflow = 'hidden'
  }

  function close() {
    lb?.classList.remove('is-open')
    document.body.style.overflow = ''
  }

  function goTo(newIdx: number) {
    const slides = lbTrack?.querySelectorAll('.lb__slide')
    if (!slides) return
    slides[idx]?.classList.remove('is-active')
    idx = (newIdx + imgs.length) % imgs.length
    slides[idx]?.classList.add('is-active')
    if (lbCounter) lbCounter.textContent = `${idx + 1} / ${imgs.length}`
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const raw      = card.getAttribute('data-imagenes') ?? '[]'
      const imagenes = JSON.parse(raw) as string[]
      const label    = card.getAttribute('data-label') ?? ''
      open(imagenes, label)
    })
  })

  lbClose?.addEventListener('click', close)
  lbPrev?.addEventListener('click',  () => goTo(idx - 1))
  lbNext?.addEventListener('click',  () => goTo(idx + 1))

  lb?.addEventListener('click', e => { if (e.target === lb) close() })

  document.addEventListener('keydown', e => {
    if (!lb?.classList.contains('is-open')) return
    if (e.key === 'Escape')     close()
    if (e.key === 'ArrowLeft')  goTo(idx - 1)
    if (e.key === 'ArrowRight') goTo(idx + 1)
  })

  let touchX = 0
  lb?.addEventListener('touchstart', e => { touchX = e.touches[0].clientX })
  lb?.addEventListener('touchend',   e => {
    const diff = touchX - e.changedTouches[0].clientX
    if (Math.abs(diff) > 50) diff > 0 ? goTo(idx + 1) : goTo(idx - 1)
  })
</script>