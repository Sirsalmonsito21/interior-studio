---
const categorias = [
  {
    id: "sala",
    label: "Sala de Estar",
    tipo: "RESIDENCIAL",
    filtro: "residencial",
    cover: "/images/sala1.jpeg",
    imagenes: [
      "/images/sala1.jpeg", "/images/sala2.jpeg", "/images/sala3.jpeg", "/images/sala4.jpeg",
      "/images/sala5.jpeg", "/images/sala6.jpeg", "/images/sala7.jpeg", "/images/sala8.png",
    ]
  },
  {
    id: "comedor",
    label: "Comedor",
    tipo: "RESIDENCIAL",
    filtro: "residencial",
    cover: "/images/comedor1.jpeg",
    imagenes: [
      "/images/comedor1.jpeg", "/images/comedor2.jpeg", "/images/comedor3.jpeg",
    ]
  },
  {
    id: "cocina",
    label: "Cocina",
    tipo: "RESIDENCIAL",
    filtro: "residencial",
    cover: "/images/cocina1-1.png",
    imagenes: [
      "/images/cocina1-1.png", "/images/cocina2.jpeg", "/images/cocina3.png", "/images/cocina4.jpeg", "/images/cocina5.jpeg",
    ]
  },
  {
    id: "dormitorio",
    label: "Dormitorio",
    tipo: "RESIDENCIAL",
    filtro: "residencial",
    cover: "/images/dormitorio1.jpeg",
    imagenes: [
      "/images/dormitorio1.jpeg", "/images/dormitorio2.jpeg", "/images/dormitorio3.jpeg", "/images/dormitorio4.jpeg",
    ]
  },
  {
    id: "banio",
    label: "Baño",
    tipo: "RESIDENCIAL",
    filtro: "residencial",
    cover: "/images/baño1.jpeg",
    imagenes: [
      "/images/baño1.jpeg", "/images/baño2.jpeg", "/images/baño3.jpeg",
    ]
  },
  {
    id: "comercial",
    label: "Comercial",
    tipo: "COMERCIAL",
    filtro: "comercial",
    cover: "/images/oficina2.png",
    imagenes: [
      "/images/oficina1.png", "/images/oficina2.png"
    ]
  },
  {
    id: "ninos",
    label: "Niños",
    tipo: "INFANTIL",
    filtro: "ninos",
    cover: "/images/niña4.jpeg",
    imagenes: [
      "/images/niña1.jpeg", "/images/niña2.jpeg", "/images/niña3.jpeg", "/images/niña4.jpeg",
    ]
  }
]
---

<section class="prt" id="portafolio">
  <div class="prt__header-container">
    <header class="prt__header">
      <div class="prt__mask">
        <h2 class="prt__heading">PROYECTOS</h2>
      </div>
      
      <nav class="prt__nav">
        <button class="prt__cat-btn is-active" data-filter="all">TODOS</button>
        <button class="prt__cat-btn" data-filter="ninos">NIÑOS</button>
        <button class="prt__cat-btn" data-filter="residencial">RESIDENCIAL</button>
        <button class="prt__cat-btn" data-filter="comercial">COMERCIAL</button>
      </nav>
    </header>
  </div>

  <div class="prt__grid">
    {categorias.map(cat => (
      <div class="prt__item" data-filtro={cat.filtro} data-imagenes={JSON.stringify(cat.imagenes)} data-label={cat.label}>
        <div class="prt__card">
          <div class="prt__img-wrapper">
            <img src={cat.cover} alt={cat.label} class="prt__img" loading="lazy" />
            <div class="prt__overlay">
              <span class="prt__view-btn">EXPLORAR CATÁLOGO</span>
            </div>
          </div>
          <div class="prt__info">
            <span class="prt__project-type">{cat.tipo}</span>
            <h3 class="prt__project-label">{cat.label}</h3>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="prt__lb" id="prtLightbox">
    <div class="prt__lb-controls">
        <button class="prt__lb-close" aria-label="Cerrar">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M18 6L6 18M6 6l12 12"></path>
          </svg>
        </button>
        <div class="prt__lb-title-box">
            <h4 id="lbProjectTitle">PROYECTO</h4>
            <span>Desliza para ver más</span>
        </div>
    </div>

    <div class="prt__lb-content" id="lbScrollArea" data-lenis-prevent>
    </div>
  </div>
</section>

<style>
  .prt { background: #f5f2ee; padding: 6rem 0 0; color: #0a0a08; overflow: hidden; }
  
  .prt__header-container { max-width: 1400px; margin: 0 auto; padding: 0 5vw; }

  .prt__header { margin-bottom: 4rem; text-align: center; }
  .prt__heading { 
    font-family: 'Inter', sans-serif; 
    font-size: clamp(3.5rem, 10vw, 8rem); 
    font-weight: 800; 
    color: #0a0a08;
    letter-spacing: -0.04em;
    margin-bottom: 2.5rem;
    line-height: 1;
  }

  .prt__nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.8rem; margin-bottom: 2rem; }
  .prt__cat-btn {
    background: transparent; border: 1px solid rgba(0,0,0,0.15);
    color: #0a0a08; padding: 0.8rem 1.8rem; font-size: 0.8rem; font-weight: 600;
    cursor: pointer; transition: all 0.3s ease; border-radius: 50px;
    letter-spacing: 0.05em;
  }
  .prt__cat-btn:hover, .prt__cat-btn.is-active { background: #0a0a08; color: #fff; border-color: #0a0a08; }

  .prt__grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    width: 100%;
    gap: 2px; 
    background: #f5f2ee;
  }

  @media (max-width: 1024px) { .prt__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .prt__grid { grid-template-columns: 1fr; } }

  .prt__item { cursor: pointer; position: relative; }
  .prt__img-wrapper { position: relative; aspect-ratio: 1/1; overflow: hidden; }
  .prt__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  
  .prt__item:hover .prt__img { transform: scale(1.05); }

  .prt__overlay { 
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
    background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.4s ease;
  }
  .prt__item:hover .prt__overlay { opacity: 1; }
  .prt__view-btn { 
    background: #fff; color: #000; padding: 14px 28px; font-size: 0.75rem; 
    font-weight: 700; letter-spacing: 0.15em; border-radius: 2px;
  }

  .prt__info { 
    position: absolute; bottom: 30px; left: 30px; z-index: 2; 
    pointer-events: none; transition: transform 0.4s ease;
  }
  .prt__item:hover .prt__info { transform: translateY(-10px); }
  
  .prt__project-type { 
    font-size: 0.7rem; color: #fff; font-weight: 600; letter-spacing: 0.15em; 
    text-shadow: 0 2px 4px rgba(0,0,0,0.3); display: block; 
  }
  .prt__project-label { 
    font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; 
    font-weight: 600; color: #fff; line-height: 1;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  /* =============================================
     LIGHTBOX — FIX DEFINITIVO
     ============================================= */

  .prt__lb {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #0a0a08;
    z-index: 9999;
    display: none;
    overflow: hidden;
  }
  .prt__lb.is-open { display: block; }

  .prt__lb-controls {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 4vw;
    z-index: 100;
    background: linear-gradient(to bottom, rgba(10,10,8,0.9), transparent);
    pointer-events: none;
    box-sizing: border-box;
  }
  .prt__lb-close {
    background: transparent; color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
    width: 50px; height: 50px; border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    pointer-events: auto;
    transition: all 0.3s;
    flex-shrink: 0;
  }
  .prt__lb-close:hover { background: #fff; color: #000; }

  .prt__lb-title-box { text-align: right; color: #fff; }
  .prt__lb-title-box h4 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; margin: 0; font-weight: 600; }
  .prt__lb-title-box span { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.7; font-weight: 600; }

  /*
    ZONA DE SCROLL:
    overflow-x: hidden  → elimina el scroll horizontal que se veía en tu screenshot
    overflow-y: auto    → permite deslizar entre imágenes
  */
  .prt__lb-content {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    box-sizing: border-box;
  }

  /*
    CADA SLIDE:
    - Usa el viewport completo como caja
    - overflow: hidden → la imagen nunca rompe los bordes
  */
  .prt__lb-img-wrapper {
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 110px 6vw 40px;
    box-sizing: border-box;
    overflow: hidden;
  }

  /*
    LA IMAGEN:
    - max-width: 100% → no desborda el ancho del wrapper (que ya tiene padding)
    - max-height: 85vh → no supera el alto visible
    - width/height: auto → respeta la proporción real (vertical, horizontal, cuadrada)
    No se necesita object-fit porque la imagen no está forzada a ningún tamaño fijo.
  */
  .prt__lb-img {
    display: block;
    max-width: 100%;
    max-height: 85vh;
    width: auto;
    height: auto;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .prt__lb-img-wrapper { padding: 100px 4vw 30px; }
    .prt__lb-img { max-height: 82vh; }
  }

  @media (max-width: 480px) {
    .prt__lb-img-wrapper { padding: 90px 3vw 20px; }
    .prt__lb-img { max-height: 80vh; }
  }
</style>

<script>
  const items = document.querySelectorAll('.prt__item');
  const btns = document.querySelectorAll('.prt__cat-btn');
  const lb = document.getElementById('prtLightbox')!;
  const lbScrollArea = document.getElementById('lbScrollArea')!;
  const lbTitle = document.getElementById('lbProjectTitle')!;
  const lbClose = document.querySelector('.prt__lb-close')!;

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.getAttribute('data-filter');
      items.forEach(item => {
        if (filter === 'all' || item.getAttribute('data-filtro') === filter) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  function openCatalog(item: Element) {
    const imagenes = JSON.parse(item.getAttribute('data-imagenes') || '[]');
    const label = item.getAttribute('data-label') || '';

    (lbTitle as HTMLElement).innerText = label.toUpperCase();
    lbScrollArea.innerHTML = '';

    imagenes.forEach((src: string) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'prt__lb-img-wrapper';
      const img = document.createElement('img');
      img.src = src;
      img.className = 'prt__lb-img';
      img.alt = 'Proyecto Studio2810';
      img.loading = 'lazy';
      wrapper.appendChild(img);
      lbScrollArea.appendChild(wrapper);
    });

    lb.classList.add('is-open');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
    lbScrollArea.scrollTop = 0;
  }

  function closeLb() {
    lb.classList.remove('is-open');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
  }

  items.forEach(item => {
    item.addEventListener('click', () => openCatalog(item));
  });

  lbClose.addEventListener('click', closeLb);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLb(); });
</script>