---

<section class="port" id="portafolio">
  <div class="port__header">
    <div class="port__header-inner">
      <span class="label port__label">Nuestro Trabajo</span>
      <h2 class="port__title">Portafolio de<br /><em>Proyectos</em></h2>
    </div>

    <!-- Filtros -->
    <div class="port__filtros">
      <button class="port__filtro is-active" data-filter="todos">Todos</button>
      <button class="port__filtro" data-filter="RESIDENCIAL">Residencial</button>
      <button class="port__filtro" data-filter="COMERCIAL">Comercial</button>
    </div>
  </div>

  <!-- Grilla -->
  <div class="port__grid" id="portGrid">
    {categorias.map((cat, i) => (
      <div
        class={`port__card ${i === 0 ? 'port__card--featured' : ''}`}
        data-tipo={cat.tipo}
        data-id={cat.id}
        data-imagenes={JSON.stringify(cat.imagenes)}
        data-label={cat.label}
        data-tipo-label={cat.tipo}
      >
        <div class="port__card-img-wrap">
          <img
            class="port__card-img"
            src={cat.cover}
            alt={cat.label}
            loading="lazy"
          />
          <div class="port__card-overlay">
            <span class="port__card-ver">Ver proyecto</span>
          </div>
        </div>
        <div class="port__card-info">
          <span class="label port__card-tipo">{cat.tipo}</span>
          <span class="port__card-nombre">{cat.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-hidden="true">
  <div class="lightbox__backdrop" id="lbBackdrop"></div>

  <div class="lightbox__panel">
    <div class="lightbox__top">
      <div>
        <span class="label lightbox__tipo" id="lbTipo"></span>
        <h3 class="lightbox__title" id="lbTitle"></h3>
      </div>
      <button class="lightbox__close" id="lbClose" aria-label="Cerrar">
        <span></span><span></span>
      </button>
    </div>

    <!-- Imagen principal -->
    <div class="lightbox__main">
      <img class="lightbox__main-img" id="lbMainImg" src="" alt="" />
      <button class="lightbox__arrow lightbox__arrow--prev" id="lbPrev">&#8592;</button>
      <button class="lightbox__arrow lightbox__arrow--next" id="lbNext">&#8594;</button>
    </div>

    <!-- Thumbnails -->
    <div class="lightbox__thumbs" id="lbThumbs"></div>
  </div>
</div>

<style>
  /* ── SECCIÓN ── */
  .port {
    background: #0e1110;
    padding: var(--space-24) 0;
  }

  .port__header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-8);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    margin-bottom: var(--space-20);
  }

  .port__header-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .port__label { color: var(--secondary-fixed-dim); }

  .port__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #f0ede8;
  }

  .port__title em { font-style: italic; }

  /* Filtros */
  .port__filtros {
    display: flex;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .port__filtro {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: 1px solid rgba(240, 237, 232, 0.15);
    color: rgba(240, 237, 232, 0.5);
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .port__filtro:hover,
  .port__filtro.is-active {
    border-color: rgba(240, 237, 232, 0.6);
    color: #f0ede8;
  }

  /* ── GRILLA ASIMÉTRICA ── */
  .port__grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-8);
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 280px;
    gap: 12px;
  }

  /* Distribución de cards — asimetría editorial */
  .port__card:nth-child(1) { grid-column: span 7; grid-row: span 2; } /* featured grande */
  .port__card:nth-child(2) { grid-column: span 5; grid-row: span 1; }
  .port__card:nth-child(3) { grid-column: span 5; grid-row: span 1; }
  .port__card:nth-child(4) { grid-column: span 4; grid-row: span 2; }
  .port__card:nth-child(5) { grid-column: span 4; grid-row: span 1; }
  .port__card:nth-child(6) { grid-column: span 4; grid-row: span 1; }
  .port__card:nth-child(7) { grid-column: span 4; grid-row: span 1; }

  /* ── CARD ── */
  .port__card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: #1a1f1d;
  }

  .port__card-img-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .port__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .port__card:hover .port__card-img {
    transform: scale(1.06);
  }

  /* Overlay hover */
  .port__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(12, 14, 13, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .port__card:hover .port__card-overlay { opacity: 1; }

  .port__card-ver {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #f0ede8;
    border: 1px solid rgba(240, 237, 232, 0.6);
    padding: 0.6rem 1.4rem;
  }

  /* Info debajo de la imagen */
  .port__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.2rem;
    background: linear-gradient(to top, rgba(12,14,13,0.85) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 2px;
    transform: translateY(4px);
    transition: transform 0.3s ease;
  }

  .port__card:hover .port__card-info { transform: translateY(0); }

  .port__card-tipo {
    font-size: 0.6rem;
    color: var(--secondary-fixed-dim);
    letter-spacing: 0.15em;
  }

  .port__card-nombre {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 300;
    color: #f0ede8;
    letter-spacing: 0.02em;
  }

  /* Card oculta por filtro */
  .port__card.is-hidden {
    display: none;
  }

  /* ── LIGHTBOX ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 10, 9, 0.95);
    cursor: pointer;
  }

  .lightbox__panel {
    position: relative;
    z-index: 2;
    width: 90vw;
    max-width: 1100px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .lightbox.is-open .lightbox__panel {
    transform: translateY(0);
  }

  .lightbox__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .lightbox__tipo {
    color: var(--secondary-fixed-dim);
    font-size: 0.65rem;
  }

  .lightbox__title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 300;
    color: #f0ede8;
    margin-top: 4px;
  }

  .lightbox__close {
    background: none;
    border: none;
    cursor: pointer;
    width: 36px;
    height: 36px;
    position: relative;
    flex-shrink: 0;
  }

  .lightbox__close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 1px;
    background: rgba(240, 237, 232, 0.7);
  }

  .lightbox__close span:first-child {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .lightbox__close span:last-child {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .lightbox__close:hover span { background: #f0ede8; }

  /* Imagen principal */
  .lightbox__main {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    max-height: 65vh;
    overflow: hidden;
  }

  .lightbox__main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  .lightbox__main-img.is-transitioning { opacity: 0; }

  /* Flechas */
  .lightbox__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(240, 237, 232, 0.08);
    border: 1px solid rgba(240, 237, 232, 0.15);
    color: #f0ede8;
    font-size: 1rem;
    width: 44px;
    height: 44px;
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox__arrow:hover {
    background: rgba(240, 237, 232, 0.15);
    border-color: rgba(240, 237, 232, 0.4);
  }

  .lightbox__arrow--prev { left: var(--space-4); }
  .lightbox__arrow--next { right: var(--space-4); }

  /* Thumbnails */
  .lightbox__thumbs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .lightbox__thumbs::-webkit-scrollbar { display: none; }

  .lightbox__thumb {
    flex-shrink: 0;
    width: 80px;
    height: 56px;
    object-fit: cover;
    opacity: 0.45;
    cursor: pointer;
    transition: opacity 0.3s ease;
    border: 1px solid transparent;
  }

  .lightbox__thumb.is-active {
    opacity: 1;
    border-color: rgba(240, 237, 232, 0.5);
  }

  .lightbox__thumb:hover { opacity: 0.8; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .port__grid {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 240px;
    }

    .port__card:nth-child(1) { grid-column: span 6; grid-row: span 2; }
    .port__card:nth-child(2) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(3) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(4) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(5) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(6) { grid-column: span 3; grid-row: span 1; }
    .port__card:nth-child(7) { grid-column: span 3; grid-row: span 1; }
  }

  @media (max-width: 768px) {
    .port {
      padding: var(--space-20) 0;
    }

    .port__header {
      flex-direction: column;
      align-items: flex-start;
      padding: 0 var(--space-6);
      margin-bottom: var(--space-8);
    }

    .port__filtros { flex-wrap: wrap; }

    .port__grid {
      padding: 0 var(--space-6);
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
      gap: 8px;
    }

    /* En mobile todas las cards iguales */
    .port__card:nth-child(n) {
      grid-column: span 1;
      grid-row: span 1;
    }

    .port__card:nth-child(1) {
      grid-column: span 2;
      grid-row: span 1;
    }

    .lightbox__panel { width: 95vw; }
    .lightbox__main  { max-height: 55vh; }
    .lightbox__arrow { display: none; }
  }

  @media (max-width: 480px) {
    .port__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }

    .port__card:nth-child(n) { grid-column: span 1; }
    .port__card:nth-child(1) { grid-column: span 1; }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  // ── FILTROS ──
  const filtros  = document.querySelectorAll('.port__filtro')
  const cards    = document.querySelectorAll('.port__card')

  filtros.forEach(btn => {
    btn.addEventListener('click', () => {
      filtros.forEach(b => b.classList.remove('is-active'))
      btn.classList.add('is-active')

      const filter = btn.getAttribute('data-filter')

      cards.forEach(card => {
        const tipo = card.getAttribute('data-tipo')
        if (filter === 'todos' || tipo === filter) {
          card.classList.remove('is-hidden')
        } else {
          card.classList.add('is-hidden')
        }
      })
    })
  })

  // ── LIGHTBOX ──
  const lightbox  = document.getElementById('lightbox')
  const lbBackdrop = document.getElementById('lbBackdrop')
  const lbClose   = document.getElementById('lbClose')
  const lbMainImg = document.getElementById('lbMainImg') as HTMLImageElement
  const lbThumbs  = document.getElementById('lbThumbs')
  const lbTitle   = document.getElementById('lbTitle')
  const lbTipo    = document.getElementById('lbTipo')
  const lbPrev    = document.getElementById('lbPrev')
  const lbNext    = document.getElementById('lbNext')

  let currentImages: string[] = []
  let currentIndex = 0

  function openLightbox(imagenes: string[], label: string, tipo: string, startIndex = 0) {
    currentImages = imagenes
    currentIndex  = startIndex

    if (lbTitle) lbTitle.textContent = label
    if (lbTipo)  lbTipo.textContent  = tipo

    renderThumbs()
    setMainImage(currentIndex)

    lightbox?.classList.add('is-open')
    document.body.style.overflow = 'hidden'
  }

  function closeLightbox() {
    lightbox?.classList.remove('is-open')
    document.body.style.overflow = ''
  }

  function setMainImage(index: number) {
    if (!lbMainImg) return
    lbMainImg.classList.add('is-transitioning')
    setTimeout(() => {
      lbMainImg.src = currentImages[index]
      lbMainImg.classList.remove('is-transitioning')
    }, 150)

    // Actualizar thumb activo
    document.querySelectorAll('.lightbox__thumb').forEach((t, i) => {
      t.classList.toggle('is-active', i === index)
    })
  }

  function renderThumbs() {
    if (!lbThumbs) return
    lbThumbs.innerHTML = ''
    currentImages.forEach((src, i) => {
      const img = document.createElement('img')
      img.src = src
      img.className = 'lightbox__thumb' + (i === 0 ? ' is-active' : '')
      img.addEventListener('click', () => {
        currentIndex = i
        setMainImage(i)
      })
      lbThumbs.appendChild(img)
    })
  }

  // Abrir al click en card
  cards.forEach(card => {
    card.addEventListener('click', () => {
      const raw     = card.getAttribute('data-imagenes') ?? '[]'
      const imagenes = JSON.parse(raw) as string[]
      const label   = card.getAttribute('data-label') ?? ''
      const tipo    = card.getAttribute('data-tipo-label') ?? ''
      openLightbox(imagenes, label, tipo)
    })
  })

  // Cerrar
  lbClose?.addEventListener('click', closeLightbox)
  lbBackdrop?.addEventListener('click', closeLightbox)

  // Flechas
  lbPrev?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length
    setMainImage(currentIndex)
  })

  lbNext?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % currentImages.length
    setMainImage(currentIndex)
  })

  // Teclado
  document.addEventListener('keydown', e => {
    if (!lightbox?.classList.contains('is-open')) return
    if (e.key === 'Escape')     closeLightbox()
    if (e.key === 'ArrowLeft')  { currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length; setMainImage(currentIndex) }
    if (e.key === 'ArrowRight') { currentIndex = (currentIndex + 1) % currentImages.length; setMainImage(currentIndex) }
  })

  // Entrada animada de cards
  gsap.from('.port__card', {
    scrollTrigger: { trigger: '.port__grid', start: 'top 80%' },
    opacity: 0,
    y: 30,
    duration: 0.8,
    stagger: 0.08,
    ease: 'power2.out'
  })
</script>