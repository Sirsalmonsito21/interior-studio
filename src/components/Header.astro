---
const navLinks = [
  { label: "Nosotros",   href: "#esencia"   },
  { label: "Servicios",  href: "#servicios"  },
  { label: "Portafolio", href: "#portafolio" },
  { label: "Contacto",   href: "#contacto"   },
]
---

<header class="header" id="header">

  <div class="header__top">
    
    <div class="header__top-left">
      <button class="header__burger" id="menuToggle" aria-label="Abrir menú">
        <span></span><span></span>
      </button>
    </div>

    <a href="/" class="header__logo" id="headerLogoLink" aria-label="Studio2810">
      <img
        src="/images/studioLOGO.jpeg"
        alt="Studio2810"
        class="header__logo-img"
        id="headerLogoImg"
      />
    </a>

    <div class="header__top-actions">
      <button class="header__lang" id="langToggle" aria-label="Cambiar idioma">
        <span class="header__lang-active" id="langLabel">ES</span>
        <span class="header__lang-sep">/</span>
        <span class="header__lang-other" id="langOther">EN</span>
      </button>
      <a href="#shop" class="header__shop">Shop Studio2810</a>
    </div>

  </div>

  <div class="header__bottom" id="mobileMenu">
    <nav class="header__nav">
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li class="header__nav-item">
            <a href={link.href} class="header__nav-link">{link.label}</a>
          </li>
        ))}
      </ul>
      
      <div class="header__mobile-extra">
        <button class="header__lang-mobile" id="langToggleBottom">
          <span id="langMobile">ES / EN</span>
        </button>
      </div>
    </nav>
  </div>

</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap');

  /* ── Contenedor Principal ── */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background-color: #F9F8F5; /* Tono claro sólido, no transparente */
    z-index: 100;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.3s ease;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Línea muy sutil para separar del resto de la web */
  }

  .header.is-scrolled {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .header.is-hidden {
    transform: translateY(-100%);
  }

  /* ── Fila 1: Top (Logo) ── */
  .header__top {
    display: grid;
    grid-template-columns: 1fr auto 1fr; /* Clave para centrar perfectamente el logo */
    align-items: center;
    padding: 0.5rem 4vw; /* Padding vertical muy pequeño para no robar altura */
    min-height: 100px;
  }

  .header__top-left {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .header__logo {
    display: block;
    text-align: center;
  }

  /* El Logo: Más grande y optimizado */
  .header__logo-img {
    height: 85px; /* MUCHO más grande */
    width: auto;
    max-width: 280px;
    object-fit: contain; /* Evita que se deforme */
    display: block;
    margin: 0 auto;
    /* Si la imagen tiene fondo blanco y no combina con el crema, descomenta la siguiente línea: */
    /* mix-blend-mode: multiply; */
  }

  .header__top-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.5rem;
  }

  .header__lang {
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: #111;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .header__lang-other {
    color: #888;
  }

  .header__shop {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #111;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  /* ── Fila 2: Navegación Inferior ── */
  .header__bottom {
    border-top: 1px solid rgba(0,0,0,0.06);
    padding: 1rem 0;
    background-color: #F9F8F5;
  }

  .header__nav-list {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem; /* Separación amplia y elegante */
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem; /* Tamaño legible */
    font-weight: 400;
    letter-spacing: 0.15em; /* Espaciado que da look premium */
    text-transform: uppercase;
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .header__nav-link:hover {
    color: #a07846; /* Color de acento al pasar el mouse */
  }

  /* Ocultar elementos mobile en desktop */
  .header__burger,
  .header__mobile-extra {
    display: none;
  }

  /* ── RESPONSIVE (Móviles y Tablets) ── */
  @media (max-width: 900px) {
    .header__top {
      grid-template-columns: auto 1fr auto; /* Burger izquierda, Logo centro, Vacio derecha */
      padding: 0.5rem 5vw;
      min-height: 80px;
    }

    .header__logo-img {
      height: 60px; /* Un poco más pequeño en móviles */
    }

    .header__top-actions {
      display: none; /* Ocultamos idioma y shop en top para mobile */
    }

    .header__burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 30px;
      height: 30px;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 200;
    }

    .header__burger span {
      display: block;
      width: 100%;
      height: 2px;
      background-color: #111;
      transition: all 0.3s ease;
    }

    /* Menú Mobile desplegable */
    .header__bottom {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 100vh;
      background-color: #F9F8F5;
      flex-direction: column;
      justify-content: flex-start;
      padding-top: 2rem;
      clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
      transition: clip-path 0.5s cubic-bezier(0.77, 0, 0.175, 1);
    }

    .header__bottom.is-open {
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    }

    .header__nav-list {
      flex-direction: column;
      gap: 2rem;
    }

    .header__nav-link {
      font-size: 1.2rem;
    }

    .header__mobile-extra {
      display: flex;
      justify-content: center;
      margin-top: 3rem;
    }

    .header__lang-mobile {
      font-family: 'Jost', sans-serif;
      font-size: 1rem;
      background: none;
      border: none;
      cursor: pointer;
    }

    /* Animación de la X del menú */
    .header__burger.is-active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .header__burger.is-active span:nth-child(2) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  // ── Lógica de Scroll (Ocultar/Mostrar) ──
  let lastScroll = 0
  const header = document.getElementById('header')
  let menuOpen = false

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY
    
    // Sombra sutil al bajar
    header?.classList.toggle('is-scrolled', currentScroll > 40)
    
    // Lógica de esconder el header al bajar y mostrar al subir
    if (currentScroll <= 60) {
      header?.classList.remove('is-hidden')
    } else if (currentScroll > lastScroll + 10) {
      if (!menuOpen) header?.classList.add('is-hidden') // Solo oculta si el menú mobile está cerrado
    } else if (currentScroll < lastScroll - 10) {
      header?.classList.remove('is-hidden')
    }
    
    lastScroll = currentScroll
  }, { passive: true })

  // ── Menú Móvil ──
  const burger = document.getElementById('menuToggle')
  const mobileMenu = document.getElementById('mobileMenu')

  burger?.addEventListener('click', () => {
    menuOpen = !menuOpen
    burger.classList.toggle('is-active')
    mobileMenu?.classList.toggle('is-open')
  })

  // Cerrar menú al hacer click en un link
  document.querySelectorAll('.header__nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menuOpen = false
      burger?.classList.remove('is-active')
      mobileMenu?.classList.remove('is-open')
    })
  })

  // ── Idioma ──
  let currentLang = 'ES'
  function toggleLang() {
    currentLang = currentLang === 'ES' ? 'EN' : 'ES'
    const other = currentLang === 'ES' ? 'EN' : 'ES'
    
    const lb = document.getElementById('langLabel')
    const ob = document.getElementById('langOther')
    const lm = document.getElementById('langMobile')
    
    if (lb) lb.textContent = currentLang
    if (ob) ob.textContent = other
    if (lm) lm.textContent = `${currentLang} / ${other}`

    document.documentElement.lang = currentLang.toLowerCase()
  }

  document.getElementById('langToggle')?.addEventListener('click', toggleLang)
  document.getElementById('langToggleBottom')?.addEventListener('click', toggleLang)
</script>