---
const navLinks = [
  { label: "Nosotros",        href: "#esencia",    key: "nav.nosotros"   },
  { label: "Servicios",       href: "#servicios",  key: "nav.servicios"  },
  { label: "Portafolio",      href: "#portafolio", key: "nav.portafolio" },
  { label: "Contacto",        href: "#contacto",   key: "nav.contacto"   },
  { label: "Shop Studio2810", href: "/shop", key: "nav.shop", isShop: true }
]
---

<header class="header" id="header">
  <div class="header__container" id="headerContainer">
    
    <div class="header__left">
      <a href="/" class="header__logo" id="headerLogoLink" aria-label="Studio2810">
        <img
          src="/images/studioLOGO.jpeg"
          alt="Studio2810"
          class="header__logo-img"
          id="headerLogoImg"
        />
      </a>
    </div>

    <nav class="header__nav-desktop" id="navDesktop">
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class={`header__nav-link ${link.isShop ? 'is-shop' : ''}`} data-i18n={link.key}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__right" id="headerActions">
      <div class="header__lang-wrapper" id="langContainer">
        <button class="header__lang" id="langToggle">
          <span id="langLabel">ES</span> / <span id="langOther">EN</span>
        </button>
      </div>

      <button class="header__burger" id="menuToggle" aria-label="Menu">
        <svg id="iconOpen" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg id="iconClose" style="display: none;" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

  </div>

  <div class="header__mobile-menu" id="mobileMenu">
    <nav class="header__mobile-nav">
      {navLinks.map((link) => (
        <a href={link.href} class="header__mobile-link" data-i18n={link.key}>{link.label}</a>
      ))}
      <a href="#contacto" class="header__mobile-link" data-i18n="nav.conversemos">Conversemos</a>
    </nav>
  </div>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap');

  .header {
    position: fixed;
    top: 0; left: 0; width: 100%;
    z-index: 1000;
    background: transparent;
    transition: transform 0.4s ease, background 0.4s ease, box-shadow 0.4s ease;
    color: white;
  }

  .header.is-hidden {
    transform: translateY(-100%);
  }

  .header.is-scrolled {
    background: rgba(249, 248, 245, 0.95);
    backdrop-filter: blur(10px);
    color: #111;
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
  }

  .header__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
    padding: 0 2vw;
    max-width: 98%;
    margin: 0 auto;
    transition: height 0.4s ease;
  }

  .header.is-scrolled .header__container {
    height: 50px;
  }

  .header__left { flex: 1; display: flex; align-items: center; justify-content: flex-start; }
  .header__logo { 
    text-decoration: none !important; 
    color: transparent;
    border: none;
    outline: none;
    display: inline-block;
  }
  .header__logo-img {
    height: 38px;
    width: auto;
    display: block;
    mix-blend-mode: screen;
    filter: brightness(0) invert(1); 
    transition: filter 0.4s ease, transform 0.4s ease, height 0.4s ease;
  }

  .header.is-scrolled .header__logo-img {
    filter: none;
    mix-blend-mode: multiply;
    height: 30px;
  }

  .header__nav-desktop { flex: 2; }
  .header__nav-list {
    display: flex;
    justify-content: center; gap: 3rem;
    list-style: none; padding: 0; margin: 0;
  }
  .header__nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase; 
    letter-spacing: 0.2em;
    color: inherit; 
    text-decoration: none; 
    position: relative;
    padding-bottom: 4px;
    transition: opacity 0.3s;
  }
  
  .header__nav-link:not(.is-shop)::after {
    content: '';
    position: absolute;
    width: 0;
    height: 1px;
    bottom: 0;
    left: 50%;
    background-color: currentColor;
    transition: width 0.3s ease, left 0.3s ease;
    transform: translateX(-50%);
  }
  .header__nav-link:not(.is-shop):hover::after {
    width: 100%;
  }

  .header__nav-link.is-shop { 
    font-weight: 500;
    border-bottom: 1px solid currentColor; 
  }
  .header__nav-link.is-shop:hover {
    opacity: 0.6;
  }

  .header__right {
    flex: 1; display: flex;
    justify-content: flex-end; align-items: center; gap: 2.5rem;
  }

  .header__lang {
    background: none; 
    border: none; 
    cursor: pointer;
    font-family: 'Jost', sans-serif; 
    font-size: 0.8rem; 
    font-weight: 500;
    color: inherit;
    display: flex;
    gap: 0.3rem;
    align-items: center;
    padding: 5px;
  }
  .header__lang:hover {
    opacity: 0.7;
    transform: scale(1.05);
  }
  #langOther {
    opacity: 0.5;
  }
  .header__lang span {
    display: inline-block;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .header__lang:hover #langLabel {
    transform: scale(1.1);
    opacity: 1;
  }
  .header__lang:hover #langOther {
    transform: scale(1.1);
    opacity: 0.8;
  }

  .header__burger {
    display: none; 
    background: none;
    border: none; 
    cursor: pointer;
    color: inherit; 
    z-index: 1001;
  }

  .header__mobile-menu {
    position: fixed;
    top: 0; right: 0; width: 100%; height: 100vh;
    background: #F9F8F5; 
    display: flex; align-items: center; justify-content: center;
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .header__mobile-menu.is-open { opacity: 1; pointer-events: auto; }
  
  .header__mobile-nav { display: flex; flex-direction: column; gap: 2.5rem; align-items: center; }
  .header__mobile-link { 
    font-family: 'Jost', sans-serif; 
    font-size: 1.4rem; 
    font-weight: 400; 
    text-decoration: none; 
    color: #111; 
    text-transform: uppercase; 
    letter-spacing: 0.1em; 
    transition: opacity 0.3s; 
  }
  .header__mobile-link:hover { opacity: 0.5; }

  @media (max-width: 1024px) {
    .header__nav-desktop, .header__cta { display: none; }
    .header__lang-wrapper { display: flex; }
    .header__burger { display: flex; align-items: center; justify-content: center; }
    .header__right { gap: 1rem; }
  }

  @media (max-width: 768px) {
    .header__container { height: 70px; }
    .header.is-scrolled .header__container { height: 55px; }
    .header__logo-img { height: 32px; }
    .header.is-scrolled .header__logo-img { height: 26px; }
  }

  @media (max-width: 480px) {
    .header__container { height: 60px; padding: 0 4vw; }
    .header__logo-img { height: 26px; }
    .header.is-scrolled .header__logo-img { height: 22px; }
  }
</style>

<script is:inline>
  function initHeader() {
    try {
      const header = document.getElementById('header');
      const logoLink = document.getElementById('headerLogoLink');
      const nav = document.getElementById('navDesktop');
      const actions = document.getElementById('headerActions');
      const langContainer = document.getElementById('langContainer');

      // Animación de entrada PC
      if (window.gsap && window.innerWidth > 1024 && logoLink && nav && actions) {
        const logoRect = logoLink.getBoundingClientRect();
        const xOffset = (window.innerWidth / 2) - (logoRect.left + logoRect.width / 2);
        gsap.set(logoLink, { x: xOffset });
        gsap.set([nav, actions], { opacity: 0, y: 10 });
        const tl = gsap.timeline({ delay: 1.5 });
        tl.to(logoLink, { x: 0, duration: 1.6, ease: "power3.inOut" })
          .to([nav, actions], { opacity: 1, y: 0, duration: 0.8, stagger: 0.15 }, "-=0.6");
      }

      // SMART SCROLL
      let lastScroll = 0;
      window.addEventListener('scroll', () => {
        const currentScroll = window.scrollY;
        if (currentScroll > 60) {
          header?.classList.add('is-scrolled');
        } else {
          header?.classList.remove('is-scrolled');
        }
        const isMenuOpen = document.getElementById('mobileMenu')?.classList.contains('is-open');
        if (!isMenuOpen) {
          if (currentScroll > lastScroll && currentScroll > 150) {
            header?.classList.add('is-hidden'); 
          } else {
            header?.classList.remove('is-hidden'); 
          }
        }
        lastScroll = currentScroll;
      });

      // CAMBIO DE IDIOMA
      const langBtn = document.getElementById('langToggle');
      langBtn?.addEventListener('click', () => {
        const newLang = window.__lang === 'ES' ? 'EN' : 'ES'
        window.applyTranslations(newLang)
        if (window.gsap) gsap.fromTo(langContainer, { scale: 1 }, { scale: 1.1, duration: 0.1, yoyo: true, repeat: 1 })
      });

      // MENÚ MÓVIL
      const burger = document.getElementById('menuToggle');
      const mobileMenu = document.getElementById('mobileMenu');
      const iconOpen = document.getElementById('iconOpen');
      const iconClose = document.getElementById('iconClose');

      function toggleMobileMenu() {
        if(!mobileMenu) return;
        const isOpen = mobileMenu.classList.contains('is-open');
        if (isOpen) {
          mobileMenu.classList.remove('is-open');
          iconOpen.style.display = 'block';
          iconClose.style.display = 'none';
          document.body.style.overflow = '';
          if (window.scrollY <= 60) header.style.color = 'white';
        } else {
          mobileMenu.classList.add('is-open');
          iconOpen.style.display = 'none';
          iconClose.style.display = 'block';
          document.body.style.overflow = 'hidden'; 
          header.style.color = '#111';
        }
      }

      burger?.addEventListener('click', toggleMobileMenu);

      document.querySelectorAll('.header__nav-link, .header__mobile-link, .header__cta').forEach(link => {
        link.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (href && href.startsWith('#')) {
            e.preventDefault();
            if (mobileMenu?.classList.contains('is-open')) {
              toggleMobileMenu();
            }
            const targetSection = document.querySelector(href);
            if (targetSection) {
              const offsetPosition = targetSection.getBoundingClientRect().top + window.scrollY - 65;
              window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            }
          }
        });
      });

    } catch (e) { console.error("Error en Header:", e); }
  }

  window.addEventListener('load', initHeader);
</script>