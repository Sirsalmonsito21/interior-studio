---
const navLinks = [
  { label: "Nosotros",   href: "#esencia"   },
  { label: "Servicios",  href: "#servicios"  },
  { label: "Portafolio", href: "#portafolio" },
  { label: "Contacto",   href: "#contacto"   },
  { label: "Shop Studio2810", href: "#shop", isShop: true }
]
---

<header class="header" id="header">
  <div class="header__container" id="headerContainer">
    
    <div class="header__left">
      <a href="/" class="header__logo" id="headerLogoLink" aria-label="Studio2810">
        <img
          src="/images/studioLOGO.jpeg"
          alt="Studio2810"
          class="header__logo-img"
          id="headerLogoImg"
        />
      </a>
    </div>

    <nav class="header__nav-desktop" id="navDesktop">
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class={`header__nav-link ${link.isShop ? 'is-shop' : ''}`}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__right" id="headerActions">
      <div class="header__lang-wrapper" id="langContainer">
        <button class="header__lang" id="langToggle">
          <span id="langLabel">ES</span> / <span id="langOther">EN</span>
        </button>
      </div>
      
      <a href="#contacto" class="header__cta">Conversemos</a>

      <button class="header__burger" id="menuToggle" aria-label="Abrir Menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="header__mobile-menu" id="mobileMenu">
    <button class="mobile-menu__close" id="closeMenu">&times;</button>
    <nav class="header__mobile-nav">
      {navLinks.map((link) => (
        <a href={link.href} class="header__mobile-link">{link.label}</a>
      ))}
      <a href="#contacto" class="header__mobile-link mobile-cta">Conversemos</a>
    </nav>
  </div>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap');

  /* RESET DE ENLACES PARA EVITAR RAYAS AZULES */
  a, a:visited, a:hover, a:active {
    text-decoration: none !important;
    color: inherit;
    -webkit-tap-highlight-color: transparent; /* Quita el cuadro gris en iPhone */
  }

  .header {
    position: fixed;
    top: 0; left: 0; 
    width: 100%;
    z-index: 1000;
    background: transparent;
    transition: all 0.4s ease;
    color: white;
    box-sizing: border-box;
  }

  .header.is-scrolled {
    background: rgba(249, 248, 245, 0.98);
    backdrop-filter: blur(10px);
    color: #111;
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
  }

  .header__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px; /* Reducido de 100px para iPhone */
    padding: 0 5%;
    max-width: 1400px;
    margin: 0 auto;
    transition: height 0.4s ease;
  }

  .header.is-scrolled .header__container {
    height: 60px;
  }

  /* LOGO RESPONSIVO */
  .header__left { flex: 0 1 auto; }
  
  .header__logo-img {
    height: 40px; /* Tamaño base más seguro */
    width: auto;
    display: block;
    mix-blend-mode: screen;
    filter: brightness(0) invert(1);
    transition: all 0.4s ease;
  }

  .header.is-scrolled .header__logo-img {
    filter: none;
    mix-blend-mode: multiply;
    height: 35px;
  }

  /* NAV DESKTOP (Oculto en móvil) */
  .header__nav-desktop { display: none; }

  @media (min-width: 1025px) {
    .header__nav-desktop { 
      display: block; 
      flex: 1;
    }
    .header__nav-list {
      display: flex;
      justify-content: center;
      gap: 2rem;
      list-style: none;
    }
    .header__nav-link {
      font-family: 'Jost', sans-serif;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      transition: opacity 0.3s;
    }
  }

  /* DERECHA */
  .header__right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* CTA oculto en móviles muy pequeños para dar espacio al logo */
  .header__cta {
    display: none;
    background: white; 
    color: black;
    padding: 10px 20px;
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    border-radius: 2px;
    border: 1px solid white;
  }

  @media (min-width: 768px) {
    .header__cta { display: inline-block; }
    .header__right { gap: 2rem; }
  }

  /* BURGER CORREGIDO */
  .header__burger {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 16px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: inherit;
  }

  .header__burger span {
    width: 100%;
    height: 1.5px;
    background-color: currentColor;
    transition: 0.3s;
  }

  @media (min-width: 1025px) {
    .header__burger { display: none; }
    .header__lang-wrapper { display: block; }
  }

  /* MENÚ MÓVIL (Súper limpio para iPhone 12 Mini) */
  .header__mobile-menu {
    position: fixed;
    top: 0; right: -100%; /* Empieza fuera de pantalla */
    width: 100%;
    height: 100vh;
    background: #F9F8F5;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: right 0.5s cubic-bezier(0.77,0.2,0.05,1.0);
  }

  .header__mobile-menu.is-open {
    right: 0;
  }

  .mobile-menu__close {
    position: absolute;
    top: 25px;
    right: 25px;
    font-size: 2.5rem;
    background: none;
    border: none;
    color: #111;
  }

  .header__mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    text-align: center;
    width: 100%;
  }

  .header__mobile-link {
    font-family: 'Jost', sans-serif;
    font-size: 1.4rem;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .mobile-cta {
    margin-top: 1rem;
    font-weight: 500;
    color: #bfa181; /* Un color de acento para el botón en móvil */
  }

  /* Ajustes específicos para pantallas Retina/iPhone */
  @media (max-width: 380px) {
    .header__container { padding: 0 15px; }
    .header__logo-img { height: 32px; }
  }
</style>

<script is:inline>
  function initHeader() {
    const header = document.getElementById('header');
    const burger = document.getElementById('menuToggle');
    const closeBtn = document.getElementById('closeMenu');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileLinks = document.querySelectorAll('.header__mobile-link');

    // 1. Scroll Logic
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) {
        header?.classList.add('is-scrolled');
      } else {
        header?.classList.remove('is-scrolled');
      }
    }, { passive: true });

    // 2. Mobile Menu Toggle
    const toggleMenu = () => mobileMenu?.classList.toggle('is-open');
    
    burger?.addEventListener('click', toggleMenu);
    closeBtn?.addEventListener('click', toggleMenu);

    // Cerrar menú al hacer click en un link
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => mobileMenu?.classList.remove('is-open'));
    });

    // 3. Smooth Scroll Corregido
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const href = this.getAttribute('href');
        if (href === '#') return;
        
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          const headerHeight = header.classList.contains('is-scrolled') ? 60 : 80;
          const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - headerHeight;
          
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  }

  // Soporte para Astro transitions y carga inicial
  document.addEventListener('astro:page-load', initHeader);
  window.addEventListener('load', initHeader);
</script>