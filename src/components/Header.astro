---
const navLinks = [
  { label: "Nosotros",   href: "#esencia"   },
  { label: "Servicios",  href: "#servicios"  },
  { label: "Portafolio", href: "#portafolio" },
  { label: "Contacto",   href: "#contacto"   },
  { label: "Shop Studio2810", href: "#shop", isShop: true }
]
---

<header class="header" id="header">
  <div class="header__container" id="headerContainer">
    
    <div class="header__left">
      <a href="/" class="header__logo" id="headerLogoLink" aria-label="Studio2810">
        <img
          src="/images/studioLOGO.jpeg"
          alt="Studio2810"
          class="header__logo-img"
          id="headerLogoImg"
        />
      </a>
    </div>

    <nav class="header__nav-desktop" id="navDesktop">
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class={`header__nav-link ${link.isShop ? 'is-shop' : ''}`}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__right" id="headerActions">
      <div class="header__lang-wrapper" id="langContainer">
        <button class="header__lang" id="langToggle">
          <span id="langLabel">ES</span> / <span id="langOther">EN</span>
        </button>
      </div>
      
      <a href="#contacto" class="header__cta">Conversemos</a>

      <button class="header__burger" id="menuToggle" aria-label="Menu">
        <span></span><span></span>
      </button>
    </div>

  </div>

  <div class="header__mobile-menu" id="mobileMenu">
    <nav class="header__mobile-nav">
      {navLinks.map((link) => (
        <a href={link.href} class="header__mobile-link">{link.label}</a>
      ))}
      <a href="#contacto" class="header__mobile-link">Conversemos</a>
    </nav>
  </div>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap');

  .header {
    position: fixed;
    top: 0; left: 0; width: 100%;
    z-index: 1000;
    background: transparent;
    transition: all 0.4s ease;
    color: white; /* Base blanco */
  }

  /* Estado Scroll: Fondo crema, texto negro, sombra */
  .header.is-scrolled {
    background: rgba(249, 248, 245, 0.95);
    backdrop-filter: blur(10px);
    color: #111;
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
  }

  .header__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100px; /* Altura inicial en el Hero */
    padding: 0 2vw;
    max-width: 98%;
    margin: 0 auto;
    transition: height 0.4s ease; /* Transición suave para encogerse */
  }

  /* Cuando hay scroll, el header se hace más delgado para no ocupar pantalla */
  .header.is-scrolled .header__container {
    height: 65px;
  }

  /* LOGO */
  .header__left { flex: 1; display: flex; align-items: center; justify-content: flex-start; }
  .header__logo { 
    text-decoration: none !important; /* Adiós raya morada */
    color: transparent; 
    border: none;
    outline: none;
    display: inline-block;
  }
  .header__logo-img {
    height: 50px; /* Logo ligeramente más chico como pediste */
    width: auto;
    display: block;
    mix-blend-mode: screen;
    filter: brightness(0) invert(1); /* Lo vuelve blanco */
    transition: filter 0.4s ease, transform 0.4s ease, height 0.4s ease;
    transform: scale(1.3);
    transform-origin: left center; /* Lo ancla a la izquierda */
  }

  .header.is-scrolled .header__logo-img {
    filter: none;
    mix-blend-mode: multiply;
    height: 40px; /* Se encoge un poco más al hacer scroll */
  }

  /* NAV LINKS */
  .header__nav-desktop { flex: 2; }
  .header__nav-list {
    display: flex;
    justify-content: center;
    gap: 3rem;
    list-style: none;
    padding: 0; margin: 0;
  }
  .header__nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .header__nav-link.is-shop { font-weight: 500; border-bottom: 1px solid currentColor; }

  /* DERECHA */
  .header__right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 2.5rem;
  }
  .header__lang {
    background: none; border: none; cursor: pointer;
    font-family: 'Jost', sans-serif; font-size: 0.85rem; font-weight: 500;
    color: inherit;
  }
  #langOther { opacity: 0.5; }

  /* BOTÓN CONVERSEMOS */
  .header__cta {
    background: white; 
    color: black;
    padding: 12px 24px;
    font-family: 'Jost', sans-serif; font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.1em;
    text-decoration: none; 
    border-radius: 2px;
    transition: all 0.3s ease;
    border: 1px solid white;
  }

  .header__cta:hover {
    background: black;
    color: white;
    border-color: black;
  }

  .header.is-scrolled .header__cta {
    background: #111;
    color: white;
    border-color: #111;
  }
  .header.is-scrolled .header__cta:hover {
    background: transparent;
    color: #111;
  }

  /* BURGER (Adiós punto blanco) */
  .header__burger {
    display: none; /* Totalmente oculto en computadora */
    flex-direction: column; 
    gap: 5px; 
    background: none; 
    border: none; 
    cursor: pointer;
  }
  .header__burger span { 
    background: currentColor; 
    width: 25px; 
    height: 1.5px; 
  }

  /* MENÚ MÓVIL (OCULTO POR DEFECTO) */
  .header__mobile-menu {
    position: fixed; top: 0; right: 0; width: 100%; height: 100vh;
    background: #F9F8F5; display: none; 
    align-items: center; justify-content: center;
    z-index: 999;
  }
  .header__mobile-menu.is-open { display: flex; }
  .header__mobile-nav { display: flex; flex-direction: column; gap: 2rem; align-items: center; }
  .header__mobile-link { font-family: 'Jost', sans-serif; font-size: 1.2rem; text-decoration: none; color: #111; text-transform: uppercase; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .header__nav-desktop, .header__cta, .header__lang-wrapper { display: none; }
    .header__burger { display: flex; } /* Solo aparece en tablet/celular */
  }
</style>

<script is:inline>
  function initHeader() {
    try {
      const header = document.getElementById('header');
      const logoLink = document.getElementById('headerLogoLink');
      const nav = document.getElementById('navDesktop');
      const actions = document.getElementById('headerActions');
      const langContainer = document.getElementById('langContainer');

      // 1. ANIMACIÓN DE ENTRADA (GSAP)
      if (window.gsap && window.innerWidth > 1024 && logoLink && nav && actions) {
        const logoRect = logoLink.getBoundingClientRect();
        const xOffset = (window.innerWidth / 2) - (logoRect.left + logoRect.width / 2);

        gsap.set(logoLink, { x: xOffset });
        gsap.set([nav, actions], { opacity: 0, y: 10 });

        const tl = gsap.timeline({ delay: 1.5 }); // Espera a que termine el Loader
        
        tl.to(logoLink, { x: 0, duration: 1.6, ease: "power3.inOut" })
          .to([nav, actions], { opacity: 1, y: 0, duration: 0.8, stagger: 0.15 }, "-=0.6");
      }

      // 2. SCROLL LOGIC (Encoger header)
      window.addEventListener('scroll', () => {
        if (window.scrollY > 60) {
          header?.classList.add('is-scrolled');
        } else {
          header?.classList.remove('is-scrolled');
        }
      });

      // 3. CAMBIO DE IDIOMA
      const langBtn = document.getElementById('langToggle');
      let currentLang = 'ES';
      
      langBtn?.addEventListener('click', () => {
        // Cambiamos el idioma inmediatamente
        currentLang = currentLang === 'ES' ? 'EN' : 'ES';
        document.getElementById('langLabel').textContent = currentLang;
        document.getElementById('langOther').textContent = currentLang === 'ES' ? 'EN' : 'ES';
        
        // Efecto visual suave y rápido
        if (window.gsap) {
          gsap.fromTo(langContainer, { scale: 1 }, { scale: 1.1, duration: 0.1, yoyo: true, repeat: 1 });
        }
      });

      // 4. SCROLL SUAVE PARA LOS LINKS
      document.querySelectorAll('.header__nav-link, .header__mobile-link, .header__cta').forEach(link => {
        link.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          
          // Solo aplicar smooth scroll si es un anclaje interno (#)
          if (href && href.startsWith('#')) {
            e.preventDefault();
            const targetSection = document.querySelector(href);
            
            if (targetSection) {
              // Calculamos la posición considerando que el header encogido mide 65px
              const offsetPosition = targetSection.getBoundingClientRect().top + window.scrollY - 65;
              
              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });
            }
          }
        });
      });

      // 5. MENÚ MÓVIL
      const burger = document.getElementById('menuToggle');
      const mobileMenu = document.getElementById('mobileMenu');
      burger?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('is-open');
      });

    } catch (e) { console.error("Error en Header:", e); }
  }

  // Ejecutamos cuando cargue la página
  window.addEventListener('load', initHeader);
</script>