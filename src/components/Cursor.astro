---
---

<div class="cursor" id="cursor">
  <div class="cursor__dot" id="cursorDot"></div>
  <div class="cursor__ring" id="cursorRing"></div>
</div>

<style is:global>
  @media (pointer: fine) {
    *, *::before, *::after { cursor: none !important; }
  }

  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 99999;
    pointer-events: none;
  }

  /* Punto central — más grande y sólido */
  .cursor__dot {
    position: fixed;
    width: 6px;
    height: 6px;
    background: #2C2420;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.12s ease, height 0.12s ease, background 0.12s ease, opacity 0.12s ease;
    will-change: left, top;
    /* Sombra para que nunca se pierda sobre cualquier fondo */
    box-shadow:
      0 0 0 2px rgba(255,255,255,0.45),
      0 0 7px rgba(0,0,0,0.25);
  }

  /* Anillo exterior — más grueso y visible */
  .cursor__ring {
    position: fixed;
    width: 34px;
    height: 34px;
    border: 1.5px solid rgba(44, 36, 32, 0.55);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition:
      width 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      height 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.22s ease,
      border-width 0.22s ease,
      background 0.22s ease,
      opacity 0.22s ease;
    will-change: left, top;
    /* Sombra doble: oscura + clara para contrastar sobre cualquier fondo */
    box-shadow:
      0 0 0 0.5px rgba(255,255,255,0.2),
      0 0 8px rgba(0,0,0,0.12);
  }

  /* ── Hover en links/botones ── */
  .cursor--hovering .cursor__dot {
    width: 7px;
    height: 7px;
    background: rgb(100, 85, 60);
    box-shadow:
      0 0 0 1.5px rgba(255,255,255,0.45),
      0 0 6px rgba(100, 85, 60, 0.3);
  }

  .cursor--hovering .cursor__ring {
    width: 46px;
    height: 46px;
    border-color: rgba(100, 85, 60, 0.65);
    border-width: 1.5px;
    background: rgba(100, 85, 60, 0.05);
  }

  /* ── Hover sobre cards/imágenes → círculo "VER" ── */
  .cursor--image .cursor__dot {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .cursor--image .cursor__ring {
    width: 72px;
    height: 72px;
    border-color: rgba(44, 36, 32, 0.6);
    border-width: 1px;
    background: rgba(44, 36, 32, 0.05);
    box-shadow:
      0 0 0 0.5px rgba(255,255,255,0.15),
      0 0 12px rgba(0,0,0,0.1);
  }

  .cursor--image .cursor__ring::after {
    content: 'VER';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Jost', 'Manrope', system-ui, sans-serif;
    font-size: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: rgba(44, 36, 32, 0.8);
  }

  /* ── Sobre fondo oscuro ── */
  .cursor--dark .cursor__dot {
    background: rgba(240, 237, 232, 0.95);
    box-shadow:
      0 0 0 1.5px rgba(0,0,0,0.3),
      0 0 6px rgba(240,237,232,0.2);
  }

  .cursor--dark .cursor__ring {
    border-color: rgba(240, 237, 232, 0.5);
    box-shadow:
      0 0 0 0.5px rgba(0,0,0,0.2),
      0 0 8px rgba(240,237,232,0.08);
  }

  .cursor--dark.cursor--hovering .cursor__dot {
    background: #C4A882;
    box-shadow:
      0 0 0 1.5px rgba(0,0,0,0.3),
      0 0 8px rgba(196,168,130,0.35);
  }

  .cursor--dark.cursor--hovering .cursor__ring {
    border-color: rgba(196, 168, 130, 0.65);
    background: rgba(196, 168, 130, 0.07);
  }

  .cursor--dark.cursor--image .cursor__ring {
    border-color: rgba(240, 237, 232, 0.55);
    background: rgba(240, 237, 232, 0.06);
  }

  .cursor--dark.cursor--image .cursor__ring::after {
    color: rgba(240, 237, 232, 0.9);
  }

  /* ── Click ── */
  .cursor--clicking .cursor__dot {
    width: 9px;
    height: 9px;
  }

  .cursor--clicking .cursor__ring {
    width: 26px;
    height: 26px;
    border-color: rgba(44, 36, 32, 0.8);
  }

  /* Solo desktop */
  @media (pointer: coarse) {
    .cursor { display: none; }
  }
</style>

<script is:inline>
  (function () {
    const dot  = document.getElementById('cursorDot')
    const ring = document.getElementById('cursorRing')
    const root = document.getElementById('cursor')

    if (!dot || !ring || !root) return
    if (!window.matchMedia('(pointer: fine)').matches) return

    let mouseX = 0, mouseY = 0
    let ringX  = 0, ringY  = 0
    let darkMode = false

    // ── Dot: sigue exacto sin lag ──
    document.addEventListener('mousemove', function (e) {
      mouseX = e.clientX
      mouseY = e.clientY
      dot.style.left = mouseX + 'px'
      dot.style.top  = mouseY + 'px'
    }, { passive: true })

    // ── Ring: lag reducido a 0.28 — más rápido, menos pérdida ──
    function animateRing() {
      ringX += (mouseX - ringX) * 0.24
      ringY += (mouseY - ringY) * 0.24
      ring.style.left = ringX + 'px'
      ring.style.top  = ringY + 'px'
      requestAnimationFrame(animateRing)
    }
    animateRing()

    // ── Detectar si el lightbox está abierto ──
    function checkDarkContext() {
      const lb = document.getElementById('lightbox')
      const isOpen = lb && lb.classList.contains('is-open')
      if (isOpen !== darkMode) {
        darkMode = isOpen
        root.classList.toggle('cursor--dark', darkMode)
      }
    }

    const lb = document.getElementById('lightbox')
    if (lb) {
      new MutationObserver(checkDarkContext).observe(lb, {
        attributes: true,
        attributeFilter: ['class']
      })
    }

    // ── Hover targets ──
    const hoverTargets = 'a, button, [data-id], .port__card, input, textarea, select, label'

    document.addEventListener('mouseover', function (e) {
      const target = e.target.closest(hoverTargets)
      if (!target) {
        root.classList.remove('cursor--hovering', 'cursor--image')
        return
      }
      const isCard = target.classList.contains('port__card')
      root.classList.remove('cursor--hovering', 'cursor--image')
      if (isCard) {
        root.classList.add('cursor--image')
      } else {
        root.classList.add('cursor--hovering')
      }
    })

    document.addEventListener('mouseout', function (e) {
      const target = e.target.closest(hoverTargets)
      if (!target) return
      root.classList.remove('cursor--hovering', 'cursor--image')
    })

    // ── Click ──
    document.addEventListener('mousedown', function () {
      root.classList.add('cursor--clicking')
    })
    document.addEventListener('mouseup', function () {
      root.classList.remove('cursor--clicking')
    })

    // ── Visibilidad al salir de ventana ──
    document.addEventListener('mouseleave', function () {
      root.style.opacity = '0'
    })
    document.addEventListener('mouseenter', function () {
      root.style.opacity = '1'
    })
  })()
</script>