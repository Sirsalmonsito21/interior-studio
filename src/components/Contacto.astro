---

<section class="contact" id="contacto">
  <div class="contact__inner">

    <div class="contact__info">
      <span class="label contact__label">Contacto</span>
      <h2 class="contact__title">
        Hablemos de<br />
        <em>tu proyecto</em>
      </h2>
      <p class="contact__desc">
        Cuéntanos tu visión. Nos pondremos en contacto
        en menos de 24 horas para agendar una primera conversación.
      </p>
    </div>

    <div class="contact__form-wrap">
      <form class="contact__form" id="contactForm" novalidate>

        <div class="contact__row">
          <div class="contact__field">
            <label class="contact__field-label" for="nombre">Nombre</label>
            <input
              class="contact__input"
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Tu nombre completo"
              required
            />
          </div>
          <div class="contact__field">
            <label class="contact__field-label" for="email">Email</label>
            <input
              class="contact__input"
              type="email"
              id="email"
              name="email"
              placeholder="tu@email.com"
              required
            />
          </div>
        </div>

        <div class="contact__field">
          <label class="contact__field-label" for="servicio">¿En qué podemos ayudarte?</label>
          <select class="contact__select" id="servicio" name="servicio" required>
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="residencial">Diseño Residencial</option>
            <option value="comercial">Diseño Comercial</option>
            <option value="infantil">Diseño Infantil / Kids</option>
            <option value="otro">Otro</option>
          </select>
        </div>

        <div class="contact__field">
          <label class="contact__field-label" for="mensaje">Mensaje</label>
          <textarea
            class="contact__textarea"
            id="mensaje"
            name="mensaje"
            rows="4"
            placeholder="Cuéntanos un poco más..."
            required
          ></textarea>
        </div>

        <button class="contact__submit" type="submit">
          <span class="contact__submit-text">Enviar mensaje</span>
        </button>

        <div class="contact__feedback" id="formFeedback"></div>
      </form>
    </div>

  </div>
</section>

<style>
  .contact {
    background: #0a0a08;
    padding: 8rem 5vw; /* Reducido un poco para tablets */
    color: #fff;
    overflow: hidden; /* Evita cualquier desborde lateral */
  }

  .contact__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem; /* Reducido de 8rem para que quepa mejor en laptops */
    align-items: center;
  }

  .contact__info {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact__label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .contact__title {
    font-size: clamp(2.2rem, 5vw, 3.8rem); /* Ajustado el mínimo */
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .contact__desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 400px;
    margin: 0 auto;
  }

  .contact__form-wrap {
    background: #111;
    padding: 3.5rem; /* Ajustado */
    border: 1px solid rgba(255, 255, 255, 0.05);
    width: 100%; /* Asegura que no crezca más que su contenedor */
    box-sizing: border-box; /* Crucial para que el padding no sume al ancho */
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .contact__field {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
  }

  .contact__field-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
    color: #fff;
  }

  .contact__input, .contact__select, .contact__textarea {
    padding: 1rem 0;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #fff;
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }

  .contact__input::placeholder, .contact__textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .contact__submit {
    width: 100%;
    background: #fff;
    color: #000;
    border: none;
    padding: 1.2rem;
    text-transform: uppercase;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  /* --- MEDIA QUERIES --- */

  /* Para Laptops pequeñas / Tablets grandes */
  @media (max-width: 1100px) {
    .contact__inner {
      gap: 3rem;
    }
    .contact__form-wrap {
      padding: 2.5rem;
    }
  }

  /* Para Tablets y Móviles */
  @media (max-width: 900px) {
    .contact {
      padding: 6rem 5vw;
    }
    .contact__inner {
      grid-template-columns: 1fr; /* Una sola columna */
      gap: 4rem;
    }
    .contact__info {
      text-align: center;
    }
  }

  /* Específico para Teléfonos */
  @media (max-width: 600px) {
    .contact__row {
      grid-template-columns: 1fr; /* Nombre y Email uno debajo del otro */
      gap: 0;
    }
    .contact__form-wrap {
      padding: 2rem 1.5rem; /* Padding más pequeño para que respire en el cel */
    }
    .contact__title {
      font-size: 2.5rem; /* Tamaño fijo cómodo para móvil */
    }
  }
</style>