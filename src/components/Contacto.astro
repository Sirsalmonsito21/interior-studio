---
---

<section class="contact" id="contacto">
  <div class="contact__inner">

    <div class="contact__info">
      <span class="label contact__label" data-i18n="contact.label">Contacto</span>
      <h2 class="contact__title">
        <span data-i18n="contact.titulo.1">Hablemos de</span><br />
        <em data-i18n="contact.titulo.2">tu proyecto</em>
      </h2>
      <p class="contact__desc" data-i18n="contact.desc">
        Cuéntanos tu visión. Nos pondremos en contacto lo antes posible.
      </p>
    </div>

    <div class="contact__form-wrap">
      <form class="contact__form" id="contactForm" novalidate>

        <div class="contact__row">
          <div class="contact__field">
            <label class="contact__field-label" for="nombre" data-i18n="contact.nombre.label">Nombre</label>
            <input class="contact__input" type="text" id="nombre" name="nombre" data-i18n-ph="contact.nombre.ph" placeholder="Tu nombre completo" required />
          </div>
          <div class="contact__field">
            <label class="contact__field-label" for="email" data-i18n="contact.email.label">Email</label>
            <input class="contact__input" type="email" id="email" name="email" placeholder="tu@email.com" required />
          </div>
        </div>

        <div class="contact__field">
          <label class="contact__field-label" for="servicio" data-i18n="contact.servicio.label">¿En qué podemos ayudarte?</label>
          <select class="contact__select" id="servicio" name="servicio" required>
            <option value="" disabled selected data-i18n="contact.servicio.ph">Selecciona una opción</option>
            <option value="residencial" data-i18n="contact.op.residencial">Diseño Residencial</option>
            <option value="comercial"   data-i18n="contact.op.comercial">Diseño Comercial</option>
            <option value="infantil"    data-i18n="contact.op.infantil">Diseño Infantil / Kids</option>
            <option value="otro"        data-i18n="contact.op.otro">Otro</option>
          </select>
        </div>

        <div class="contact__field">
          <label class="contact__field-label" for="mensaje" data-i18n="contact.mensaje.label">Mensaje</label>
          <textarea class="contact__textarea" id="mensaje" name="mensaje" rows="4" data-i18n-ph="contact.mensaje.ph" placeholder="Cuéntanos un poco más..." required></textarea>
        </div>

        <button class="contact__submit" type="submit">
          <span class="contact__submit-text" data-i18n="contact.btn">Enviar mensaje</span>
        </button>

        <div class="contact__feedback" id="formFeedback"></div>
      </form>
    </div>

  </div>
</section>

<style>
  .contact__select option {
    background: #111;
    color: #fff;
  }

  .contact {
    background: #0a0a08;
    padding: 8rem 5vw;
    color: #fff;
    overflow: hidden;
  }

  .contact__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .contact__info {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact__label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .contact__title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .contact__desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 400px;
    margin: 0 auto;
  }

  .contact__form-wrap {
    background: #111;
    padding: 3.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    width: 100%;
    box-sizing: border-box;
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .contact__field {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
  }

  .contact__field-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
    color: #fff;
  }

  .contact__input,
  .contact__select,
  .contact__textarea {
    padding: 1rem 0;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #fff;
    outline: none;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.3s ease;
  }

  .contact__input:focus,
  .contact__select:focus,
  .contact__textarea:focus {
    border-bottom-color: rgba(255, 255, 255, 0.7);
  }

  .contact__input.error,
  .contact__select.error,
  .contact__textarea.error {
    border-bottom-color: #e07070;
  }

  .contact__input::placeholder,
  .contact__textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .contact__submit {
    width: 100%;
    background: #fff;
    color: #000;
    border: none;
    padding: 1.2rem;
    text-transform: uppercase;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }

  .contact__submit:hover {
    background: #25D366;
    color: #fff;
  }

  .contact__submit svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .contact__feedback {
    margin-top: 1rem;
    font-size: 0.85rem;
    min-height: 1.2rem;
    text-align: center;
  }

  .contact__feedback.error {
    color: #e07070;
  }

  @media (max-width: 1100px) {
    .contact__inner { gap: 3rem; }
    .contact__form-wrap { padding: 2.5rem; }
  }

  @media (max-width: 900px) {
    .contact { padding: 6rem 5vw; }
    .contact__inner { grid-template-columns: 1fr; gap: 4rem; }
    .contact__info { text-align: center; }
  }

  @media (max-width: 600px) {
    .contact__row { grid-template-columns: 1fr; gap: 0; }
    .contact__form-wrap { padding: 2rem 1.5rem; }
    .contact__title { font-size: 2.5rem; }
  }
</style>

<script is:inline>
  function initContactForm() {
    const form     = document.getElementById('contactForm')
    const feedback = document.getElementById('formFeedback')
    if (!form) return

    form.addEventListener('submit', function (e) {
      e.preventDefault()

      const nombre   = document.getElementById('nombre')
      const email    = document.getElementById('email')
      const servicio = document.getElementById('servicio')
      const mensaje  = document.getElementById('mensaje')

      // Limpiar errores previos
      ;[nombre, email, servicio, mensaje].forEach(el => el.classList.remove('error'))
      feedback.textContent = ''
      feedback.className = 'contact__feedback'

      // Validación
      const lang = window.__lang || 'ES'
      let valid = true

      if (!nombre.value.trim()) {
        nombre.classList.add('error')
        valid = false
      }
      if (!email.value.trim() || !email.value.includes('@')) {
        email.classList.add('error')
        valid = false
      }
      if (!servicio.value) {
        servicio.classList.add('error')
        valid = false
      }
      if (!mensaje.value.trim()) {
        mensaje.classList.add('error')
        valid = false
      }

      if (!valid) {
        feedback.textContent = lang === 'ES'
          ? 'Por favor completa todos los campos.'
          : 'Please fill in all fields.'
        feedback.className = 'contact__feedback error'
        return
      }

      // Armar el mensaje para WhatsApp
      const servicioTexto = servicio.options[servicio.selectedIndex].text

      const mensajeWS = lang === 'ES'
        ? `Hola Studio2810!\n\n*Nombre:* ${nombre.value.trim()}\n*Email:* ${email.value.trim()}\n*Servicio:* ${servicioTexto}\n*Mensaje:* ${mensaje.value.trim()}`
: `Hello Studio2810!\n\n*Name:* ${nombre.value.trim()}\n*Email:* ${email.value.trim()}\n*Service:* ${servicioTexto}\n*Message:* ${mensaje.value.trim()}`

      const url = `https://wa.me/51912813145?text=${encodeURIComponent(mensajeWS)}`

      window.open(url, '_blank')

      // Limpiar el form
      form.reset()
    })
  }

  document.addEventListener('DOMContentLoaded', initContactForm)
  document.addEventListener('astro:after-swap', initContactForm)
</script>